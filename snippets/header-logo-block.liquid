{%- comment -%}
  MTW header logo lockup (Option B). Wagon mark via CSS mask so it
  inherits the ink color; Cormorant wordmark + tagline beside it.
  Namespaced .mtw-logo so it cannot collide with Impulse styles.
  Mark asset: mytoywagon-logo-mark.png in Shopify Files (2541x1105).
{%- endcomment -%}

{%- liquid
  assign mark_url = 'mytoywagon-logo-mark.png' | file_url
-%}

{%- style -%}
  /* Let the lockup size itself instead of Impulse's fixed logo width */
  .header-item--logo,
  .header-layout--left-center .header-item--logo {
    -webkit-box-flex: 0; -ms-flex: 0 1 auto; flex: 0 1 auto; max-width: none;
  }
  .site-header__logo { width: auto; max-width: none; margin: 0; }

  .mtw-logo {
    --mtw-ink: #2C2C2A; --mtw-cream: #F5F0E5; --mtw-stone: #5F5E5A;
    display: inline-flex; align-items: center; gap: 16px;
    text-decoration: none; line-height: 1; max-width: 100%;
  }
  .mtw-logo__mark {
    height: 56px; width: 129px; flex-shrink: 0; display: block;
    background-color: var(--mtw-ink);
    -webkit-mask: url('{{ mark_url }}') center / contain no-repeat;
            mask: url('{{ mark_url }}') center / contain no-repeat;
  }
  .mtw-logo__text { display: flex; flex-direction: column; align-items: flex-start; line-height: 1; min-width: 0; }
  .mtw-logo__wordmark {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 22px; font-weight: 500; letter-spacing: 0.24em;
    text-transform: uppercase; color: var(--mtw-ink); white-space: nowrap; line-height: 1;
  }
  .mtw-logo__tagline {
    display: block; margin-top: 8px;
    font-family: 'Mulish', sans-serif; font-size: 9.5px; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--mtw-stone); white-space: nowrap;
  }

  @media only screen and (max-width: 900px) {
    .mtw-logo { gap: 12px; }
    .mtw-logo__mark { height: 46px; width: 106px; }
    .mtw-logo__wordmark { font-size: 19px; }
    .mtw-logo__tagline { font-size: 9px; margin-top: 6px; }
  }
  @media only screen and (max-width: 600px) {
    .mtw-logo { gap: 10px; }
    .mtw-logo__mark { height: 40px; width: 92px; }
    .mtw-logo__wordmark { font-size: 16px; letter-spacing: 0.2em; }
    .mtw-logo__tagline { font-size: 8px; margin-top: 5px; letter-spacing: 0.16em; }
  }
  @media only screen and (max-width: 380px) {
    .mtw-logo__mark { height: 36px; width: 83px; }
    .mtw-logo__tagline { display: none; }
  }

  /* Inverted on dark / image-overlay headers (Impulse adds .is-light) */
  .is-light .mtw-logo__mark,
  .mtw-logo--inverted .mtw-logo__mark { background-color: var(--mtw-cream); }
  .is-light .mtw-logo__wordmark,
  .mtw-logo--inverted .mtw-logo__wordmark { color: var(--mtw-cream); }
  .is-light .mtw-logo__tagline,
  .mtw-logo--inverted .mtw-logo__tagline { color: rgba(245, 240, 229, 0.7); }
{%- endstyle -%}

{%- if template == 'index' -%}
  <h1 class="site-header__logo" itemscope itemtype="http://schema.org/Organization">
    <span class="visually-hidden">{{ shop.name }}</span>
{%- else -%}
  <div class="h1 site-header__logo" itemscope itemtype="http://schema.org/Organization">
{%- endif -%}

  <a href="{{ routes.root_url }}" itemprop="url" class="mtw-logo" aria-label="{{ shop.name | escape }}">
    <span class="mtw-logo__mark" aria-hidden="true"></span>
    <span class="mtw-logo__text">
      <span class="mtw-logo__wordmark">My Toy Wagon</span>
      <span class="mtw-logo__tagline">Los Angeles &middot; California &middot; est. 2020</span>
    </span>
  </a>

{%- if template == 'index' -%}
  </h1>
{%- else -%}
  </div>
{%- endif -%}
