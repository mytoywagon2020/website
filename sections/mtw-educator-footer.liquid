{%- comment -%}MTW Educator Footer — replaces the retail footer on educator templates.{%- endcomment -%}
<style>
  .mtw-edu-f{background:#F5F0E5;border-top:1px solid rgba(44,44,42,.12);font-family:'Mulish',sans-serif;color:#2C2C2A;padding:56px 0 28px;margin-top:64px;}
  .mtw-edu-f__in{max-width:1440px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;}
  .mtw-edu-f__brand h3{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:500;font-size:24px;color:#2C2C2A;margin:0 0 10px;}
  .mtw-edu-f__brand p{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:15px;color:#5F5E5A;margin:0 0 16px;line-height:1.55;max-width:380px;}
  .mtw-edu-f__brand a{display:inline-block;font-size:13px;font-weight:600;color:#2C2C2A;text-decoration:none;}
  .mtw-edu-f__brand a:hover{color:#3B6D11;}
  .mtw-edu-f__col h4{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:500;font-size:18px;color:#2C2C2A;margin:0 0 16px;}
  .mtw-edu-f__col ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:10px;}
  .mtw-edu-f__col a{font-size:13.5px;color:#2C2C2A;text-decoration:none;}
  .mtw-edu-f__col a:hover{color:#3B6D11;}
  .mtw-edu-f__pay{max-width:1440px;margin:36px auto 0;padding:22px 40px 0;border-top:1px solid rgba(44,44,42,.1);display:flex;align-items:center;flex-wrap:wrap;gap:12px 20px;}
  .mtw-edu-f__pay-label{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:15px;color:#5F5E5A;}
  .mtw-edu-f__terms{display:flex;gap:8px;flex-wrap:wrap;}
  .mtw-edu-f__term{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#3B6D11;background:#edf4e6;border-radius:3px;padding:5px 9px;white-space:nowrap;}
  .mtw-edu-f__cards{display:flex;gap:7px;flex-wrap:wrap;margin-left:auto;}
  .mtw-edu-f__cards .pc{display:inline-flex;align-items:center;justify-content:center;width:44px;height:28px;border:1px solid rgba(44,44,42,.16);border-radius:4px;background:#FFFCF7;color:#5F5E5A;}
  .mtw-edu-f__cards .pc--wide{width:56px;}
  .mtw-edu-f__cards .pc svg{height:14px;width:auto;display:block;}
  .mtw-edu-f__bot{max-width:1440px;margin:24px auto 0;padding:24px 40px 0;border-top:1px solid rgba(44,44,42,.1);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;}
  .mtw-edu-f__bot span{font-size:11.5px;color:#5F5E5A;letter-spacing:.06em;}
  .mtw-edu-f__legal{display:flex;gap:18px;}
  .mtw-edu-f__legal a{font-size:11.5px;color:#5F5E5A;text-decoration:none;}
  .mtw-edu-f__legal a:hover{color:#2C2C2A;}
  @media(max-width:720px){.mtw-edu-f{padding:40px 0 22px;margin-top:40px;}.mtw-edu-f__in{grid-template-columns:1fr;padding:0 24px;gap:28px;}.mtw-edu-f__bot{padding:20px 24px 0;}}
</style>
<footer class="mtw-edu-f" role="contentinfo">
  <div class="mtw-edu-f__in">
    <div class="mtw-edu-f__brand">
      <h3>The Educator Catalog</h3>
      <p>Hand curated, made to order, and built for the classroom. Net-30 and tax-exempt purchasing for approved schools.</p>
      <a href="mailto:educators@mytoywagon.com">educators@mytoywagon.com</a>
    </div>
    <div class="mtw-edu-f__col">
      <h4>Catalog</h4>
      <ul>
        <li><a href="/pages/educator-sensory-play">01 &middot; Sensory Play</a></li>
        <li><a href="/pages/educator-nature-play">02 &middot; Nature Play</a></li>
        <li><a href="/pages/educator-woodland">03 &middot; Woodland</a></li>
        <li><a href="/pages/educator-small-world">04 &middot; Small World &amp; Storytelling</a></li>
        <li><a href="/pages/educator-fairy-villages">05 &middot; Fairy Villages</a></li>
        <li><a href="/pages/educator-steam">06 &middot; STEAM</a></li>
        <li><a href="/pages/educator-dramatic-play">07 &middot; Dramatic Play</a></li>
        <li><a href="/pages/educator-creative-arts">08 &middot; Creative Arts</a></li>
      </ul>
    </div>
    <div class="mtw-edu-f__col">
      <h4>Account</h4>
      <ul>
        <li><a href="/pages/educators">Catalog home</a></li>
        <li><a href="/pages/educator-dashboard">Dashboard</a></li>
        <li><a href="/pages/new-quote">Request a quote</a></li>
        <li><a href="/pages/educator-login">Sign in</a></li>
        <li><a href="/pages/educator-register">Apply for access</a></li>
      </ul>
    </div>
    <div class="mtw-edu-f__col">
      <h4>Procurement</h4>
      <ul>
        <li><a href="/pages/procurement-guide">Procurement guide</a></li>
        <li><a href="/pages/vendor-profile">Vendor profile</a></li>
        <li><a href="/pages/educator-catalog-guide">Catalog guide</a></li>
        <li><a href="mailto:educators@mytoywagon.com">W-9, COI, sole-source letters</a></li>
      </ul>
    </div>
  </div>
  <div class="mtw-edu-f__pay">
    <span class="mtw-edu-f__pay-label">We accept</span>
    <div class="mtw-edu-f__terms">
      <span class="mtw-edu-f__term">Purchase orders</span>
      <span class="mtw-edu-f__term">Net-30</span>
      <span class="mtw-edu-f__term">Tax-exempt</span>
    </div>
    <div class="mtw-edu-f__cards" aria-label="Accepted cards and wallets">
      <span class="pc" role="img" aria-label="Visa"><svg viewBox="0 0 40 14" fill="currentColor"><text x="20" y="11.5" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="700" font-style="italic" font-size="13" letter-spacing="1">VISA</text></svg></span>
      <span class="pc" role="img" aria-label="Mastercard"><svg viewBox="0 0 34 22" fill="currentColor"><circle cx="13" cy="11" r="9" fill-opacity=".8"/><circle cx="21" cy="11" r="9" fill-opacity=".42"/></svg></span>
      <span class="pc" role="img" aria-label="American Express"><svg viewBox="0 0 40 14" fill="currentColor"><text x="20" y="11" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="800" font-size="10" letter-spacing="1">AMEX</text></svg></span>
      <span class="pc pc--wide" role="img" aria-label="Discover"><svg viewBox="0 0 64 14" fill="currentColor"><text x="32" y="11" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="700" font-size="10" letter-spacing=".4">DISCOVER</text></svg></span>
      <span class="pc pc--wide" role="img" aria-label="Apple Pay"><svg viewBox="0 0 46 16" fill="currentColor"><path d="M9.2 5.4c-.5.6-1.2 1-1.9 1-.1-.7.2-1.4.6-1.9.5-.5 1.3-1 1.9-1 .1.7-.1 1.4-.6 1.9zm.6 1c-1-.06-1.9.6-2.4.6-.5 0-1.2-.55-2-.55-1 0-2 .6-2.5 1.5-1.1 1.9-.3 4.7.8 6.2.5.7 1.1 1.5 1.9 1.5.7 0 1-.45 1.9-.45.8 0 1.1.45 1.9.44.8-.01 1.3-.7 1.8-1.4.5-.7.7-1.2.7-1.25-1.9-.7-2.2-3.4-.4-4.4-.6-.85-1.6-1-1.9-1z"/><text x="25" y="13" font-family="Arial,Helvetica,sans-serif" font-weight="600" font-size="11">Pay</text></svg></span>
      <span class="pc pc--wide" role="img" aria-label="Google Pay"><svg viewBox="0 0 48 16" fill="currentColor"><text x="24" y="12.5" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="600" font-size="12">G Pay</text></svg></span>
      <span class="pc pc--wide" role="img" aria-label="PayPal"><svg viewBox="0 0 52 16" fill="currentColor"><text x="26" y="12.5" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="700" font-style="italic" font-size="12">PayPal</text></svg></span>
      <span class="pc pc--wide" role="img" aria-label="Shop Pay"><svg viewBox="0 0 54 16" fill="currentColor"><text x="27" y="12.5" text-anchor="middle" font-family="Arial,Helvetica,sans-serif" font-weight="700" font-size="11">Shop&nbsp;Pay</text></svg></span>
    </div>
  </div>
  <div class="mtw-edu-f__bot">
    <span>&copy; {{ 'now' | date: '%Y' }} My Toy Wagon. Heirloom toys, curated by hand.</span>
    <div class="mtw-edu-f__legal">
      <a href="/policies/privacy-policy">Privacy</a>
      <a href="/policies/terms-of-service">Terms</a>
      <a href="/pages/accessibility">Accessibility</a>
    </div>
  </div>
</footer>
{% schema %}
{
  "name": "MTW Educator Footer",
  "settings": [],
  "presets": [{ "name": "MTW Educator Footer" }]
}
{% endschema %}
