{%- style -%}
  .image-grid--{{ section.id }} {
    --image-grid-gap: {{ section.settings.grid_spacing }}px;
    --image-grid-columns: {{ section.settings.images_per_row }};
    --image-grid-overlay-color: {{ section.settings.overlay_color }};
    --image-grid-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --image-grid-overlay-hover-increment: {% if section.settings.overlay_opacity == 0 %}0{% else %}0.1{% endif %};
    --image-grid-overlay-text-color: {{ section.settings.overlay_text_color }};
  }
{%- endstyle -%}

{%- if section.settings.divider -%}<div class="section--divider">{%- endif -%}

<div class="image-grid image-grid--{{ section.id }}{% if section.settings.space_above %} image-grid--space-top{% endif %}{% if section.settings.space_below %} image-grid--space-bottom{% endif %}">
  {%- unless section.settings.full_width -%}<div class="page-width">{%- endunless -%}

  {%- if section.settings.heading != blank -%}
    <div class="section-header text-{{ section.settings.text_alignment }}">
      <h2 class="section-header__title {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    {%- assign loading = 'lazy' -%}
    {%- if section.index <= 2 -%}
      {%- assign loading = 'eager' -%}
    {%- endif -%}
    <ul class="image-grid__grid image-grid__grid--{{ section.settings.image_shape }}" role="list">
      {%- for block in section.blocks -%}
        {%- liquid
          assign block_image = block.settings.image
          assign block_heading = block.settings.heading

          if block.settings.link != blank
            if block.settings.link contains '/collections/'
              assign url_handle = block.settings.link | split: '/collections/' | last | split: '/' | first | split: '?' | first
              assign linked_object = collections[url_handle]
              if block_image == blank and linked_object.image
                assign block_image = linked_object.image
              endif
              if block_heading == blank
                assign block_heading = linked_object.title
              endif
            elsif block.settings.link contains '/products/'
              assign url_handle = block.settings.link | split: '/products/' | last | split: '/' | first | split: '?' | first
              assign linked_object = all_products[url_handle]
              if block_image == blank and linked_object.featured_media
                assign block_image = linked_object.featured_media.preview_image
              endif
              if block_heading == blank
                assign block_heading = linked_object.title
              endif
            endif
          endif
        -%}
        <li
          class="image-grid__item"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="image-grid__link">
          {%- endif -%}

          <div class="image-grid__image-wrap">
            {%- if block_image != blank -%}
              {%- render 'image-element',
                img: block_image,
                loading: loading,
                widths: '360, 540, 720, 900, 1080',
                classes: 'image-grid__image',
                sizeVariable: section.settings.images_per_row,
                fallback: 'variable'
              -%}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
            {%- if block_heading != blank -%}
              <span class="image-grid__item-heading">{{ block_heading | escape }}</span>
            {%- endif -%}
          </div>

          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}

  {%- unless section.settings.full_width -%}</div>{%- endunless -%}
</div>

{%- if section.settings.divider -%}</div>{%- endif -%}

{% schema %}
{
  "name": "t:sections.image-grid.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.image-grid.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.image-grid.settings.heading.label",
      "default": "Image grid"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.image-grid.settings.heading_size.label",
      "default": "h2",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.image-grid.settings.heading_size.options.h3.label"
        },
        {
          "value": "h2",
          "label": "t:sections.image-grid.settings.heading_size.options.h2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.image-grid.settings.heading_size.options.h1.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.image-grid.settings.text_alignment.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-grid.settings.text_alignment.options.left.label"
        },
        {
          "value": "center",
          "label": "t:sections.image-grid.settings.text_alignment.options.center.label"
        },
        {
          "value": "right",
          "label": "t:sections.image-grid.settings.text_alignment.options.right.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.image-grid.settings.header_layout.content"
    },
    {
      "type": "range",
      "id": "images_per_row",
      "label": "t:sections.image-grid.settings.images_per_row.label",
      "info": "t:sections.image-grid.settings.images_per_row.info",
      "default": 5,
      "min": 2,
      "max": 5,
      "step": 1
    },
    {
      "type": "select",
      "id": "image_shape",
      "label": "t:sections.image-grid.settings.image_shape.label",
      "default": "square",
      "options": [
        {
          "value": "portrait",
          "label": "t:sections.image-grid.settings.image_shape.options.portrait.label"
        },
        {
          "value": "square",
          "label": "t:sections.image-grid.settings.image_shape.options.square.label"
        },
        {
          "value": "landscape",
          "label": "t:sections.image-grid.settings.image_shape.options.landscape.label"
        },
        {
          "value": "arch",
          "label": "t:sections.image-grid.settings.image_shape.options.arch.label"
        }
      ]
    },
    {
      "type": "range",
      "id": "grid_spacing",
      "label": "t:sections.image-grid.settings.grid_spacing.label",
      "default": 30,
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.image-grid.settings.full_width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "space_above",
      "label": "t:sections.image-grid.settings.space_above.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "space_below",
      "label": "t:sections.image-grid.settings.space_below.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.image-grid.settings.divider.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.image-grid.settings.header_overlay.content"
    },
    {
      "type": "color",
      "id": "overlay_text_color",
      "label": "t:sections.image-grid.settings.overlay_text_color.label",
      "info": "t:sections.image-grid.settings.overlay_text_color.info",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:sections.image-grid.settings.overlay_color.label",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.image-grid.settings.overlay_opacity.label",
      "default": 20,
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "%"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.image-grid.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.image-grid.blocks.image.settings.image.label",
          "info": "t:sections.image-grid.blocks.image.settings.image.info"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.image-grid.blocks.image.settings.link.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.image-grid.blocks.image.settings.heading.label",
          "info": "t:sections.image-grid.blocks.image.settings.heading.info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-grid.presets.image_grid.name",
      "category": "t:sections.categories.storytelling",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["footer", "header", "custom.popups"]
  }
}
{% endschema %}
