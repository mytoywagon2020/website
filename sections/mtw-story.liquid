{%- comment -%} MTW Story — centered founder narrative. {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
{%- style -%}
  #shopify-section-{{ section.id }} { background:#F5F0E5; }
  .mtw-story {
    --cream:#F5F0E5; --ink:#2C2C2A; --stone:#5F5E5A; --rule-strong:rgba(44,44,42,0.22);
    border-top:0.5px solid rgba(44,44,42,0.12); box-sizing:border-box;
    font-family:'Mulish',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; color:var(--ink);
  }
  .mtw-story *, .mtw-story *::before, .mtw-story *::after { box-sizing:border-box; }
  .mtw-story__inner { max-width:760px; margin:0 auto; padding:120px 40px 110px; text-align:center; }
  .mtw-story__label { display:block; margin-bottom:20px; font-size:11px; letter-spacing:0.18em; text-transform:uppercase; color:var(--stone); font-weight:500; }
  .mtw-story__title { font-family:'Cormorant Garamond',Georgia,serif; font-size:60px; font-weight:500; line-height:1.02; letter-spacing:-0.008em; margin:0 0 32px; }
  .mtw-story__title em { font-style:italic; }
  .mtw-story__body p { font-size:17px; line-height:1.75; margin:0 auto 18px; max-width:600px; }
  .mtw-story__lead p:first-child { font-size:18.5px; color:var(--ink); }
  .mtw-story__sign { margin:36px auto 28px; display:flex; flex-direction:column; gap:4px; }
  .mtw-story__sig { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:32px; line-height:1.1; color:var(--ink); }
  .mtw-story__role { font-size:11.5px; letter-spacing:0.18em; text-transform:uppercase; color:var(--stone); font-weight:500; }
  .mtw-story__btn { display:inline-flex; align-items:center; gap:10px; padding:14px 24px; font-size:13.5px; font-weight:500; letter-spacing:0.04em; border-radius:2px; border:0.5px solid var(--rule-strong); color:var(--ink); text-decoration:none; margin-top:12px; transition:all 160ms ease; }
  .mtw-story__btn:hover { border-color:var(--ink); }
  .mtw-story__arrow { width:14px; height:8px; position:relative; display:inline-block; }
  .mtw-story__arrow::before,.mtw-story__arrow::after { content:""; position:absolute; background:currentColor; }
  .mtw-story__arrow::before { left:0; top:50%; width:100%; height:1px; transform:translateY(-50%); }
  .mtw-story__arrow::after { right:0; top:50%; width:6px; height:6px; border-top:1px solid currentColor; border-right:1px solid currentColor; background:none; transform:translateY(-50%) rotate(45deg); }
  @media (max-width:700px) { .mtw-story__inner { padding:72px 24px; } .mtw-story__title { font-size:40px; } }
{%- endstyle -%}
<div class="mtw-story">
  <div class="mtw-story__inner">
    {%- if section.settings.label != blank -%}<span class="mtw-story__label">{{ section.settings.label }}</span>{%- endif -%}
    {%- if section.settings.title != blank -%}<h2 class="mtw-story__title">{{ section.settings.title }}</h2>{%- endif -%}
    {%- if section.settings.lead != blank -%}<div class="mtw-story__body mtw-story__lead">{{ section.settings.lead }}</div>{%- endif -%}
    {%- if section.settings.body != blank -%}<div class="mtw-story__body">{{ section.settings.body }}</div>{%- endif -%}
    {%- if section.settings.signature != blank or section.settings.role != blank -%}
      <p class="mtw-story__sign">
        {%- if section.settings.signature != blank -%}<span class="mtw-story__sig">{{ section.settings.signature }}</span>{%- endif -%}
        {%- if section.settings.role != blank -%}<span class="mtw-story__role">{{ section.settings.role }}</span>{%- endif -%}
      </p>
    {%- endif -%}
    {%- if section.settings.button_text != blank -%}
      <a class="mtw-story__btn" href="{{ section.settings.button_link | default: '/pages/our-story' }}">{{ section.settings.button_text }} <span class="mtw-story__arrow"></span></a>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "MTW Story",
  "tag": "section",
  "class": "mtw-story-section",
  "settings": [
    { "type": "text", "id": "label", "label": "Eyebrow", "default": "Our Story" },
    { "type": "inline_richtext", "id": "title", "label": "Title", "default": "A small toy shop, with a <em>big heart</em>." },
    { "type": "richtext", "id": "lead", "label": "Lead paragraph", "default": "<p>My Toy Wagon began with a simple inspiration: our two daughters, Hafsa and Noor. They are the heartbeat of the shop, the reminders that childhood is fleeting, and that the toys we choose for it matter.</p>" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>We carefully curate wooden and felt toys that hold up to real play, that scale across ages, and that pass quietly to a younger sibling. Most orders are packed and shipped by hand from our shop in Los Angeles.</p>" },
    { "type": "text", "id": "signature", "label": "Signature", "default": "Irfana & Rashid" },
    { "type": "text", "id": "role", "label": "Role", "default": "Founders, My Toy Wagon" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Read our full story" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "MTW Story" }]
}
{% endschema %}
