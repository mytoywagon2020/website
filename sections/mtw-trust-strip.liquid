{%- comment -%}
  MTW Trust Strip — 4 edge-to-edge trust cards. New namespaced section
  (.mtw-trust); each card is a block, fully editable in the theme editor
  (icon image, title, subtitle, optional corner badge, link).
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- style -%}
  #shopify-section-{{ section.id }} { background: #F5F0E5; }
  .mtw-trust {
    --cream:#F5F0E5; --warm-white:#FFFCF7; --ink:#2C2C2A; --forest:#3B6D11;
    --amber:#854F0B; --stone:#5F5E5A; --rule:rgba(44,44,42,0.12);
    --rule-strong:rgba(44,44,42,0.22);
    border-top:0.5px solid var(--rule); box-sizing:border-box;
    font-family:'Mulish',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  }
  .mtw-trust *, .mtw-trust *::before, .mtw-trust *::after { box-sizing:border-box; }
  .mtw-trust__inner {
    max-width:1200px; margin:0 auto; padding:64px 40px 76px;
    display:grid; grid-template-columns:repeat(4,1fr); gap:36px; align-items:start;
  }
  .mtw-trust__card {
    display:flex; flex-direction:column; align-items:center; text-align:center;
    gap:10px; transition:transform 220ms ease; text-decoration:none; color:inherit;
  }
  .mtw-trust__card:hover { transform:translateY(-2px); }
  .mtw-trust__visual {
    height:132px; display:flex; align-items:center; justify-content:center;
    margin-bottom:4px; position:relative;
  }
  .mtw-trust__visual img { height:132px; width:auto; object-fit:contain; display:block; }
  .mtw-trust__badge {
    position:absolute; top:12%; left:50%;
    transform:translate(-50%,-50%) rotate(-8deg);
    padding:6px 12px; background:var(--amber); color:var(--cream);
    font-family:'Cormorant Garamond',Georgia,serif; font-style:italic;
    font-size:13px; font-weight:500; letter-spacing:0.04em; border-radius:2px;
    white-space:nowrap; box-shadow:0 2px 6px rgba(44,44,42,0.18);
    border:0.5px dashed rgba(245,240,229,0.55); pointer-events:none;
  }
  .mtw-trust__divider { width:28px; height:0.5px; background:var(--rule-strong); margin:2px auto 4px; }
  .mtw-trust__title {
    font-family:'Cormorant Garamond',Georgia,serif; font-style:italic;
    font-size:22px; font-weight:500; color:var(--ink); line-height:1.1;
    margin:0; letter-spacing:-0.005em;
  }
  .mtw-trust__sub {
    font-size:13px; line-height:1.55; color:var(--stone); margin:0;
    max-width:220px; text-wrap:pretty;
  }
  @media (max-width:900px) {
    .mtw-trust__inner { grid-template-columns:repeat(2,1fr); gap:40px 24px; padding:48px 24px 56px; }
  }
  @media (max-width:520px) {
    .mtw-trust__inner { grid-template-columns:1fr; }
  }
{%- endstyle -%}

<div class="mtw-trust">
  <div class="mtw-trust__inner">
    {%- for block in section.blocks -%}
      {%- if block.settings.link != blank -%}<a class="mtw-trust__card" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{%- else -%}<div class="mtw-trust__card" {{ block.shopify_attributes }}>{%- endif -%}
        <div class="mtw-trust__visual">
          {%- if block.settings.image != blank -%}
            {%- assign img_src = block.settings.image | image_url -%}
            {%- if img_src contains '.svg' -%}
              <img src="{{ img_src }}" loading="lazy" alt="{{ block.settings.title | escape }}" width="320" height="280">
            {%- else -%}
              {{ block.settings.image | image_url: width: 320 | image_tag: loading: 'lazy', alt: block.settings.title, widths: '160, 240, 320, 440' }}
            {%- endif -%}
          {%- endif -%}
          {%- if block.settings.badge != blank -%}<span class="mtw-trust__badge">{{ block.settings.badge }}</span>{%- endif -%}
        </div>
        {%- if block.settings.title != blank -%}<h3 class="mtw-trust__title">{{ block.settings.title }}</h3>{%- endif -%}
        <div class="mtw-trust__divider"></div>
        {%- if block.settings.subtitle != blank -%}<p class="mtw-trust__sub">{{ block.settings.subtitle }}</p>{%- endif -%}
      {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "MTW Trust Strip",
  "tag": "section",
  "class": "mtw-trust-section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "card",
      "name": "Trust card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon image" },
        { "type": "text", "id": "badge", "label": "Corner badge (optional)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Trust point" },
        { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "A short supporting line." },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MTW Trust Strip",
      "blocks": [
        { "type": "card", "settings": { "title": "Free U.S. shipping", "subtitle": "On orders $150 and up, contiguous U.S.", "badge": "free shipping" } },
        { "type": "card", "settings": { "title": "Free 30-day returns", "subtitle": "If the toy isn't right, send it back, with our love." } },
        { "type": "card", "settings": { "title": "Packed with care", "subtitle": "Tissue-wrapped, with a handwritten note, free." } },
        { "type": "card", "settings": { "title": "Earn Rewards", "subtitle": "Points on every order, redeem on the next." } }
      ]
    }
  ]
}
{% endschema %}
