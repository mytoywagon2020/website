  .szl-button,
  .sezzle-checkout-button-wrapper,
  sezzle-checkout-button,
  [class*="szl-"],
  .product__price__sezzle,
  .jdgm-widget,
  .jdgm-prev-badge,
  .jdgm-rev-widg,
  .jdgm-form-wrapper,
  .judgeme-preview-badge,
  .product-share,
  .add-to-wishlist,
  .product__wishlist,
