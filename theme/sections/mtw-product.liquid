{%- comment -%}
  MTW Product (PDP). Header/footer come from the theme. Namespaced
  .mtw-pdp. Fulfillment state from product.metafields.fulfillment.type
  (in_stock | pre_order | partner_warehouse); falls back gracefully.
  Long-form copy from product.metafields.custom.* with description
  fallback so the page is never empty.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
{{ 'mtw-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign cur = product.selected_or_first_available_variant
  assign ff = product.metafields.fulfillment.type | default: ''
  assign is_pre = false
  for pc in product.collections
    if pc.handle == section.settings.preorder_collection
      assign is_pre = true
    endif
  endfor
  if ff == 'pre_order'
    assign is_pre = true
  endif
  assign state = 'in_stock'
  if is_pre
    assign state = 'pre_order'
  elsif ff == 'partner_warehouse'
    assign state = 'partner'
  elsif product.available == false
    assign state = 'sold_out'
  endif
-%}

<div class="mtw-pdp" data-mtw-pdp>
  <nav class="mtw-pdp__crumbs">
    <a href="{{ routes.root_url }}">Home</a><span class="sep">·</span>
    {%- if product.collections.first -%}<a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a><span class="sep">·</span>{%- endif -%}
    <span class="current">{{ product.title }}</span>
  </nav>

  <section class="mtw-pdp__main">
    <div class="mtw-pdp__gallery">
      <div class="mtw-pdp__thumbs">
        {%- for image in product.images limit: 6 -%}
          <button type="button" class="mtw-pdp__thumb {% if forloop.first %}active{% endif %}" data-mtw-thumb="{{ image | image_url: width: 900 }}">
            <img src="{{ image | image_url: width: 160 }}" alt="{{ image.alt | escape }}" loading="lazy">
          </button>
        {%- endfor -%}
      </div>
      <div class="mtw-pdp__mainimg">
        {%- case state -%}
          {%- when 'pre_order' -%}<span class="mtw-pdp__badge amber">Pre-order</span>
          {%- when 'partner' -%}<span class="mtw-pdp__badge amber">Ships from partner warehouse</span>
          {%- when 'sold_out' -%}<span class="mtw-pdp__badge amber">Sold out</span>
        {%- endcase -%}
        {%- if product.featured_image -%}
          <img data-mtw-main src="{{ product.featured_image | image_url: width: 1100 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" width="1100" height="1375">
        {%- endif -%}
      </div>
    </div>

    <div class="mtw-pdp__metacol">
      {%- if product.vendor != blank -%}<p class="mtw-pdp__maker"><a href="{{ product.vendor | url_for_vendor }}">{{ product.vendor }}</a></p>{%- endif -%}
      <h1 class="mtw-pdp__title">{{ product.title }}</h1>
      <div class="mtw-pdp__rating"><div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}" data-template="index"></div></div>

      <div class="mtw-pdp__price-row">
        <span class="mtw-pdp__price" data-mtw-price>
          {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
          {{ product.price | money }}
        </span>
        {%- if state == 'partner' -%}<span class="mtw-pdp__ship-pill amber">Ships from partner warehouse</span>
        {%- elsif state == 'pre_order' -%}<span class="mtw-pdp__ship-pill amber">Pre-order{% if product.metafields.fulfillment.ship_date != blank %} · ships {{ product.metafields.fulfillment.ship_date }}{% endif %}</span>
        {%- else -%}<span class="mtw-pdp__ship-pill">Free shipping over $150</span>{%- endif -%}
      </div>
      <p class="mtw-pdp__tax">Tax included where applicable. <a href="/pages/shipping">Shipping calculated at checkout.</a></p>

      {%- form 'product', product, id: 'mtw-pform', novalidate: 'novalidate' -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="mtw-pdp__vgroup">
              <div class="mtw-pdp__vlabel">{{ option.name }}</div>
              <div class="mtw-pdp__vopts" data-mtw-optgroup="{{ forloop.index0 }}">
                {%- for value in option.values -%}
                  <label class="mtw-pdp__chip {% if option.selected_value == value %}sel{% endif %}">
                    <input type="radio" name="mtw-opt-{{ forloop.parentloop.index0 }}" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} data-mtw-opt="{{ forloop.parentloop.index0 }}">
                    {{ value }}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endunless -%}
        <input type="hidden" name="id" data-mtw-vid value="{{ cur.id }}">

        <div class="mtw-pdp__add-row">
          <div class="mtw-pdp__qty">
            <button type="button" data-mtw-qm aria-label="Decrease">&minus;</button>
            <input type="text" name="quantity" value="1" data-mtw-qty inputmode="numeric" aria-label="Quantity">
            <button type="button" data-mtw-qp aria-label="Increase">+</button>
          </div>
          <button type="submit" class="mtw-pdp__btn mtw-pdp__btn--primary" data-mtw-add {% unless product.available %}disabled{% endunless %}>
            {%- if state == 'pre_order' -%}Pre-order now{%- elsif product.available -%}Add to cart{%- else -%}Sold out{%- endif -%}
          </button>
        </div>
        {%- if product.available and state != 'pre_order' -%}
          <div class="mtw-pdp__buynow">{{ form | payment_button }}</div>
        {%- endif -%}
      {%- endform -%}

      <div class="mtw-pdp__trust">
        <div class="mtw-pdp__trust-item"><svg viewBox="0 0 24 24"><path d="M3 7h13l5 5v5h-3"/><path d="M14 17H8"/><circle cx="6" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg><div><strong>Free U.S. shipping</strong>On orders $150+</div></div>
        <div class="mtw-pdp__trust-item"><svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 1 1-3-6.7"/><path d="M21 4v5h-5"/></svg><div><strong>30-day returns</strong>If the toy isn't right</div></div>
        <div class="mtw-pdp__trust-item"><svg viewBox="0 0 24 24"><path d="M4 7h16v13H4z"/><path d="M4 7l8 5 8-5"/><path d="M9 7V4h6v3"/></svg><div><strong>Packed by hand</strong>Wrapped in tissue, with care</div></div>
      </div>

      {%- if state == 'partner' -%}
        <p class="mtw-pdp__shipnote"><strong>Ships from our partner warehouse</strong> in the contiguous U.S. Standard transit 5 to 10 business days.</p>
      {%- elsif state == 'pre_order' -%}
        <p class="mtw-pdp__shipnote"><strong>Pre-order.</strong> {% if product.metafields.fulfillment.ship_date != blank %}Ships on or around {{ product.metafields.fulfillment.ship_date }}.{% else %}We'll email you when it ships.{% endif %} Your card is charged at checkout.</p>
      {%- else -%}
        <p class="mtw-pdp__shipnote"><strong>Ships within 2 to 4 business days</strong> from our Los Angeles warehouse.</p>
      {%- endif -%}
    </div>
  </section>

  <section class="mtw-pdp__desc">
    {%- assign hero_intro = product.metafields.custom.hero_intro -%}
    {%- if hero_intro != blank -%}
      <p class="mtw-pdp__hero-para">{{ hero_intro }}</p>
    {%- elsif product.description != blank -%}
      <div class="mtw-pdp__hero-para rte">{{ product.description }}</div>
    {%- endif -%}

    {%- if product.metafields.custom.why_youll_love != blank -%}
      <div class="mtw-pdp__why"><h2>Why <em>you'll love it</em></h2>{{ product.metafields.custom.why_youll_love }}</div>
    {%- endif -%}

    {%- if product.metafields.custom.at_a_glance != blank -%}
      <div class="mtw-pdp__glance"><span class="label">At a glance</span><div class="rte">{{ product.metafields.custom.at_a_glance }}</div></div>
    {%- endif -%}

    {%- if product.metafields.custom.pull_quote != blank -%}
      <p class="mtw-pdp__emotional">{{ product.metafields.custom.pull_quote }}</p>
    {%- endif -%}

    <div class="mtw-pdp__acc">
      {%- assign acc_keys = 'materials_and_construction|Materials and construction,ways_to_play|Ways to play,skills_it_builds|Skills it builds,who_it_is_for|Who it is for,care_and_storage|Care and storage,includes_set_contents|Includes / set contents,faq|FAQ' | split: ',' -%}
      {%- for pair in acc_keys -%}
        {%- assign kv = pair | split: '|' -%}
        {%- assign val = product.metafields.custom[kv[0]] -%}
        {%- if val != blank -%}
          <details {% if forloop.first %}open{% endif %}><summary>{{ kv[1] }}</summary><div class="mtw-pdp__acc-body rte">{{ val }}</div></details>
        {%- endif -%}
      {%- endfor -%}
      {%- if section.settings.shipping_text != blank -%}
        <details><summary>Shipping</summary><div class="mtw-pdp__acc-body rte">{{ section.settings.shipping_text }}</div></details>
      {%- endif -%}
      {%- if section.settings.returns_text != blank -%}
        <details><summary>Returns</summary><div class="mtw-pdp__acc-body rte">{{ section.settings.returns_text }}</div></details>
      {%- endif -%}
    </div>
  </section>

  {%- if product.metafields.custom.maker_story != blank -%}
    <section class="mtw-pdp__maker-band">
      <div class="mtw-pdp__maker-inner">
        <div class="mtw-pdp__rc-img" style="aspect-ratio:1/1;margin:0;">
          {%- if product.metafields.custom.maker_image != blank -%}{{ product.metafields.custom.maker_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.vendor }}{%- endif -%}
        </div>
        <div>
          <span class="label" style="display:block;margin-bottom:14px;">Meet the maker</span>
          <h2 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:40px;font-weight:500;margin:0 0 18px;letter-spacing:-0.008em;">{{ product.vendor }}</h2>
          <div class="rte" style="font-size:16.5px;line-height:1.78;">{{ product.metafields.custom.maker_story }}</div>
          {%- if product.vendor != blank -%}<p style="margin-top:22px;"><a href="{{ product.vendor | url_for_vendor }}" style="font-size:12.5px;letter-spacing:0.14em;text-transform:uppercase;border-bottom:0.5px solid var(--rule-strong);padding-bottom:2px;font-weight:500;">Browse all {{ product.vendor }} &rarr;</a></p>{%- endif -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  <section class="mtw-pdp__maker-band" id="reviews">
    <div class="mtw-pdp__reviews-inner" style="padding-top:48px;padding-bottom:48px;">
      <span class="label" style="display:block;margin-bottom:18px;">Reviews</span>
      <div class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}" data-product-title="{{ product.title | escape }}"></div>
    </div>
  </section>

  {%- assign rel = product.collections.first -%}
  {%- if rel and rel.products.size > 1 -%}
    <section class="mtw-pdp__related">
      <div class="mtw-pdp__related-head">
        <h2>More from <em>{% if product.vendor != blank %}{{ product.vendor }}{% else %}{{ rel.title }}{% endif %}</em></h2>
        <a href="{{ rel.url }}">See all</a>
      </div>
      <div class="mtw-pdp__related-grid">
        {%- assign shown = 0 -%}
        {%- for p in rel.products -%}
          {%- if p.id != product.id and shown < 4 -%}
            {%- assign shown = shown | plus: 1 -%}
            <a class="mtw-pdp__rc" href="{{ p.url }}">
              <div class="mtw-pdp__rc-img">{%- if p.featured_image -%}{{ p.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: p.title }}{%- endif -%}</div>
              {%- if p.vendor != blank -%}<p class="mtw-pdp__rc-maker">{{ p.vendor }}</p>{%- endif -%}
              <h3 class="mtw-pdp__rc-name">{{ p.title }}</h3>
              <div class="mtw-pdp__rc-meta"><span>{{ p.type }}</span><span class="mtw-pdp__rc-price">{{ p.price | money }}</span></div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}

  <section class="mtw-pdp__recent">
    <h2>Recently viewed</h2>
    <div class="mtw-pdp__recent-grid" data-mtw-recent></div>
  </section>

  <div class="mtw-pdp__sticky" data-mtw-sticky aria-hidden="true">
    <div class="mtw-pdp__sticky-inner">
      <div class="mtw-pdp__sticky-thumb">{%- if product.featured_image -%}<img src="{{ product.featured_image | image_url: width: 120 }}" alt="">{%- endif -%}</div>
      <div class="mtw-pdp__sticky-text">
        {%- if product.vendor != blank -%}<div class="mtw-pdp__sticky-maker">{{ product.vendor }}</div>{%- endif -%}
        <div class="mtw-pdp__sticky-name">{{ product.title }}</div>
      </div>
      <div class="mtw-pdp__sticky-price" data-mtw-sticky-price>{{ product.price | money }}</div>
      <button type="button" class="mtw-pdp__sticky-cta" data-mtw-sticky-cta>{% if state == 'pre_order' %}Pre-order{% else %}Add to cart{% endif %}</button>
    </div>
  </div>
</div>

<script>
(function(){
  var root=document.querySelector('[data-mtw-pdp]'); if(!root) return;
  var variants={{ product.variants | json }};
  var optCount={{ product.options.size }};
  var main=root.querySelector('[data-mtw-main]');
  root.querySelectorAll('[data-mtw-thumb]').forEach(function(t){
    t.addEventListener('click',function(){
      root.querySelectorAll('.mtw-pdp__thumb').forEach(function(x){x.classList.remove('active');});
      t.classList.add('active'); if(main) main.src=t.getAttribute('data-mtw-thumb');
    });
  });
  var vid=root.querySelector('[data-mtw-vid]');
  var addBtn=root.querySelector('[data-mtw-add]');
  var priceEl=root.querySelector('[data-mtw-price]');
  var sPrice=root.querySelector('[data-mtw-sticky-price]');
  function money(c){ try{return '$'+(c/100).toLocaleString(undefined,{minimumFractionDigits:2});}catch(e){return '$'+(c/100);} }
  function selectedOpts(){
    var o=[];
    for(var i=0;i<optCount;i++){
      var r=root.querySelector('input[data-mtw-opt="'+i+'"]:checked');
      o.push(r?r.value:null);
    }
    return o;
  }
  function resolve(){
    if(!variants||!variants.length) return;
    var o=selectedOpts();
    var v=variants.find(function(x){return x.options.every(function(val,i){return o[i]==null||val==o[i];});});
    if(!v) v=variants[0];
    if(vid) vid.value=v.id;
    if(priceEl) priceEl.innerHTML=(v.compare_at_price&&v.compare_at_price>v.price?'<s>'+money(v.compare_at_price)+'</s> ':'')+money(v.price);
    if(sPrice) sPrice.textContent=money(v.price);
    if(addBtn){
      if(v.available){addBtn.removeAttribute('disabled'); if(addBtn.textContent.trim()==='Sold out') addBtn.textContent='Add to cart';}
      else {addBtn.setAttribute('disabled','disabled'); addBtn.textContent='Sold out';}
    }
  }
  root.querySelectorAll('input[data-mtw-opt]').forEach(function(inp){
    inp.addEventListener('change',function(){
      var g=inp.closest('.mtw-pdp__vopts');
      g.querySelectorAll('.mtw-pdp__chip').forEach(function(c){c.classList.remove('sel');});
      inp.closest('.mtw-pdp__chip').classList.add('sel');
      resolve();
    });
  });
  resolve();
  var qty=root.querySelector('[data-mtw-qty]');
  var qm=root.querySelector('[data-mtw-qm]'), qp=root.querySelector('[data-mtw-qp]');
  if(qm) qm.addEventListener('click',function(){var n=parseInt(qty.value,10)||1; if(n>1) qty.value=n-1;});
  if(qp) qp.addEventListener('click',function(){var n=parseInt(qty.value,10)||1; qty.value=n+1;});
  var sticky=root.querySelector('[data-mtw-sticky]');
  var form=document.getElementById('mtw-pform');
  var cta=root.querySelector('[data-mtw-sticky-cta]');
  if(cta&&form) cta.addEventListener('click',function(){ if(addBtn&&addBtn.hasAttribute('disabled')) return; form.requestSubmit?form.requestSubmit(addBtn):form.submit(); });
  if(sticky&&addBtn&&'IntersectionObserver' in window){
    var io=new IntersectionObserver(function(e){ sticky.classList.toggle('show',!e[0].isIntersecting); },{rootMargin:'-80px 0px 0px 0px'});
    io.observe(addBtn);
  }
  try{
    var key='mtwRecent', cap=12;
    var rv=JSON.parse(localStorage.getItem(key)||'[]');
    rv=rv.filter(function(x){return x.h!={{ product.handle | json }};});
    rv.unshift({h:{{ product.handle | json }},u:{{ product.url | json }},t:{{ product.title | json }},p:{{ product.price | money | json }},i:{{ product.featured_image | image_url: width: 200 | json }}});
    localStorage.setItem(key,JSON.stringify(rv.slice(0,cap)));
    var box=root.querySelector('[data-mtw-recent]');
    rv.slice(1,7).forEach(function(x){
      var a=document.createElement('a'); a.href=x.u;
      a.innerHTML='<div class="mtw-pdp__rv-img">'+(x.i?'<img src="'+x.i+'" alt="">':'')+'</div><p class="mtw-pdp__rv-name">'+x.t+'</p><span class="mtw-pdp__rv-price">'+x.p+'</span>';
      box.appendChild(a);
    });
  }catch(e){}
})();
</script>

{% schema %}
{
  "name": "MTW Product",
  "settings": [
    { "type": "text", "id": "preorder_collection", "label": "Pre-order collection handle", "default": "pre-order" },
    { "type": "richtext", "id": "shipping_text", "label": "Shipping accordion (global)", "default": "<p>$9.95 standard U.S. shipping, free on orders $150 and up. Ships within 2 to 4 business days from our Los Angeles warehouse.</p>" },
    { "type": "richtext", "id": "returns_text", "label": "Returns accordion (global)", "default": "<p>30-day returns. If the toy isn't right, send it back. Free returns on damaged or defective items.</p>" }
  ]
}
{% endschema %}
