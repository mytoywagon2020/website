{%- comment -%}
  MTW Collection — editorial collection template. Native Shopify
  faceted filters / sort / pagination. Header & footer come from the
  theme. Namespaced .mtw-coll so it can't collide with Impulse.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
{{ 'mtw-collection.css' | asset_url | stylesheet_tag }}
{%- style -%}
  .mtw-coll__facet--more { display:none; }
  .mtw-coll__group.is-open .mtw-coll__facet--more { display:flex; }
  .mtw-coll__showmore { margin-top:10px; background:none; border:none; padding:2px 0; font-family:inherit; font-size:11.5px; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; color:var(--forest,#3B6D11); cursor:pointer; border-bottom:0.5px solid var(--forest,#3B6D11); }
  .mtw-coll__story { border-top:0.5px solid var(--rule,rgba(44,44,42,0.12)); background:var(--warm-white,#FFFCF7); }
  .mtw-coll__story-inner { max-width:1280px; margin:0 auto; padding:80px 40px; display:grid; grid-template-columns:0.85fr 1fr; gap:64px; align-items:center; }
  .mtw-coll__story-media { aspect-ratio:4/5; border-radius:2px; overflow:hidden; background:var(--card-bg,#EDE3CD); }
  .mtw-coll__story-media img { width:100%; height:100%; object-fit:cover; display:block; }
  .mtw-coll__story-body .label { display:block; margin-bottom:14px; }
  .mtw-coll__story-body h2 { font-family:'Cormorant Garamond',Georgia,serif; font-size:42px; font-weight:500; line-height:1.1; letter-spacing:-0.008em; margin:0 0 22px; color:var(--ink,#2C2C2A); }
  .mtw-coll__story-body h2 em { font-style:italic; }
  .mtw-coll__story-rte, .mtw-coll__story-rte p { font-size:16.5px; line-height:1.78; color:var(--ink,#2C2C2A); margin:0 0 18px; }
  .mtw-coll__story-rte p:last-child { margin-bottom:0; }
  @media (max-width:1000px) { .mtw-coll__story-inner { grid-template-columns:1fr; gap:36px; padding:56px 24px; } .mtw-coll__story-body h2 { font-size:32px; } }
{%- endstyle -%}

<div class="mtw-coll">
  <nav class="mtw-coll__crumbs">
    <a href="{{ routes.root_url }}">Home</a><span class="sep">·</span>
    <a href="{{ routes.collections_url }}">Collections</a><span class="sep">·</span>
    <span style="color:var(--ink);">{{ collection.title }}</span>
  </nav>

  <section class="mtw-coll__hero">
    <div>
      {%- if section.settings.eyebrow != blank -%}<span class="label">{{ section.settings.eyebrow }}</span>{%- endif -%}
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="mtw-coll__dek">{{ collection.description | strip_html | truncatewords: 40 }}</div>
      {%- endif -%}
      <div class="mtw-coll__cta-row">
        <a href="#mtw-coll-grid" class="mtw-coll__btn mtw-coll__btn--primary">Browse the collection</a>
        {%- if section.settings.cta_link != blank -%}<a href="{{ section.settings.cta_link }}" class="mtw-coll__btn mtw-coll__btn--ghost">{{ section.settings.cta_text | default: 'Read more' }}</a>{%- endif -%}
      </div>
    </div>
    <div class="mtw-coll__hero-img">
      {%- if collection.image -%}
        {{ collection.image | image_url: width: 1100 | image_tag: loading: 'eager', alt: collection.title }}
      {%- elsif collection.products.first.featured_image -%}
        {{ collection.products.first.featured_image | image_url: width: 1100 | image_tag: loading: 'eager', alt: collection.products.first.title }}
      {%- elsif section.settings.hero_image != blank -%}
        {{ section.settings.hero_image | image_url: width: 1100 | image_tag: loading: 'eager', alt: collection.title }}
      {%- endif -%}
    </div>
  </section>

  {%- paginate collection.products by 24 -%}
  <div class="mtw-coll__filterbar">
    <div class="mtw-coll__filterinner">
      <div class="mtw-coll__pills">
        <span class="mtw-coll__meta">{{ collection.products_count | default: paginate.items }} products</span>
        {%- for filter in collection.filters -%}
          {%- for value in filter.active_values -%}
            <a class="mtw-coll__pill" href="{{ value.url_to_remove }}">{{ value.label }}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </a>
          {%- endfor -%}
          {%- if filter.type == 'price_range' -%}
            {%- if filter.min_value.value != null or filter.max_value.value != null -%}
              <a class="mtw-coll__pill" href="{{ filter.url_to_remove }}">Price
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
              </a>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
      <form method="get" class="mtw-coll__sort">
        <label for="mtw-sort">Sort:</label>
        <select id="mtw-sort" name="sort_by" onchange="this.form.submit()">
          {%- for opt in collection.sort_options -%}
            <option value="{{ opt.value }}" {% if opt.value == collection.sort_by %}selected{% endif %}>{{ opt.name }}</option>
          {%- endfor -%}
        </select>
        {%- for f in collection.filters -%}
          {%- for v in f.active_values -%}<input type="hidden" name="{{ v.param_name }}" value="{{ v.value }}">{%- endfor -%}
        {%- endfor -%}
      </form>
    </div>
  </div>

  <div class="mtw-coll__body">
    <aside class="mtw-coll__side">
      <div class="mtw-coll__side-top">
        <span class="label">Filter</span>
        <a class="mtw-coll__clear" href="{{ collection.url }}{% if collection.sort_by != blank %}?sort_by={{ collection.sort_by }}{% endif %}">Clear all</a>
      </div>
      <form method="get">
        {%- if collection.sort_by != blank -%}<input type="hidden" name="sort_by" value="{{ collection.sort_by }}">{%- endif -%}
        {%- for filter in collection.filters -%}
          <div class="mtw-coll__group">
            <h3>{{ filter.label }}</h3>
            {%- if filter.type == 'price_range' -%}
              <div class="mtw-coll__price">
                <input type="text" inputmode="decimal" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value }}" placeholder="$ min">
                <input type="text" inputmode="decimal" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value }}" placeholder="$ max">
              </div>
            {%- else -%}
              {%- assign is_age = false -%}
              {%- if filter.label contains 'Age' -%}{%- assign is_age = true -%}{%- endif -%}
              {%- assign vis = 0 -%}
              {%- if is_age -%}
                {%- assign age_order = '0–12 mo,18 mo,1,2,3,4,5,6,7,8' | split: ',' -%}
                {%- assign age_seen = ',0–12 mo,18 mo,1,2,3,4,5,6,7,8,' -%}
                {%- for tok in age_order -%}
                  {%- for value in filter.values -%}
                    {%- if value.value == tok -%}
                      {%- assign vis = vis | plus: 1 -%}
                      {%- if value.value == '0–12 mo' -%}{%- assign disp = 'Under 1 yr' -%}
                      {%- elsif value.value == '18 mo' -%}{%- assign disp = '18 months' -%}
                      {%- else -%}{%- assign disp = value.value | append: ' yr' -%}{%- endif -%}
                      <label class="mtw-coll__facet{% if vis > 10 and value.active == false %} mtw-coll__facet--more{% endif %}">
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} onchange="this.form.submit()">
                        {{ disp }} <span class="count">{{ value.count }}</span>
                      </label>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
                {%- for value in filter.values -%}
                  {%- assign needle = ',' | append: value.value | append: ',' -%}
                  {%- unless age_seen contains needle -%}
                    {%- assign vis = vis | plus: 1 -%}
                    <label class="mtw-coll__facet{% if vis > 10 and value.active == false %} mtw-coll__facet--more{% endif %}">
                      <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} onchange="this.form.submit()">
                      {{ value.label }} <span class="count">{{ value.count }}</span>
                    </label>
                  {%- endunless -%}
                {%- endfor -%}
              {%- else -%}
                {%- for value in filter.values -%}
                  {%- assign vis = vis | plus: 1 -%}
                  <label class="mtw-coll__facet{% if vis > 10 and value.active == false %} mtw-coll__facet--more{% endif %}">
                    <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} onchange="this.form.submit()">
                    {{ value.label }} <span class="count">{{ value.count }}</span>
                  </label>
                {%- endfor -%}
              {%- endif -%}
              {%- if vis > 10 -%}
                <button type="button" class="mtw-coll__showmore" data-mtw-showmore data-all="Show all ({{ vis }})">Show all ({{ vis }})</button>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endfor -%}
        <button type="submit" class="mtw-coll__apply">Apply filters</button>
      </form>
    </aside>

    <main id="mtw-coll-grid">
      {%- if collection.products.size > 0 -%}
        <div class="mtw-coll__grid">
          {%- for product in collection.products -%}
            {%- assign cur = product.selected_or_first_available_variant -%}
            {%- assign is_pre = false -%}
            {%- for pc in product.collections -%}{%- if pc.handle == section.settings.preorder_collection -%}{%- assign is_pre = true -%}{%- endif -%}{%- endfor -%}
            {%- assign has2 = false -%}{%- if product.images.size > 1 -%}{%- assign has2 = true -%}{%- endif -%}
            <div class="mtw-coll__prod">
              <a class="mtw-coll__prod-img" href="{{ product.url }}">
                {%- if is_pre -%}<span class="mtw-coll__tag amber">Pre-order</span>
                {%- elsif product.available == false -%}<span class="mtw-coll__tag amber">Sold out</span>{%- endif -%}
                {%- if product.featured_image -%}
                  <img class="primary {% if has2 %}has2{% else %}no2{% endif %}" src="{{ product.featured_image | image_url: width: 700 }}" srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 700 }} 700w" sizes="(min-width:1000px) 30vw, 45vw" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" width="700" height="875">
                {%- endif -%}
                {%- if has2 -%}<img class="secondary" src="{{ product.images[1] | image_url: width: 700 }}" alt="" loading="lazy" width="700" height="875">{%- endif -%}
              </a>
              {%- if product.available and is_pre == false -%}
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ cur.id }}">
                  <button type="submit" class="mtw-coll__add">Add to cart</button>
                </form>
              {%- elsif is_pre -%}
                <form method="post" action="{{ routes.cart_add_url }}">
                  <input type="hidden" name="id" value="{{ cur.id }}">
                  <button type="submit" class="mtw-coll__add">Pre-order</button>
                </form>
              {%- endif -%}
              {%- if product.vendor != blank -%}<p class="mtw-coll__maker">{{ product.vendor }}</p>{%- endif -%}
              <h3 class="mtw-coll__name"><a href="{{ product.url }}">{{ product.title }}</a></h3>
              <div class="mtw-coll__stars"><div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}" data-template="index"></div></div>
              <div class="mtw-coll__pmeta">
                <span>{% if product.type != blank %}{{ product.type }}{% endif %}</span>
                <span class="mtw-coll__pprice">
                  {%- if product.compare_at_price > product.price -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}
                  {{ product.price | money }}
                </span>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="mtw-coll__pag">
          <p class="mtw-coll__pag-count">Showing {{ collection.products.size }} of {{ paginate.items }} products</p>
          {%- if paginate.pages > 1 -%}
            <div class="mtw-coll__pag-bar">
              {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&larr; Prev</a>{%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
                {%- elsif part.title == paginate.current_page -%}<span class="current">{{ part.title }}</span>
                {%- else -%}<span>{{ part.title }}</span>{%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Next &rarr;</a>{%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- else -%}
        <p class="mtw-coll__empty">No products match these filters. <a href="{{ collection.url }}" style="border-bottom:0.5px solid var(--rule-strong);">Clear all</a></p>
      {%- endif -%}
    </main>
  </div>
  {%- endpaginate -%}

  {%- assign mstory = collection.metafields.custom.maker_story -%}
  {%- if mstory != blank -%}
    {%- assign mhead = collection.metafields.custom.maker_heading -%}
    {%- assign mimg = collection.metafields.custom.maker_image -%}
    <section class="mtw-coll__story" aria-label="The story behind {{ collection.title | escape }}">
      <div class="mtw-coll__story-inner">
        <div class="mtw-coll__story-media">
          {%- if mimg != blank -%}{{ mimg | image_url: width: 1000 | image_tag: loading: 'lazy', alt: collection.title | append: ' — the maker story' }}
          {%- elsif collection.image -%}{{ collection.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: collection.title }}
          {%- elsif collection.products.first.featured_image -%}{{ collection.products.first.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: collection.products.first.title }}
          {%- endif -%}
        </div>
        <div class="mtw-coll__story-body">
          <span class="label">{{ section.settings.story_eyebrow | default: 'The maker' }}</span>
          <h2>{% if mhead != blank %}{{ mhead }}{% else %}The story behind <em>{{ collection.title }}</em>{% endif %}</h2>
          <div class="mtw-coll__story-rte rte">{{ mstory | metafield_tag }}</div>
        </div>
      </div>
    </section>
  {%- endif -%}
</div>

<script>
(function(){
  document.querySelectorAll('[data-mtw-showmore]').forEach(function(b){
    b.addEventListener('click',function(){
      var g=b.closest('.mtw-coll__group'); if(!g) return;
      var open=g.classList.toggle('is-open');
      b.textContent=open?'Show less':b.getAttribute('data-all');
    });
  });
})();
</script>

{% schema %}
{
  "name": "MTW Collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Hero eyebrow", "default": "The collection" },
    { "type": "image_picker", "id": "hero_image", "label": "Fallback hero image (used only if no collection image/products)" },
    { "type": "text", "id": "cta_text", "label": "Secondary CTA text" },
    { "type": "url", "id": "cta_link", "label": "Secondary CTA link" },
    { "type": "text", "id": "preorder_collection", "label": "Pre-order collection handle", "default": "pre-order" },
    { "type": "text", "id": "story_eyebrow", "label": "Maker-story eyebrow", "default": "The maker" }
  ]
}
{% endschema %}
