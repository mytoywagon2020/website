{%- comment -%}
  MTW Footer — editorial footer (.mtw-foot), namespaced so it cannot collide
  with Impulse's .site-footer. Reconciled to the MTW_Footer_6 spec:
  tagline band, brand + 3 link columns (accordions on mobile), promoted
  newsletter, dedicated mobile "Talk to us", payments band, bottom bar.
  Responsive breakpoint: 720px.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
{%- if section.settings.show_badge -%}<script src="https://apis.google.com/js/platform.js?onload=renderBadge" async defer></script>{%- endif -%}

{%- liquid
  assign mark_url = 'mytoywagon-logo-mark.png' | file_url
  assign phone_href = section.settings.phone | remove: '.' | remove: ' ' | remove: '(' | remove: ')' | remove: '-'
-%}

{%- style -%}
  #shopify-section-{{ section.id }} { background:#F5F0E5; }
  .mtw-foot {
    --cream:#F5F0E5; --warm-white:#FFFCF7; --ink:#2C2C2A; --forest:#3B6D11;
    --amber:#854F0B; --stone:#5F5E5A; --rule:rgba(44,44,42,0.12); --rule-strong:rgba(44,44,42,0.22);
    border-top:0.5px solid var(--rule); background:var(--cream);
    font-family:'Mulish',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; color:var(--ink);
  }
  .mtw-foot *, .mtw-foot *::before, .mtw-foot *::after { box-sizing:border-box; }
  .mtw-foot a { text-decoration:none; color:inherit; }
  .mtw-foot__inner { max-width:1440px; margin:0 auto; padding:72px 40px 28px; }

  .mtw-foot__band { text-align:center; padding:0 0 56px; border-bottom:0.5px solid var(--rule); margin-bottom:56px; }
  .mtw-foot__band h2 { font-family:'Cormorant Garamond',Georgia,serif; font-size:30px; font-weight:500; letter-spacing:-0.008em; line-height:1.15; color:var(--ink); margin:0 0 8px; }
  .mtw-foot__band h2 em { font-style:italic; color:var(--forest); }
  .mtw-foot__band p { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:16px; color:var(--stone); max-width:560px; margin:0 auto; line-height:1.5; }

  .mtw-foot__top { display:grid; grid-template-columns:2fr 1fr 1fr 1fr; gap:56px; padding-bottom:48px; border-bottom:0.5px solid var(--rule); }
  .mtw-foot__brand { display:flex; flex-direction:column; }
  .mtw-foot__logo { display:block; width:218px; height:218px; margin-bottom:24px; background-color:var(--ink); -webkit-mask:url('{{ mark_url }}') left center/contain no-repeat; mask:url('{{ mark_url }}') left center/contain no-repeat; }
  .mtw-foot__tag { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:16px; color:var(--stone); margin:0 0 18px; max-width:320px; line-height:1.5; }
  .mtw-foot__loc { font-size:13.5px; color:var(--ink); line-height:1.6; margin:0 0 18px; }
  .mtw-foot__loc strong { font-weight:500; }
  .mtw-foot__social { display:flex; gap:12px; }
  .mtw-foot__social a { display:inline-flex; align-items:center; justify-content:center; width:34px; height:34px; border-radius:50%; border:0.5px solid var(--rule-strong); color:var(--stone); transition:background 180ms ease,color 180ms ease,border-color 180ms ease; }
  .mtw-foot__social a:hover { background:var(--ink); color:var(--cream); border-color:var(--ink); }
  .mtw-foot__social svg { width:15px; height:15px; stroke:currentColor; stroke-width:1.4; stroke-linecap:round; stroke-linejoin:round; fill:none; }

  .mtw-foot__news { margin:4px 0 22px; padding-top:22px; border-top:0.5px solid var(--rule); max-width:340px; }
  .mtw-foot__news h4 { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:18px; font-weight:500; color:var(--ink); margin:0 0 6px; }
  .mtw-foot__news p { font-size:13px; line-height:1.55; color:var(--stone); margin:0 0 12px; }
  .mtw-foot__news form { display:grid; grid-template-columns:1fr auto; gap:8px; }
  .mtw-foot__news input { height:40px; padding:0 12px; background:var(--warm-white); border:0.5px solid var(--rule-strong); border-radius:2px; font-family:inherit; font-size:13.5px; color:var(--ink); outline:none; }
  .mtw-foot__news input::placeholder { color:var(--stone); }
  .mtw-foot__news input:focus { border-color:var(--ink); }
  .mtw-foot__news button { height:40px; padding:0 18px; background:var(--ink); color:var(--cream); border:none; border-radius:2px; font-size:10.5px; font-weight:600; letter-spacing:0.14em; text-transform:uppercase; cursor:pointer; }
  .mtw-foot__news button:hover { background:var(--forest); }
  .mtw-foot__news-perk { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:12.5px; color:var(--stone); margin:8px 0 0; }
  .mtw-foot__news-ok { font-size:13px; color:var(--forest); margin:0; font-weight:600; }

  .mtw-foot__contact { font-size:13.5px; line-height:1.7; color:var(--ink); margin:18px 0 22px; }
  .mtw-foot__contact a { color:var(--ink); font-weight:500; display:block; }
  .mtw-foot__contact a:hover { color:var(--forest); }
  .mtw-foot__contact .small { font-size:12.5px; color:var(--stone); margin-top:6px; display:block; }

  .mtw-foot__col h4,
  .mtw-foot__col summary { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:18px; font-weight:500; color:var(--ink); margin:0 0 18px; letter-spacing:-0.003em; }
  .mtw-foot__col summary { list-style:none; cursor:default; display:flex; justify-content:space-between; align-items:center; }
  .mtw-foot__col summary::-webkit-details-marker { display:none; }
  .mtw-foot__col summary::after { content:""; width:8px; height:8px; border-right:1.5px solid var(--stone); border-bottom:1.5px solid var(--stone); transform:rotate(45deg); transition:transform 240ms ease; margin-right:4px; display:none; }
  .mtw-foot__col ul { list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:12px; }
  .mtw-foot__col li { font-size:13.5px; color:var(--ink); }
  .mtw-foot__col a:hover { color:var(--forest); }

  .mtw-foot__talk { display:none; }

  .mtw-foot__badge { display:flex; justify-content:center; align-items:center; gap:14px; padding:24px 0; border-bottom:0.5px solid var(--rule); }

  .mtw-foot__mid { display:flex; justify-content:space-between; align-items:center; padding:24px 0; border-bottom:0.5px solid var(--rule); gap:24px; flex-wrap:wrap; }
  .mtw-foot__pay-label { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:13.5px; color:var(--stone); }
  .mtw-foot__pay { display:flex; align-items:center; flex-wrap:wrap; }
  .mtw-foot__chip { display:inline-block; padding:0 14px 0 0; margin-right:14px; border-right:0.5px solid var(--rule); font-size:12px; color:var(--ink); letter-spacing:0.06em; font-weight:500; line-height:1.2; }
  .mtw-foot__chip:last-child { border-right:none; margin-right:0; padding-right:0; }

  .mtw-foot__bottom { display:flex; justify-content:space-between; align-items:center; padding-top:22px; gap:16px; flex-wrap:wrap; }
  .mtw-foot__bottom-copy { font-size:12px; color:var(--stone); }
  .mtw-foot__bottom-copy em { font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:13.5px; color:var(--ink); margin-right:10px; }
  .mtw-foot__bottom-links { display:flex; gap:22px; align-items:center; }
  .mtw-foot__bottom-links a { font-size:12px; color:var(--stone); }
  .mtw-foot__bottom-links a:hover { color:var(--ink); }

  @media (min-width:721px) {
    .mtw-foot__col > ul { display:flex !important; }
  }

  @media (max-width:720px) {
    .mtw-foot__inner { padding:32px 24px 24px; }
    .mtw-foot__band { padding-bottom:24px; margin-bottom:20px; }
    .mtw-foot__band h2 { font-size:24px; }
    .mtw-foot__band p { font-size:14px; }

    .mtw-foot__top { display:flex; flex-direction:column; gap:0; padding-bottom:0; border-bottom:none; }

    .mtw-foot__brand { order:2; align-items:center; text-align:center; padding-bottom:20px; margin-bottom:20px; border-bottom:0.5px solid var(--rule); }
    .mtw-foot__logo { width:180px; height:180px; margin:0 auto 4px; -webkit-mask-position:center; mask-position:center; }
    .mtw-foot__tag { order:3; margin:0 auto 10px; max-width:280px; }
    .mtw-foot__loc { order:4; margin:0 auto; }
    .mtw-foot__social { order:6; justify-content:center; margin-top:14px; }
    .mtw-foot__contact { display:none; }

    .mtw-foot__news { order:1; width:100%; max-width:none; margin:0 0 32px; padding:0 0 32px; border-top:none; border-bottom:0.5px solid var(--rule); text-align:center; }
    .mtw-foot__news-perk { order:-1; margin:0 0 10px; }
    .mtw-foot__news form { grid-template-columns:1fr; }
    .mtw-foot__news input { height:46px; text-align:center; }
    .mtw-foot__news button { height:46px; font-size:12px; }

    .mtw-foot__col { order:3; border-bottom:0.5px solid var(--rule); }
    .mtw-foot__col summary { cursor:pointer; padding:18px 4px; margin:0; }
    .mtw-foot__col summary::after { display:block; }
    .mtw-foot__col[open] summary::after { transform:rotate(-135deg); }
    .mtw-foot__col ul { padding:0 4px 18px; gap:14px; }
    .mtw-foot__col li { font-size:15px; }
    .mtw-foot__col:not([open]) > ul { display:none; }

    .mtw-foot__talk { display:block; order:4; text-align:center; padding:40px 8px 32px; border-bottom:0.5px solid var(--rule); }
    .mtw-foot__talk h4 { font-size:10.5px; letter-spacing:0.22em; text-transform:uppercase; color:var(--stone); font-weight:600; margin:0 0 16px; }
    .mtw-foot__talk a { display:block; font-family:'Cormorant Garamond',Georgia,serif; font-style:italic; font-size:19px; font-weight:500; color:var(--ink); padding:4px 0; line-height:1.3; }
    .mtw-foot__talk a:hover { color:var(--forest); }
    .mtw-foot__talk .small { font-size:11.5px; color:var(--stone); margin-top:14px; letter-spacing:0.16em; text-transform:uppercase; font-weight:500; display:block; }

    .mtw-foot__badge { flex-direction:column; gap:8px; padding:24px 8px 26px; }

    .mtw-foot__mid { justify-content:center; padding:28px 8px 24px; text-align:center; }
    .mtw-foot__pay-label { display:block; width:100%; font-family:'Mulish',sans-serif; font-style:normal; font-size:10px; letter-spacing:0.22em; text-transform:uppercase; font-weight:600; margin-bottom:12px; }
    .mtw-foot__pay { justify-content:center; gap:14px; }
    .mtw-foot__chip { padding:0; margin:0; border-right:none; font-size:11px; letter-spacing:0.08em; color:var(--stone); }
    .mtw-foot__chip--lo { display:none; }

    .mtw-foot__bottom { flex-direction:column; text-align:center; gap:14px; padding:28px 8px 20px; }
    .mtw-foot__bottom-links { justify-content:center; flex-wrap:wrap; }
  }
{%- endstyle -%}

<div class="mtw-foot" data-section-id="{{ section.id }}" data-section-type="footer-section">
  <div class="mtw-foot__inner">

    {%- if section.settings.band_heading != blank -%}
    <div class="mtw-foot__band">
      <h2>{{ section.settings.band_heading }}</h2>
      {%- if section.settings.band_subtitle != blank -%}<p>{{ section.settings.band_subtitle }}</p>{%- endif -%}
    </div>
    {%- endif -%}

    <div class="mtw-foot__top">

      <div class="mtw-foot__brand">
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}"><span class="mtw-foot__logo" aria-hidden="true"></span></a>

        <div class="mtw-foot__news" data-mtw-news data-kl-company="{{ section.settings.klaviyo_company_id }}" data-kl-list="{{ section.settings.klaviyo_list_id }}">
          <h4>{{ section.settings.news_heading | default: 'Stay close.' }}</h4>
          {%- if section.settings.news_perk != blank -%}<p class="mtw-foot__news-perk">{{ section.settings.news_perk }}</p>{%- endif -%}
          {%- if section.settings.news_body != blank -%}<p>{{ section.settings.news_body }}</p>{%- endif -%}
          <form class="mtw-foot__news-form" novalidate>
            <input type="email" name="email" placeholder="you@email.com" required aria-label="Email address">
            <button type="submit">{{ section.settings.news_button | default: 'Sign up' }}</button>
          </form>
          <p class="mtw-foot__news-ok" hidden>Thanks. Look for a note in your inbox to confirm.</p>
        </div>

        {%- if section.settings.tagline != blank -%}<p class="mtw-foot__tag">{{ section.settings.tagline }}</p>{%- endif -%}
        <p class="mtw-foot__loc">
          {%- if section.settings.location != blank -%}<strong>{{ section.settings.location }}</strong><br>{%- endif -%}
          {{ section.settings.hours }}
        </p>

        <div class="mtw-foot__contact">
          {%- if section.settings.email != blank -%}<a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>{%- endif -%}
          {%- if section.settings.phone != blank -%}<a href="tel:{{ phone_href }}">{{ section.settings.phone }}</a>{%- endif -%}
          {%- if section.settings.hours != blank -%}<span class="small">{{ section.settings.hours }}</span>{%- endif -%}
        </div>

        <div class="mtw-foot__social">
          {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg></a>
          {%- endif -%}
          {%- if section.settings.pinterest != blank -%}
          <a href="{{ section.settings.pinterest }}" aria-label="Pinterest"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M11 8c-2 .5-3.5 2.5-3 4.5.3 1.3 1.5 1.6 1.5.5 0-1 .5-2 1.5-2.5 1.5-.8 3.5 0 4 1.5.5 2-.5 4-2.5 4-1 0-1.5-.5-1.3-1.5L12 11"/><path d="M11 13.5 9.5 19"/></svg></a>
          {%- endif -%}
          {%- if section.settings.youtube != blank -%}
          <a href="{{ section.settings.youtube }}" aria-label="YouTube"><svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="3"/><path d="M10 9.5v5l4.5-2.5z" fill="currentColor"/></svg></a>
          {%- endif -%}
          {%- if section.settings.tiktok != blank -%}
          <a href="{{ section.settings.tiktok }}" aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M14 4v10.5a3.5 3.5 0 1 1-3.5-3.5"/><path d="M14 4c0 2 1.5 4 4 4"/></svg></a>
          {%- endif -%}
        </div>
      </div>

      <details class="mtw-foot__col" open>
        <summary>Shop</summary>
        <ul>
          <li><a href="/pages/shop-by-age">Shop by Age</a></li>
          <li><a href="/collections/all">Shop by Category</a></li>
          <li><a href="/collections/featured-brands">Featured Brands</a></li>
          <li><a href="/collections/new-arrivals">New</a></li>
          <li><a href="/collections/pre-order">Pre-Order</a></li>
          <li><a href="/collections/sale">Sale</a></li>
          <li><a href="/products/my-toy-wagon-e-gift-card">Gift cards</a></li>
        </ul>
      </details>

      <details class="mtw-foot__col" open>
        <summary>Customer care</summary>
        <ul>
          <li><a href="/pages/shipping">Shipping</a></li>
          <li><a href="/pages/returns">Returns</a></li>
          <li><a href="/pages/rewards">Rewards</a></li>
          <li><a href="/pages/wishlist">Wishlist</a></li>
          <li><a href="/pages/faq">FAQs</a></li>
        </ul>
      </details>

      <details class="mtw-foot__col" open>
        <summary>About</summary>
        <ul>
          <li><a href="/pages/our-story">Our story</a></li>
          <li><a href="/blogs/news">The blog</a></li>
          <li><a href="/pages/reviews">Customer reviews</a></li>
          <li><a href="/pages/educator-register">Educator program</a></li>
          <li><a href="/pages/collaboration">Collaboration</a></li>
          <li><a href="/pages/accessibility">Accessibility</a></li>
        </ul>
      </details>

      <div class="mtw-foot__talk">
        <h4>Talk to us</h4>
        {%- if section.settings.email != blank -%}<a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>{%- endif -%}
        {%- if section.settings.phone != blank -%}<a href="tel:{{ phone_href }}">{{ section.settings.phone }}</a>{%- endif -%}
        {%- if section.settings.hours != blank -%}<span class="small">{{ section.settings.hours }}</span>{%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_badge -%}
    <div class="mtw-foot__badge">
      <g:ratingbadge merchant_id="{{ section.settings.badge_merchant_id }}" position="INLINE"></g:ratingbadge>
    </div>
    {%- endif -%}

    <div class="mtw-foot__mid">
      <span class="mtw-foot__pay-label">We accept</span>
      <div class="mtw-foot__pay">
        <span class="mtw-foot__chip">Visa</span>
        <span class="mtw-foot__chip">Mastercard</span>
        <span class="mtw-foot__chip">Amex</span>
        <span class="mtw-foot__chip mtw-foot__chip--lo">Discover</span>
        <span class="mtw-foot__chip mtw-foot__chip--lo">Diners</span>
        <span class="mtw-foot__chip">Apple&nbsp;Pay</span>
        <span class="mtw-foot__chip mtw-foot__chip--lo">Google&nbsp;Pay</span>
        <span class="mtw-foot__chip">PayPal</span>
        <span class="mtw-foot__chip">Shop&nbsp;Pay</span>
      </div>
    </div>

    <div class="mtw-foot__bottom">
      <span class="mtw-foot__bottom-copy">
        {%- if section.settings.bottom_tagline != blank -%}<em>{{ section.settings.bottom_tagline }}</em>{%- endif -%}
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_suffix }}
      </span>
      <div class="mtw-foot__bottom-links">
        <a href="/policies/privacy-policy">Privacy policy</a>
        <a href="/policies/terms-of-service">Terms of service</a>
        <a href="/pages/accessibility">Accessibility</a>
      </div>
    </div>

  </div>
</div>

<script>
(function(){
  var w=document.querySelector('[data-mtw-news][data-section-id-fallback], .mtw-foot [data-mtw-news]');
  if(!w) return;
  var f=w.querySelector('form'), ok=w.querySelector('.mtw-foot__news-ok');
  if(!f) return;
  f.addEventListener('submit',function(e){
    e.preventDefault();
    var email=(f.querySelector('input[name=email]')||{}).value||'';
    if(!email||email.indexOf('@')<0){ return; }
    var co=w.getAttribute('data-kl-company'), list=w.getAttribute('data-kl-list');
    var done=function(){ f.style.display='none'; if(ok){ ok.hidden=false; } };
    if(co && list){
      fetch('https://a.klaviyo.com/client/subscriptions/?company_id='+encodeURIComponent(co),{
        method:'POST',
        headers:{'Content-Type':'application/json','revision':'2024-10-15'},
        body:JSON.stringify({data:{type:'subscription',attributes:{profile:{data:{type:'profile',attributes:{email:email}}}},relationships:{list:{data:{type:'list',id:list}}}}})
      }).then(done).catch(done);
    } else { done(); }
  });
})();
</script>

{% schema %}
{
  "name": "MTW Footer",
  "settings": [
    { "type": "header", "content": "Sustainability band" },
    { "type": "text", "id": "band_heading", "label": "Band heading (HTML em allowed)", "default": "Heirloom is <em>sustainability.</em>" },
    { "type": "text", "id": "band_subtitle", "label": "Band subtitle", "default": "Toys played with for a decade are toys not bought, broken, and replaced." },
    { "type": "header", "content": "Brand block" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Heirloom toys, curated by hand. A family-owned boutique, online since 2020." },
    { "type": "text", "id": "location", "label": "Location line", "default": "Los Angeles, California" },
    { "type": "text", "id": "hours", "label": "Hours", "default": "Mon to Fri, 9 am to 5 pm PT" },
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "news_heading", "label": "Heading", "default": "Stay close." },
    { "type": "text", "id": "news_body", "label": "Body", "default": "New arrivals, restocks, and a few thoughts on heirloom play. No spam, ever." },
    { "type": "text", "id": "news_button", "label": "Button label", "default": "Sign up" },
    { "type": "text", "id": "news_perk", "label": "Perk line", "default": "Welcome offer · $10 off your first order of $75 or more." },
    { "type": "text", "id": "klaviyo_company_id", "label": "Klaviyo public company ID", "info": "Optional. If set with a list ID, the form subscribes via Klaviyo." },
    { "type": "text", "id": "klaviyo_list_id", "label": "Klaviyo list ID" },
    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "email", "label": "Email", "default": "contact@mytoywagon.com" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "(626) 841-0421" },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "pinterest", "label": "Pinterest URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "header", "content": "Google Top Quality Store badge" },
    { "type": "checkbox", "id": "show_badge", "label": "Show Google rating badge", "default": false },
    { "type": "text", "id": "badge_merchant_id", "label": "Google merchant ID", "default": "370063513" },
    { "type": "text", "id": "badge_title", "label": "Badge title (legacy)", "default": "Top Quality Store" },
    { "type": "text", "id": "badge_sub", "label": "Badge subtitle (legacy)", "default": "Awarded by Google" },
