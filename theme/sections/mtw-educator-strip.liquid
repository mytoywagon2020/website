{%- comment -%}
  MTW Educator Strip — slim, low-prominence editorial callout that sits
  just below the hero. New namespaced section (.mtw-edu) so it cannot
  collide with Impulse styles; all copy editable in the theme editor.
{%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">

{%- style -%}
  #shopify-section-{{ section.id }} { background: #F5F0E5; }
  .mtw-edu {
    --cream:#F5F0E5; --ink:#2C2C2A; --forest:#3B6D11; --stone:#5F5E5A;
    --rule:rgba(44,44,42,0.12); --rule-strong:rgba(44,44,42,0.22);
    max-width:1100px; margin:0 auto; padding:36px 40px;
    border-top:0.5px solid var(--rule); border-bottom:0.5px solid var(--rule);
    box-sizing:border-box;
    font-family:'Mulish',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  }
  .mtw-edu *, .mtw-edu *::before, .mtw-edu *::after { box-sizing:border-box; }
  .mtw-edu__inner {
    display:flex; align-items:center; justify-content:space-between;
    gap:32px; flex-wrap:wrap;
  }
  .mtw-edu__text {
    font-family:'Cormorant Garamond',Georgia,serif; font-style:italic;
    font-size:18px; color:var(--ink); max-width:540px; line-height:1.4; margin:0;
  }
  .mtw-edu__eyebrow {
    font-weight:500; font-style:normal; color:var(--stone);
    letter-spacing:0.18em; text-transform:uppercase; font-size:11px;
    display:block; margin-bottom:6px;
  }
  .mtw-edu__cta {
    display:inline-flex; align-items:center; gap:10px; font-size:12.5px;
    letter-spacing:0.14em; text-transform:uppercase; color:var(--ink);
    border-bottom:0.5px solid var(--rule-strong); padding-bottom:4px;
    font-weight:500; flex-shrink:0; text-decoration:none;
  }
  .mtw-edu__cta:hover { border-color:var(--ink); color:var(--forest); }
  @media (max-width:700px) {
    .mtw-edu { padding:28px 24px; }
    .mtw-edu__inner { gap:18px; }
  }
{%- endstyle -%}

<div class="mtw-edu">
  <div class="mtw-edu__inner">
    <p class="mtw-edu__text">
      {%- if section.settings.eyebrow != blank -%}<span class="mtw-edu__eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {{ section.settings.text }}
    </p>
    {%- if section.settings.cta_text != blank -%}
      <a class="mtw-edu__cta" href="{{ section.settings.cta_link | default: '#' }}">{{ section.settings.cta_text }} &rarr;</a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "MTW Educator Strip",
  "tag": "section",
  "class": "mtw-edu-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "For educators" },
    { "type": "text", "id": "text", "label": "Message", "default": "Volume pricing, Net-30 invoicing, and one-on-one curation for schools, therapists, and homeschool families." },
    { "type": "text", "id": "cta_text", "label": "Link text", "default": "Apply for an account" },
    { "type": "url", "id": "cta_link", "label": "Link" }
  ],
  "presets": [{ "name": "MTW Educator Strip" }]
}
{% endschema %}
