  border-bottom: 0.5px solid var(--rule);
}
.how-it-works-inner{
  max-width: 1340px;
  margin: 0 auto;
  padding: 56px clamp(20px, 5vw, 56px);
}
.how-head{
  display: grid;
  grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  gap: 56px;
  align-items: end;
  margin-bottom: 36px;
  padding-bottom: 28px;
  border-bottom: 0.5px solid var(--rule);
}
.how-head .eyebrow{ color: var(--accent-deep); margin-bottom: 18px; display: inline-block; }
.how-head h3{
  margin: 0;
