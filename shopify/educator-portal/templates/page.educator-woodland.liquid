  display: inline-block;
}

.gallery .quote-strip{
  margin-top: 110px;
  padding: 56px 0;
  border-top: 1px solid var(--rule-soft);
  border-bottom: 1px solid var(--rule-soft);
  text-align: center;
}
.gallery .quote-strip p{
  margin: 0 auto;
  max-width: 32ch;
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(24px, 2.6vw, 36px);
  line-height: 1.35;
  color: var(--ink);
}

/* ============================== COMPANIONS ============================== */
.companions{
  position: relative;
  overflow: hidden;
  color: var(--cream);
  background: var(--hue-3-deep);
}
.companions::after{
  content:""; position:absolute; left:0; right:0; bottom:0; height: 3px; z-index: 2;
  background: linear-gradient(to right, var(--accent) 0%, var(--alt) 50%, var(--hue-3) 100%);
  opacity: .55;
}
.companions .wrap{
  display: grid;
  grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
  gap: 80px;
  align-items: center;
}
.companions .col-img .tile{ height: 460px; }
.companions .col-txt .eyebrow{ color: color-mix(in oklab, var(--accent-soft) 80%, white); }
.companions h2{
  margin: 22px 0 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(44px, 5.8vw, 92px);
  line-height: .98;
  letter-spacing: -.01em;
}
.companions h2 .it{ color: color-mix(in oklab, var(--accent-soft) 85%, white); }
.companions p.lede{
  margin: 28px 0 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  line-height: 1.55;
  color: rgba(250,246,237,.84);
  max-width: 38ch;
}
.companions .folk{
  margin-top: 48px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.companions .folk .f{
  display: flex;
  flex-direction: column;
}
.companions .folk .f .tile{
  position: relative;
  aspect-ratio: 1 / 1.1;
  width: 100%;
}
.companions .folk .f .name{
  position: static;
  margin: 12px 0 0;
  text-shadow: none;
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  color: var(--cream);
  line-height: 1.2;
  text-align: left;
  display: block;
}
.companions .folk .folk-row{
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.companions .folk .folk-price{
  font-family: var(--serif);
  font-weight: 500;
  font-size: 18px;
  color: var(--cream);
  line-height: 1;
}
.companions .folk .folk-price small{
  font-family: var(--sans);
  font-style: normal;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 500;
  color: rgba(245,240,229,.55);
  margin-left: 6px;
}
.companions .folk .add-btn.icon{
  padding: 7px 10px;
  background: transparent;
  border: 1px solid rgba(245,240,229,.4);
  color: var(--cream);
}
.companions .folk .add-btn.icon:hover{
  background: var(--cream); color: var(--ink); border-color: var(--cream);
}
.companions .folk .add-btn.icon .plus{ width: 11px; height: 11px; }
.companions .price-line{
  margin-top: 36px;
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: color-mix(in oklab, var(--accent-soft) 70%, white);
}

/* ============================== BOTTOM HERO ============================== */
.bottom-hero{
  position: relative;
  height: 80vh;
  min-height: 520px;
  max-height: 920px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}
.bottom-hero .bg{ position: absolute; inset: 0; z-index: 0; }
.bottom-hero .veil{
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background: linear-gradient(to bottom, rgba(44,26,14,.02) 0%, rgba(44,26,14,.4) 65%, rgba(44,26,14,.85) 100%);
}
.bottom-hero .content{
  position: relative; z-index: 2;
  width: 100%;
  padding: 0 clamp(28px, 5vw, 80px) 80px;
  text-align: center;
}
.bottom-hero h3{
  margin: 0 auto;
  max-width: 22ch;
  font-family: var(--serif);
  font-weight: 400;
  font-style: italic;
  font-size: clamp(36px, 5vw, 80px);
  line-height: 1.1;
  letter-spacing: -.005em;
  color: var(--cream);
  text-shadow: 0 1px 28px rgba(0,0,0,.3);
}

/* ============================== CLOSING ============================== */
.closing{
  background:
    linear-gradient(180deg, var(--cream) 0%, var(--accent-pale) 60%, var(--accent-soft) 100%);
  color: var(--ink);
  position: relative;
  overflow: hidden;
}
.closing::before{
  content:""; position: absolute;
  top: 0; left: 50%; transform: translateX(-50%);
  width: 1px; height: 80px;
  background: var(--accent); opacity: .45;
}
.closing .wrap{ text-align: center; position: relative; z-index: 2; }
.closing .eyebrow{ color: var(--accent-deep); }
.closing h2{
  margin: 36px auto 0;
  max-width: 22ch;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(44px, 6.4vw, 104px);
  line-height: 1.02;
  letter-spacing: -.01em;
}
.closing h2 .it{ color: var(--accent-deep); }
.closing .price{
  margin: 56px auto 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  color: var(--ink-soft);
}
.closing .cta{ margin-top: 28px; }
.closing .signoff{
  margin-top: 100px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 24px;
  padding-top: 28px;
  border-top: 1px solid var(--rule-soft);
}
.closing .signoff .left,
.closing .signoff .right{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .1em;
  color: var(--ink-soft);
}
.closing .signoff .right{ text-align: right; }
.closing .signoff .center{
  font-family: var(--serif);
  font-style: italic;
  font-size: 15px;
  color: var(--ink-soft);
}

/* ============================== FOOTER ============================== */
footer{
  background: var(--ink);
  color: var(--cream);
  padding: 64px clamp(28px, 5vw, 56px);
}
footer .wrap{
  display: grid;
  grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
  gap: 48px;
  max-width: 1340px; margin: 0 auto; padding: 0;
}
footer .left .foot-mark{
  display: block;
  width: 110px;
  height: auto;
  margin-bottom: 18px;
}
footer .left p{
  margin-top: 14px;
  max-width: 46ch;
  color: rgba(250,246,237,.7);
  font-size: 14px; line-height: 1.65;
}
footer .left .foot-contact{
  margin-top: 22px;
  padding-top: 20px;
  border-top: 0.5px solid rgba(250,246,237,.18);
  font-family: var(--sans);
  font-size: 13px;
  line-height: 1.7;
  color: rgba(250,246,237,.86);
}
footer .left .foot-contact a{
  color: inherit;
  text-decoration: none;
  display: block;
  transition: color .2s ease;
}
footer .left .foot-contact a:hover{ color: color-mix(in oklab, var(--accent-soft) 80%, white); }
footer .left .foot-contact .hours{
  display: block;
  margin-top: 8px;
  color: rgba(250,246,237,.55);
  font-size: 12px;
}
footer .left .foot-social{
  margin-top: 22px;
  display: flex;
  gap: 10px;
}
footer .left .foot-social a{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px; height: 36px;
  border: 0.5px solid rgba(250,246,237,.32);
  border-radius: 50%;
  color: rgba(250,246,237,.85);
  transition: background .2s ease, color .2s ease, border-color .2s ease;
}
footer .left .foot-social a:hover{
  background: var(--cream);
  color: var(--ink);
  border-color: var(--cream);
}
footer .left .foot-social svg{ width: 16px; height: 16px; stroke: currentColor; stroke-width: 1.4; fill: none; }
footer .left .retail-link{
  margin: 22px 0 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px;
  line-height: 1.5;
  color: rgba(250,246,237,.6);
}
footer .left .retail-link a{
  color: rgba(250,246,237,.88);
  text-decoration: none;
  border-bottom: 0.5px solid rgba(250,246,237,.32);
  padding-bottom: 1px;
  transition: color .2s ease, border-color .2s ease;
}
footer .left .retail-link a:hover{
  color: var(--cream);
  border-color: var(--cream);
}

/* Pay methods row */
footer .foot-mid{
  max-width: 1340px; margin: 40px auto 0;
  padding-top: 24px;
  border-top: 0.5px solid rgba(250,246,237,.18);
  display: flex; align-items: center; gap: 20px;
  flex-wrap: wrap;
}
footer .foot-mid .pay-label{
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px;
  color: rgba(250,246,237,.6);
  flex-shrink: 0;
}
footer .pay-methods{ display: flex; flex-wrap: wrap; align-items: center; gap: 0; }
footer .pay-chip{
  display: inline-block;
  padding: 0 14px 0 0;
  margin-right: 14px;
  border-right: 0.5px solid rgba(250,246,237,.18);
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: rgba(250,246,237,.65);
  white-space: nowrap;
}
footer .pay-chip:last-child{ border-right: 0; margin-right: 0; padding-right: 0; }
footer .pay-chip.po{ color: var(--cream); font-weight: 600; }
footer .cols{ display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px; }
footer .cols h6{
  margin: 0 0 14px;
  font-family: var(--sans); font-weight: 600;
  font-size: 11px; letter-spacing: .22em; text-transform: uppercase;
  color: rgba(250,246,237,.5);
}
footer .cols ul{ list-style: none; margin: 0; padding: 0; }
footer .cols li{
  font-family: var(--sans);
  font-size: 13px;
  line-height: 1.55;
  color: rgba(250,246,237,.86);
  margin-bottom: 6px;
}
footer .cols .catalog-list li{
  padding-left: 2.6em;
  text-indent: -2.6em;
}
footer .cols li a{
  text-decoration: none;
  color: inherit;
  transition: color .2s ease;
}
footer .cols li a:hover{ color: color-mix(in oklab, var(--accent-soft) 80%, white); }
footer .legal{
  max-width: 1340px; margin: 32px auto 0;
  padding-top: 22px;
  border-top: 0.5px solid rgba(250,246,237,.14);
  display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap;
  font-family: var(--sans);
  font-size: 12px;
  letter-spacing: .04em;
  color: rgba(250,246,237,.55);
}
footer .legal .legal-links{ display: flex; gap: 22px; flex-wrap: wrap; }
footer .legal .legal-links a{ color: inherit; text-decoration: none; transition: color .2s ease; }
footer .legal .legal-links a:hover{ color: var(--cream); }

/* ============================== RESPONSIVE ============================== */
@media (max-width: 1080px){
  .anchor .wrap,
  .intro .wrap,
  .companions .wrap,
  .gallery .head{
    grid-template-columns: 1fr; gap: 44px;
  }
  .anchor .side{
    border-left: 0; padding-left: 0;
    border-top: 1px solid var(--rule-soft); padding-top: 28px;
  }
  .intro .pillars{ grid-template-columns: repeat(2, 1fr); gap: 18px; }
  .stage .content{ padding: 56px 28px; }
  .split{ grid-template-columns: 1fr; }
  .split .img-side{ min-height: 360px; }
  .split .img-side::after{ display: none; }
  .split .content::before{ display: none; }
  .split .content .contents-list{ grid-template-columns: 1fr; }
  .spread{ padding: 72px 28px; }
  .spread .row{ grid-template-columns: 1fr; gap: 36px; }
  .spread .crops{ grid-template-columns: 1fr 1fr; grid-auto-rows: 200px; }
  .spread .learn{ grid-template-columns: 1fr 1fr; }
  .spread .learn .l{ border-bottom: 1px solid rgba(250,246,237,.12); }
  .spread .learn .l:nth-child(2){ border-right: 0; }
  .homes{ grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .home.size-hero, .home.size-tall, .home.size-std, .home.size-wide{
    grid-column: span 1;
  }
  .companions .col-img .tile{ height: 540px; }
  footer .wrap{ grid-template-columns: 1fr; }
}
@media (max-width: 640px){
  body{ font-size: 16px; }
  .nav{ grid-template-columns: 1fr auto; padding: 12px 18px; }
  .nav__center{ display: none; }
  .cover{ height: 88vh; min-height: 600px; }
  .cover .frame{ inset: 14px; }
  .cover .head{ top: 72px; left: 24px; right: 24px; }
  .cover h1{ left: 24px; right: 24px; bottom: 112px; }
  .cover .footer{ left: 24px; right: 24px; bottom: 28px; flex-direction: column; align-items: flex-start; gap: 16px; }
  .anchor, .intro, .gallery, .companions, .closing{ }
  .stage .top{ flex-direction: column; }
  .stage .top .right{ text-align: left; }
  .intro .pillars{ grid-template-columns: 1fr; }
  .split .content .craft{ grid-template-columns: 1fr; }
  .spread .crops{ grid-template-columns: 1fr; }
  .spread .learn{ grid-template-columns: 1fr; }
  .spread .learn .l{ border-right: 0 !important; }
  .homes{ grid-template-columns: 1fr 1fr; }
  .companions .folk{ grid-template-columns: repeat(2, 1fr); }
  .closing .signoff{ grid-template-columns: 1fr; text-align: center; }
  .closing .signoff .right{ text-align: center; }
  footer .cols{ grid-template-columns: 1fr 1fr; gap: 24px; }
}

/*"Ships separately" pill, auto-injected by data-long-lead JS at the bottom of the page.
   Tag any product card (.home), kit (.kit), or featured split with data-long-lead="true"
   to show a small pill that signals the item has its own ship timeline. */
.ships-separately-pill{
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 5px 11px;
  margin: 8px 8px 0 0;
  background: color-mix(in oklab, var(--amber, #854F0B) 10%, var(--cream, #F5F0E5));
  color: var(--amber, #854F0B);
  border: 0.5px solid color-mix(in oklab, var(--amber, #854F0B) 30%, transparent);
  border-radius: 999px;
  font-family: var(--sans, system-ui), sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
}
.ships-separately-pill::before{
  content:"";
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--amber, #854F0B);
  flex-shrink: 0;
}


/* Pillar/eyebrow + body alignment, fixes uneven row heights when eyebrow
   text wraps to 2 lines on some pillars but not others. Sets a minimum height
   on the eyebrow so all 4 pillar bodies start at the same y-position. */
.pillars .p{ display: flex; flex-direction: column; gap: 12px; }
.pillars .p .label{
  min-height: 2.4em;
  display: flex;
  align-items: flex-start;
  line-height: 1.25;
}
.pillars .p p{ margin: 0; }


/* Layout alternation, editorial rhythm.
   .split.image-right flips the standard split so content-left, image-right.
   Apply to Featured 2 (Letter Tracing) and Featured 3 (My Forest Floor) on
   Sensory Play, and to Featured 2 on Woodland and Small World, for rhythm. */
/* (Variant B below — the CSS grid order flip — is the canonical implementation.) */

/* Section divider, magazine TOC-entry style.
   Used between major editorial sections to mark transition. */
.section-divider{
  max-width: 1280px;
  margin: 0 auto;
  padding: 36px clamp(20px, 5vw, 56px) 0;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 24px;
  align-items: center;
}
.section-divider .num{
  font-family: var(--serif);
  font-style: italic;
  font-weight: 500;
  font-size: 16px;
  color: var(--accent-deep);
  letter-spacing: .04em;
}
.section-divider .line{
  height: 0.5px;
  background: var(--rule-strong);
}
.section-divider .label{
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--stone);
}


/* =================================================================
   LAYOUT ROTATION SYSTEM
   Three split variants (Featured Product) and three gallery
   variants (Collection Grid), applied in a fixed alternating
   pattern across each section page so no two adjacent blocks
   share the same geometry. Editorial rhythm without bespoke
   per-section markup.
   
   SPLIT VARIANTS (Featured Product):
     .split            — default: image-left, content-right
     .split.image-right — mirror: image-right, content-left
     .split.stage      — stacked: full-width image, content centered below
   
   GALLERY VARIANTS (Collection Grid):
     .gallery          — default: 5-card grid with hero/tall/std
     .gallery.even     — 5 equal columns, no hero sizing
     .gallery.strip    — 3 across hero row + 2 across detail row
   
   ROTATION PER SECTION PAGE:
     Featured 1 (Hero)    → default split
     Gallery 1            → default gallery (hero+4)
     Featured 2           → .image-right
     Gallery 2            → .even
     Featured 3 (if any)  → .stage
     Gallery 3 (if any)   → .strip
   ================================================================= */

/* Variant B — Mirror split: content-left, image-right.
   Uses CSS grid order property; text direction unchanged. */
.split.image-right .img-side{ order: 2; }
.split.image-right .content{ order: 1; }

/* Variant C — Stage split: full-width image hero, content centered beneath.
   Different visual rhythm from the side-by-side splits. */
.split.stage{
  display: block !important;
  padding: 0 0 clamp(56px, 7vw, 96px);
}
.split.stage .img-side{
  width: 100%;
  height: auto;
  padding: 0;
}
.split.stage .img-side .tile{
  width: 100%;
  aspect-ratio: 16 / 7;
  height: auto;
}
.split.stage .content{
  max-width: 920px;
  margin: clamp(40px, 5vw, 64px) auto 0;
  padding: 0 clamp(20px, 5vw, 56px);
}

/* Variant Y — Even gallery: 5 equal columns, override hero/tall/std sizing.
   Reads as a"collection" rather than a featured spread. */
.gallery.even .homes{ grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 18px; }
.gallery.even .home.size-hero,
.gallery.even .home.size-tall,
.gallery.even .home.size-std{ grid-column: auto; }
.gallery.even .home .tile-wrap{ aspect-ratio: 1 / 1; }
.gallery.even .home .tile-wrap .tile{ height: 100%; }
@media (max-width: 1080px){ .gallery.even .homes{ grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 720px){ .gallery.even .homes{ grid-template-columns: repeat(2, 1fr); } }

/* Variant Z — Strip gallery: 3 hero across the top, 2 wide detail below.
   Magazine"feature spread" geometry. */
.gallery.strip .homes{ grid-template-columns: repeat(6, 1fr); gap: 18px; }
.gallery.strip .home:nth-child(1),
.gallery.strip .home:nth-child(2),
.gallery.strip .home:nth-child(3){ grid-column: span 2; }
.gallery.strip .home:nth-child(4),
.gallery.strip .home:nth-child(5){ grid-column: span 3; }
.gallery.strip .home:nth-child(4) .tile-wrap,
.gallery.strip .home:nth-child(5) .tile-wrap{ aspect-ratio: 16 / 9; }
@media (max-width: 1080px){
  .gallery.strip .homes{ grid-template-columns: repeat(2, 1fr); }
  .gallery.strip .home:nth-child(1),
  .gallery.strip .home:nth-child(2),
  .gallery.strip .home:nth-child(3),
  .gallery.strip .home:nth-child(4),
  .gallery.strip .home:nth-child(5){ grid-column: auto; }
}


/* Row alignment, gallery cards.
   Stretches every card in a row to match the tallest, then floats the
   procurement footer (SKU, price, add-to-cart row) to card bottom so
   they land at a single horizontal line across the row. */
.gallery .homes{ grid-auto-rows: 1fr; align-items: stretch; }
.gallery .home{ height: 100%; }
.gallery .home .cap{ flex: 1 1 auto; display: flex; flex-direction: column; }
.gallery .home .cap > .meta{ margin-top: auto; }
.gallery .home .cap .price + .add-row,
.gallery .home .cap .add-row{ margin-top: auto; }

/* Even variant, equal columns so the row-stretch effect is most visible. */
.gallery.even .homes{ grid-auto-rows: 1fr; }
.gallery.even .home{ height: 100%; }

/* Strip variant, two-row pattern. Stretch within each row. */
.gallery.strip .homes{ grid-auto-rows: 1fr; }
.gallery.strip .home{ height: 100%; }


/* Standards row — sits below the .craft 3-cell block on Featured Product splits.
   Holds curriculum/standards alignment codes (CCSS, NGSS, EYFS, etc.) as
   small chip-pills. Kept separate from .craft to avoid cramming long codes
   into the 3-column grid and to keep the row alignment crisp. */
.split .content .standards-row{
  margin-top: 24px;
  padding-top: 20px;
  border-top: 1px solid var(--rule);
  display: grid;
  grid-template-columns: minmax(140px, auto) 1fr;
  gap: 24px;
  align-items: start;
}
.split .content .standards-row .label{
  color: var(--muted);
  font-size: 11px;
  letter-spacing: .18em;
  display: block;
  padding-top: 6px;
}
.split .content .standards-row .codes{
  display: flex; flex-wrap: wrap; gap: 8px;
}
.split .content .standards-row .code{
  font-family: var(--sans);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .06em;
  color: var(--accent-deep);
  padding: 6px 12px;
  background: color-mix(in oklab, var(--accent-deep) 6%, transparent);
  border: 0.5px solid color-mix(in oklab, var(--accent-deep) 28%, transparent);
  border-radius: 999px;
  white-space: nowrap;
}
@media (max-width: 720px){
  .split .content .standards-row{ grid-template-columns: 1fr; gap: 12px; }
  .split .content .standards-row .label{ padding-top: 0; }
}


/* Pull-quote, drops a large serif italic line between sections.
   Pulled from catalog body copy to connect the reader to the ecosystem.
   Centered, generous margin, hairline rule above and below. */
.pull-quote{
  background: var(--cream);
  padding: clamp(56px, 7vw, 96px) clamp(20px, 5vw, 56px);
  text-align: center;
  border-top: 0.5px solid var(--rule);
  border-bottom: 0.5px solid var(--rule);
}
.pull-quote blockquote{
  max-width: 56ch;
  margin: 0 auto;
  font-family: var(--serif);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(22px, 2.8vw, 32px);
  line-height: 1.25;
  color: var(--ink);
  letter-spacing: -.008em;
}
.pull-quote blockquote em{ color: var(--accent-deep); font-style: italic; }
.pull-quote cite{
  display: block;
  margin-top: 28px;
  font-family: var(--sans);
  font-style: normal;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--stone);
}


/* Caption variety, editorial. Apply explicitly via markup.
   Use <div class="cap stripped"> for less-important products (variants, accents).
   Use <div class="cap expanded"> for products that warrant editorial breath. */
.gallery .home .cap.stripped .desc{ display: none; }
.gallery .home .cap.stripped{ padding-bottom: 16px; }
.gallery .home .cap.expanded::before{
  content:"";
  display: block;
  width: 32px;
  height: 1px;
  background: var(--accent);
  opacity: .6;
  margin: 10px 0 12px;
}
.gallery .home .cap.expanded .desc{
  font-family: var(--serif);
  font-style: italic;
  font-size: 16px;
  line-height: 1.5;
}


/* Section 03 — Woodland personality
   Slow, contemplative, wide breath. More vertical air. */
.gallery { padding-top: clamp(80px, 9vw, 120px); padding-bottom: clamp(80px, 9vw, 120px); }

/* ============================== SECTION-SCOPED OVERRIDES ============================== */
/* Papoose Seasonal Trees: composition leaves the right-third of the photo
   as clean cream wall + table, perfect for the overlay text zone. We just
   need a soft right-side darkening so the cream serif stays legible
   without obscuring the trees. */
[data-screen-label="07 Papoose Seasonal Trees"] .veil{ display: none !important; }
/* Hero Product (Deer Family): the source photo is 1:1 with rearing antlers
   and ground-level fawns. Use a 1:1 tile so the whole deer family is flush
   with the frame, no letterbox. */
[data-screen-label="04 Hero Product"]{
  align-items: stretch !important;
}
[data-screen-label="04 Hero Product"] .img-side{
  align-self: stretch !important;
  background: transparent !important;
  padding: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  overflow: hidden !important;
}
[data-screen-label="04 Hero Product"] .img-side::before,
[data-screen-label="04 Hero Product"] .img-side::after{
  display: none !important;
}
[data-screen-label="04 Hero Product"] .img-side .tile{
  aspect-ratio: auto !important;
  height: 100% !important;
  width: 100% !important;
  max-width: none !important;
  margin: 0 !important;
  background: transparent !important;
}
[data-screen-label="04 Hero Product"] .img-side .tile img{
  width: 100% !important;
  height: 100% !important;
  object-fit: cover !important;
  object-position: center !important;
  display: block !important;
}
[data-screen-label="04 Hero Product"] .img-side .tile::before,
[data-screen-label="04 Hero Product"] .img-side .tile::after{
  display: none !important;
}
/* Papoose Seasonal Trees: full-bleed banner with eyebrow + title + one-liner
   sitting below the photo. The full content (description, contents list, craft,
   testimony, pairs) flows in the .seasonal-details section that follows. */
[data-screen-label="07 Papoose Seasonal Trees"]{
  display: block !important;
  height: auto !important;
  min-height: 0 !important;
  padding: 0 !important;
}
[data-screen-label="07 Papoose Seasonal Trees"] .img-side{
  position: static !important;
  width: 100% !important;
  padding: 0 !important;
  max-width: none !important;
}
[data-screen-label="07 Papoose Seasonal Trees"] .img-side .tile{
  position: static !important;
  inset: auto !important;
  width: 100% !important;
  aspect-ratio: auto !important;
  height: auto !important;
  border-radius: 0 !important;
  background: var(--cream);
}
[data-screen-label="07 Papoose Seasonal Trees"] .img-side .tile img{
  position: static !important;
  inset: auto !important;
  object-fit: cover !important;
  object-position: center !important;
  width: 100% !important;
  height: auto !important;
  display: block !important;
}
[data-screen-label="07 Papoose Seasonal Trees"] .img-side::after,
[data-screen-label="07 Papoose Seasonal Trees"] .img-side .tile .corner{
  display: none !important;
}
section[data-screen-label="07 Papoose Seasonal Trees"] .content{
  display: block !important;
  position: static !important;
  height: auto !important;
  background: transparent !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
  padding: clamp(36px, 5vw, 64px) clamp(28px, 5vw, 80px) clamp(24px, 3vw, 40px) !important;
  max-width: 900px;
  margin: 0 auto !important;
  text-align: center;
  color: var(--ink) !important;
}
[data-screen-label="07 Papoose Seasonal Trees"] .content h3,
[data-screen-label="07 Papoose Seasonal Trees"] .content .sub{
  color: var(--ink) !important;
}
[data-screen-label="07 Papoose Seasonal Trees"] .content .eyebrow{
  color: var(--accent-deep) !important;
}
/* Sibling section .seasonal-details — flowed below the photo, full editorial layout */
.seasonal-details{
  background: var(--cream);
  padding: clamp(56px, 7vw, 96px) clamp(28px, 5vw, 80px) clamp(64px, 8vw, 112px);
}
.seasonal-details > .wrap{
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(0, 6fr) minmax(0, 7fr);
  gap: clamp(40px, 5vw, 88px);
  align-items: start;
}
@media (max-width: 900px){
  .seasonal-details > .wrap{ grid-template-columns: 1fr; gap: 40px; }
}
.split .content h3, .gallery h2, .intro h3 { font-weight: 400; letter-spacing: 0; }
.split .content { padding-top: clamp(72px, 9vw, 132px) !important; padding-bottom: clamp(72px, 9vw, 132px) !important; }


/* Section divider, mobile fallback. Long labels should stack vertically. */
@media (max-width: 720px){
  .section-divider{
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .section-divider .line{ display: block; }
  .section-divider .label{
    grid-column: 1 / -1;
    margin-top: -4px;
  }
}


/* Breadcrumb, retail-parallel.
   Replaces the .back link in .subnav with a Home > Educator Catalog > Section
   trail. Mirrors retail's Home > Collection > Product logic, optimized for B2B
   buyers who navigate by program tier first, then section. */
.breadcrumb{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--sans);
  font-size: 12px;
  letter-spacing: .04em;
  color: var(--stone);
