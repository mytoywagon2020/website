}
.outfit .kit:hover{ transform: translateY(-3px); border-color: var(--rule-strong); }
.outfit .kit.featured{
  background: var(--accent-pale);
  border-color: color-mix(in oklab, var(--accent-soft) 80%, transparent);
}
.outfit .kit .pill{
  position: absolute;
  top: -12px;
  right: 24px;
}
.outfit .kit .tier{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 16px;
}
.outfit .kit h3{
  margin: 0 0 6px;
  font-family: var(--serif);
  font-weight: 500;
  font-size: 30px;
  line-height: 1.1;
  letter-spacing: -.005em;
  color: var(--ink);
}
.outfit .kit .sub{
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  color: var(--accent-deep);
  line-height: 1.4;
}
.outfit .kit .hair{
  width: 40px; height: 1px;
  background: var(--ink);
  opacity: .3;
  margin: 24px 0 22px;
}
.outfit .kit .desc{
  font-size: 14px;
  line-height: 1.65;
  color: var(--ink-soft);
  margin: 0 0 22px;
  max-width: 38ch;
}
.outfit .kit ul.contains{
  list-style: none;
  margin: 0 0 28px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.outfit .kit ul.contains li{
  font-family: var(--serif);
  font-style: italic;
  font-size: 16px;
  line-height: 1.45;
  color: var(--ink);
  padding-left: 18px;
  position: relative;
}
.outfit .kit ul.contains li::before{
  content:"";
  position: absolute;
  left: 0; top: 11px;
  width: 9px; height: 1px;
  background: var(--accent);
}
.outfit .kit .price-line{
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 18px;
  padding-top: 18px;
  border-top: 0.5px solid var(--rule-strong);
}
.outfit .kit .kit-cta{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  padding-bottom: 4px;
