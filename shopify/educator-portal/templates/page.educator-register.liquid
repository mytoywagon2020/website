{%- comment -%}
  Educator Account Registration (PUBLIC apply page).
  Replaces the old placeholder "educator-register" template. Renders inside the
  theme layout (keeps MTW header/footer). Uses the native contact form so every
  field is captured and emailed to the team; staff verify and create the approved
  educator account (Company/Catalog), which flips the gate from "being reviewed"
  to full access. Returning educators sign in via the login page.
{%- endcomment -%}

<style>
  .edu-reg{--cream:#F5F0E5;--warm-white:#FFFCF7;--ink:#2C2C2A;--forest:#3B6D11;--stone:#5F5E5A;--rule:rgba(44,44,42,0.16);--rule-strong:rgba(44,44,42,0.28);
    background:var(--cream);color:var(--ink);font-family:'Mulish',sans-serif;padding:clamp(40px,6vw,88px) clamp(18px,5vw,56px);}
  .edu-reg *{box-sizing:border-box;}
  .edu-reg__wrap{max-width:760px;margin:0 auto;}
  .edu-reg__eyebrow{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.18em;color:var(--stone);margin:0 0 14px;}
  .edu-reg__title{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:clamp(30px,4.5vw,44px);line-height:1.15;margin:0 0 14px;}
  .edu-reg__title em{font-style:italic;color:var(--forest);}
  .edu-reg__lead{font-size:16px;line-height:1.7;color:var(--stone);max-width:60ch;margin:0 0 8px;}
  .edu-reg__note{font-size:13px;color:var(--stone);margin:0 0 32px;}
  .edu-reg__ok{background:var(--warm-white);border:1px solid var(--forest);border-radius:2px;padding:28px 30px;margin:0 0 28px;}
  .edu-reg__ok h2{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:26px;margin:0 0 8px;}
  .edu-reg__err{background:#fbeeee;border:1px solid #b3261e;border-radius:2px;padding:14px 18px;margin:0 0 22px;color:#7a1a15;font-size:14px;}
  .edu-reg__card{background:var(--warm-white);border:1px solid var(--rule-strong);border-radius:2px;padding:clamp(24px,4vw,40px);}
  .edu-reg__row{display:grid;grid-template-columns:1fr 1fr;gap:18px 20px;margin:0 0 18px;}
  .edu-reg__field{display:flex;flex-direction:column;}
  .edu-reg__field.full{grid-column:1 / -1;}
  .edu-reg__field label{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--ink);margin:0 0 7px;}
  .edu-reg__field input,.edu-reg__field select,.edu-reg__field textarea{font-family:inherit;font-size:15px;color:var(--ink);background:var(--cream);border:1px solid var(--rule-strong);border-radius:2px;padding:12px 13px;width:100%;}
  .edu-reg__field textarea{min-height:110px;resize:vertical;}
  .edu-reg__field .hint{font-size:12px;color:var(--stone);margin-top:6px;}
  .edu-reg__submit{display:flex;align-items:center;justify-content:space-between;gap:18px;flex-wrap:wrap;margin-top:8px;}
  .edu-reg__submit p{font-size:12px;color:var(--stone);margin:0;max-width:42ch;}
  .edu-reg__submit a{color:var(--ink);border-bottom:.5px solid var(--rule-strong);}
  .edu-reg__btn{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;padding:14px 28px;border-radius:2px;border:1px solid var(--ink);background:var(--ink);color:var(--cream);cursor:pointer;}
  .edu-reg__signin{font-size:14px;color:var(--stone);margin:26px 0 0;text-align:center;}
  .edu-reg__signin a{color:var(--forest);font-weight:600;}
  @media(max-width:620px){.edu-reg__row{grid-template-columns:1fr;}}
</style>

<section class="edu-reg" data-screen-label="Educator Register">
  <div class="edu-reg__wrap">
    <p class="edu-reg__eyebrow">Educator Program</p>
    <h1 class="edu-reg__title">Apply for an <em>Educator account</em>.</h1>
    <p class="edu-reg__lead">Tell us a little about your school, practice, or homeschool. There&rsquo;s no fee to join and no minimum order &mdash; just educator pricing, Net-30 on purchase orders, and tax-exempt checkout once you&rsquo;re approved.</p>
    <p class="edu-reg__note">We reply within one to two business days. Tax-exempt and verification documents are collected after you apply.</p>

    {%- if form.posted_successfully? -%}
      <div class="edu-reg__ok">
        <h2>Application received.</h2>
        <p>Thank you &mdash; our team will verify your account and email you within one to two business days. Once approved, you can sign in to browse educator pricing and build purchase-order quotes.</p>
      </div>
    {%- endif -%}

    {%- form 'contact' -%}
      {%- if form.errors -%}
        <div class="edu-reg__err">Please check the highlighted fields and try again.</div>
      {%- endif -%}
      <input type="hidden" name="contact[Application type]" value="Educator account">
      <div class="edu-reg__card">
        <div class="edu-reg__row">
          <div class="edu-reg__field">
            <label for="edu-name">Your full name</label>
            <input type="text" id="edu-name" name="contact[name]" required>
          </div>
          <div class="edu-reg__field">
            <label for="edu-email">Email address</label>
            <input type="email" id="edu-email" name="contact[email]" required>
          </div>
        </div>
        <div class="edu-reg__row">
          <div class="edu-reg__field">
            <label for="edu-org">Organization name</label>
            <input type="text" id="edu-org" name="contact[Organization]" placeholder="School, practice, or &lsquo;Homeschool&rsquo;" required>
          </div>
          <div class="edu-reg__field">
            <label for="edu-role">Your role</label>
            <select id="edu-role" name="contact[Role]" required>
              <option value="">Choose one&hellip;</option>
              <option>Teacher</option>
              <option>Director / Head of school</option>
              <option>Occupational therapist</option>
              <option>Speech therapist</option>
              <option>Special education</option>
              <option>Homeschool parent</option>
              <option>Buyer / Office manager</option>
              <option>Other</option>
            </select>
          </div>
        </div>
        <div class="edu-reg__row">
          <div class="edu-reg__field">
            <label for="edu-type">Type of program</label>
            <select id="edu-type" name="contact[Program type]" required>
              <option value="">Choose one&hellip;</option>
              <option>Preschool / Daycare</option>
              <option>Elementary school</option>
              <option>Montessori</option>
              <option>Waldorf</option>
              <option>Reggio</option>
              <option>Homeschool co-op</option>
              <option>Therapy practice</option>
              <option>Library</option>
              <option>Other</option>
            </select>
          </div>
          <div class="edu-reg__field">
            <label for="edu-state">State</label>
            <input type="text" id="edu-state" name="contact[State]" required>
          </div>
        </div>
        <div class="edu-reg__row">
          <div class="edu-reg__field full">
            <label for="edu-notes">Anything you&rsquo;d like us to know</label>
            <textarea id="edu-notes" name="contact[body]" placeholder="Tell us about your program, the children you serve, or specific brands you&rsquo;re interested in."></textarea>
            <span class="hint">Optional. Helps us reply with a useful first email.</span>
          </div>
        </div>
        <div class="edu-reg__submit">
          <p>By submitting, you agree to our <a href="/policies/terms-of-service">terms</a> and <a href="/policies/privacy-policy">privacy policy</a>.</p>
          <button type="submit" class="edu-reg__btn">Submit application</button>
        </div>
      </div>
    {%- endform -%}

    <p class="edu-reg__signin">Already approved? <a href="{{ routes.account_login_url }}">Sign in to the educator catalog</a>.</p>
  </div>
</section>
