<style>
:root{--cream:#F5F0E5;--warm-white:#FFFCF7;--ink:#2C2C2A;--forest:#3B6D11;--amber:#854F0B;--stone:#5F5E5A;--rule:rgba(44,44,42,0.12);--rule-strong:rgba(44,44,42,0.22);--serif:'Cormorant Garamond',Georgia,serif;--sans:'Mulish',system-ui,sans-serif}
*{box-sizing:border-box}html,body{margin:0;padding:0}
body{font-family:var(--sans);color:var(--ink);background:var(--cream);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}

.crumbs{padding:20px clamp(20px,4vw,44px) 0;max-width:1100px;margin:0 auto;font-size:12px;letter-spacing:.08em;color:var(--stone)}
.crumbs a{color:var(--forest);text-decoration:underline;text-underline-offset:3px}
.crumbs .sep{margin:0 8px;color:var(--rule-strong)}

.hero{padding:48px clamp(20px,4vw,44px) 40px;max-width:1100px;margin:0 auto}
.hero .eyebrow{font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.22em;color:var(--forest);display:block;margin-bottom:18px}
.hero h1{font-family:var(--serif);font-weight:500;font-size:clamp(32px,4.2vw,48px);line-height:1.05;letter-spacing:-.01em;margin:0 0 22px;color:var(--ink);text-wrap:balance}
.hero h1 .it{font-style:italic;color:var(--forest)}
.hero p.dek{font-size:17px;line-height:1.6;color:var(--stone);max-width:64ch;margin:0 0 14px}
.hero p.body{font-size:15px;line-height:1.65;max-width:64ch;margin:0 0 8px}

/* grants grid */
.grants{padding:24px clamp(20px,4vw,44px) 60px;max-width:1100px;margin:0 auto}
.grants-head{margin-bottom:36px}
.grants-head .eyebrow{font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.22em;color:var(--forest);display:block;margin-bottom:14px}
.grants-head h2{font-family:var(--serif);font-weight:500;font-size:clamp(26px,3vw,34px);line-height:1.2;color:var(--ink);margin:0 0 12px}
.grants-head h2 .it{font-style:italic;color:var(--forest)}
.grants-head p{font-size:15px;color:var(--stone);max-width:62ch;margin:0}

.grant-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:8px}
.grant-card{background:var(--warm-white);border:0.5px solid var(--rule);border-radius:2px;padding:28px 26px;display:flex;flex-direction:column;gap:14px}
.grant-card:hover{border-color:var(--ink);transform:translateY(-2px);box-shadow:0 8px 24px rgba(44,44,42,.06);transition:all .2s}
.grant-card .tag{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.18em;color:var(--forest);display:inline-block}
.grant-card h3{font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.2;color:var(--ink);margin:0;letter-spacing:-.005em}
.grant-card .meta{display:flex;flex-wrap:wrap;gap:14px;font-size:12px;color:var(--stone)}
.grant-card .meta span{display:inline-flex;gap:5px}
.grant-card .meta strong{color:var(--ink);font-weight:600}
.grant-card .what{font-size:14px;color:var(--ink);line-height:1.55;margin:0}
.grant-card .fit{font-size:13.5px;color:var(--stone);line-height:1.55;margin:0;border-top:0.5px solid var(--rule);padding-top:12px;font-style:italic}
.grant-card .more{margin-top:auto;padding-top:8px}
.grant-card .more a{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.14em;color:var(--forest);display:inline-flex;align-items:center;gap:6px}
.grant-card .more a::after{content:"";width:6px;height:6px;border-top:1.5px solid currentColor;border-right:1.5px solid currentColor;transform:rotate(45deg);display:inline-block}
@media(max-width:760px){.grant-grid{grid-template-columns:1fr}}

/* writing tips */
.tips-sec{background:var(--warm-white);border-top:0.5px solid var(--rule);border-bottom:0.5px solid var(--rule);padding:56px clamp(20px,4vw,44px)}
.tips-sec-inner{max-width:1000px;margin:0 auto}
.tips-sec h2{font-family:var(--serif);font-weight:500;font-size:clamp(26px,3vw,34px);line-height:1.2;color:var(--ink);margin:0 0 16px}
.tips-sec h2 .it{font-style:italic;color:var(--forest)}
.tips-sec h2 .eyebrow{font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.22em;color:var(--forest);display:block;margin-bottom:14px;font-family:var(--sans);font-style:normal}
.tips-sec p.lede{font-size:16px;color:var(--stone);line-height:1.65;max-width:62ch;margin:0 0 24px}
.tips{padding-left:0;list-style:none;margin:0}
.tips li{padding:18px 0;border-bottom:0.5px solid var(--rule);font-size:14.5px;line-height:1.65;color:var(--ink);display:flex;gap:18px;align-items:baseline}
.tips li:last-child{border-bottom:none}
.tips .n{font-family:var(--serif);font-style:italic;font-size:26px;color:var(--forest);flex:0 0 40px;line-height:1}
.tips strong{font-weight:600;color:var(--ink)}

/* budget examples */
.budgets{padding:60px clamp(20px,4vw,44px);max-width:1000px;margin:0 auto}
.budgets h2{font-family:var(--serif);font-weight:500;font-size:clamp(26px,3vw,34px);line-height:1.2;color:var(--ink);margin:0 0 16px}
.budgets h2 .it{font-style:italic;color:var(--forest)}
.budgets h2 .eyebrow{font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.22em;color:var(--forest);display:block;margin-bottom:14px;font-family:var(--sans);font-style:normal}
.budgets p.lede{font-size:16px;color:var(--stone);line-height:1.65;max-width:62ch;margin:0 0 24px}
.budget-list{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:24px}
.budget-card{background:var(--cream);border:0.5px solid var(--rule);border-radius:2px;padding:22px 20px}
.budget-card .level{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.18em;color:var(--forest);margin-bottom:8px;display:block}
.budget-card h4{font-family:var(--serif);font-weight:500;font-size:19px;color:var(--ink);margin:0 0 6px;line-height:1.2}
.budget-card .total{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--ink);margin:0 0 10px}
.budget-card .fit{font-size:13px;color:var(--stone);line-height:1.55;margin:0}
@media(max-width:760px){.budget-list{grid-template-columns:1fr}}

/* cta band */
.cta-band{background:var(--warm-white);border-top:0.5px solid var(--rule);border-bottom:0.5px solid var(--rule);padding:56px clamp(20px,4vw,44px);text-align:center}
.cta-band-inner{max-width:760px;margin:0 auto}
.cta-band h3{font-family:var(--serif);font-weight:500;font-size:clamp(24px,3vw,32px);line-height:1.2;color:var(--ink);margin:0 0 16px}
.cta-band h3 .it{font-style:italic;color:var(--forest)}
.cta-band p{font-size:15px;color:var(--stone);line-height:1.6;margin:0 0 22px;max-width:60ch;margin-left:auto;margin-right:auto}
.cta-band .actions{display:flex;gap:12px;flex-wrap:wrap;justify-content:center}
.btn{display:inline-block;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.12em;padding:14px 26px;border-radius:2px;border:1px solid var(--ink);transition:background .15s,color .15s}
.btn--solid{background:var(--ink);color:var(--cream)}
.btn--solid:hover{background:var(--forest);border-color:var(--forest)}
.btn--ghost{color:var(--ink);background:transparent}
.btn--ghost:hover{background:var(--ink);color:var(--cream)}

/* related */
.related{background:var(--cream);border-top:0.5px solid var(--rule);padding:48px clamp(20px,4vw,44px)}
.related-inner{max-width:1000px;margin:0 auto}
.related h3{font-family:var(--serif);font-weight:500;font-size:22px;color:var(--ink);margin:0 0 18px}
.related-list{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.related-card{background:var(--warm-white);border:0.5px solid var(--rule);border-radius:2px;padding:22px}
.related-card .tag{font-size:10.5px;font-weight:600;text-transform:uppercase;letter-spacing:.14em;color:var(--stone);margin-bottom:6px;display:block}
.related-card h4{font-family:var(--serif);font-weight:500;font-size:18px;color:var(--ink);margin:0 0 6px}
.related-card p{font-size:13.5px;color:var(--stone);margin:0 0 10px;line-height:1.55}
.related-card .lk{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.14em;color:var(--forest)}
@media(max-width:680px){.related-list{grid-template-columns:1fr}}

/* disclosure */
.disclosure{background:var(--cream);border-top:0.5px solid var(--rule);padding:32px clamp(20px,4vw,44px);text-align:center}
.disclosure p{font-size:12.5px;color:var(--stone);line-height:1.55;max-width:62ch;margin:0 auto}
.disclosure p strong{color:var(--ink)}
</style>
</head>
