  letter-spacing: -.01em;
}
.companions h2 .it{ color: color-mix(in oklab, var(--accent-soft) 85%, white); }
.companions p.lede{
  margin: 28px 0 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
