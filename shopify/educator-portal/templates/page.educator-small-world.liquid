}
.bottom-hero h3{
  margin: 0 auto;
  max-width: 22ch;
  font-family: var(--serif);
  font-weight: 400;
  font-style: italic;
  font-size: clamp(36px, 5vw, 80px);
  line-height: 1.1;
  letter-spacing: -.005em;
  color: var(--cream);
