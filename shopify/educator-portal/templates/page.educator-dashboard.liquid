{% layout none %}
{%- comment -%}
  Educator Dashboard — gated portal home for approved educators.
  Renders live customer data (orders, invoices) via Liquid, so it must be its own
  template (the shared page.educator-portal template only outputs static page.content).
  Closed unless the customer is tagged 'educator-approved' or is a B2B customer.
{%- endcomment -%}
{%- assign is_approved = false -%}
{%- if customer and customer.tags contains 'educator-approved' -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if customer.b2b? -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if is_approved -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Educator Dashboard | {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--cream:#F5F0E5;--warm-white:#FFFCF7;--ink:#2C2C2A;--forest:#3B6D11;--amber:#854F0B;--stone:#5F5E5A;--card-bg:#EDE3CD;--rule:rgba(44,44,42,0.12);--rule-strong:rgba(44,44,42,0.22);}
    *{box-sizing:border-box;} html,body{margin:0;padding:0;}
    body{font-family:'Mulish',sans-serif;color:var(--ink);background:var(--cream);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased;}
    a{color:inherit;text-decoration:none;} img{max-width:100%;display:block;}
    .wrap{max-width:1160px;margin:0 auto;padding:0 40px;}
    .utility{background:var(--ink);color:var(--cream);font-size:12.5px;letter-spacing:.06em;}
    .utility .wrap{display:flex;justify-content:space-between;align-items:center;padding:11px 40px;}
    .utility a{color:rgba(245,240,229,.75);} .utility a:hover{color:var(--cream);}
    header.nav{border-bottom:.5px solid var(--rule);background:var(--cream);}
    header.nav .wrap{display:flex;justify-content:space-between;align-items:center;padding:20px 40px;gap:24px;}
    .logo{font-family:'Cormorant Garamond',serif;font-size:26px;letter-spacing:.2em;text-transform:uppercase;line-height:1;color:var(--ink);}
    .logo small{display:block;font-family:'Mulish',sans-serif;font-size:10.5px;letter-spacing:.22em;color:var(--stone);margin-top:7px;}
    .nav-links{display:flex;gap:26px;font-size:14px;font-weight:500;}
    .nav-links a:hover{color:var(--forest);}
    .dash-hero{padding:48px 0 8px;}
    .dash-hero .eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .dash-hero h1{font-family:'Cormorant Garamond',serif;font-size:46px;font-weight:500;margin:12px 0 6px;letter-spacing:-.01em;line-height:1.05;}
    .dash-hero h1 em{font-style:italic;}
    .dash-hero p{color:var(--stone);margin:0;}
    .actions{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;padding:36px 0;}
    .action{background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:28px;display:flex;flex-direction:column;gap:10px;transition:border-color 160ms ease;}
    .action:hover{border-color:var(--ink);}
    .action h3{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;margin:0;}
    .action p{font-size:13.5px;color:var(--stone);margin:0;flex:1;}
    .action .go{font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);}
    .action--accent{background:var(--ink);color:var(--cream);} .action--accent p{color:rgba(245,240,229,.8);} .action--accent .go{color:var(--cream);}
    section.block{padding:30px 0;border-top:.5px solid var(--rule);}
    .block h2{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:500;margin:0 0 18px;letter-spacing:-.005em;}
    table.orders{width:100%;border-collapse:collapse;font-size:14px;}
    table.orders th{text-align:left;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--stone);font-weight:600;padding:10px 12px;border-bottom:.5px solid var(--rule-strong);}
    table.orders td{padding:14px 12px;border-bottom:.5px solid var(--rule);vertical-align:middle;}
    .pill{display:inline-block;font-size:11px;font-weight:600;letter-spacing:.04em;padding:3px 11px;border-radius:999px;}
    .pill--paid{background:#e7f0e0;color:var(--forest);} .pill--pending{background:#f6ecd8;color:var(--amber);} .pill--other{background:#ececec;color:var(--stone);}
    .lk{color:var(--forest);font-weight:600;}
    .empty{background:var(--warm-white);border:1px dashed var(--rule-strong);border-radius:3px;padding:36px;text-align:center;color:var(--stone);}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:12px 24px;font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;border-radius:2px;background:var(--ink);color:var(--cream);border:.5px solid var(--ink);}
    .btn--ghost{background:transparent;color:var(--ink);border-color:var(--rule-strong);}
    .po-grid{display:grid;grid-template-columns:1.25fr 1fr;gap:24px;align-items:start;}
    .po-card{background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:28px;}
    .po-card h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:20px;margin:0 0 8px;}
    footer.foot{border-top:.5px solid var(--rule);margin-top:44px;background:var(--cream);}
    footer.foot .wrap{display:flex;justify-content:space-between;padding:28px 40px;font-size:12px;color:var(--stone);flex-wrap:wrap;gap:12px;}
    @media(max-width:860px){.actions{grid-template-columns:1fr;}.po-grid{grid-template-columns:1fr;}.nav-links{display:none;}.dash-hero h1{font-size:34px;}.wrap,.utility .wrap,header.nav .wrap,footer.foot .wrap{padding-left:20px;padding-right:20px;}.orders thead{display:none;}table.orders,table.orders tbody{display:block;}table.orders tr{display:block;background:var(--warm-white);border:.5px solid var(--rule-strong);border-radius:7px;padding:14px 16px;margin-bottom:12px;}table.orders td{display:block;padding:3px 0;border:0;}table.orders td:first-child{font-size:16px;margin-bottom:6px;}}
    /* brand-aligned accents (cream/ink/forest/stone/amber) */
    .dash-banner{display:flex;align-items:center;gap:18px;justify-content:space-between;flex-wrap:wrap;background:var(--warm-white);color:var(--ink);border:1px solid var(--rule-strong);border-left:4px solid var(--forest);border-radius:3px;padding:22px 26px;margin:20px 0 6px;font-size:14px;line-height:1.55;}
    .dash-banner strong{font-weight:700;color:var(--ink);font-family:'Cormorant Garamond',serif;font-style:italic;font-size:18px;font-weight:500;}
    .dash-banner-cta{background:var(--ink);color:var(--cream);font-size:11.5px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:11px 22px;border-radius:2px;white-space:nowrap;border:1px solid var(--ink);}
    .dash-banner-cta:hover{background:var(--forest);border-color:var(--forest);}
    .snapshot{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;padding:14px 0 6px;}
    .stat{background:var(--warm-white);border:1px solid var(--rule-strong);border-top:3px solid var(--forest);border-radius:3px;padding:22px 24px;color:var(--ink);}
    .stat--orders,.stat--invoices,.stat--season{background:var(--warm-white);color:var(--ink);}
    .stat-k{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--stone);margin:0 0 9px;font-weight:600;}
    .stat-v{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:500;line-height:1.1;margin:0;color:var(--ink);}
    .stat-sub{font-size:12.5px;color:var(--stone);margin:7px 0 0;}
    .stat-sub a{color:var(--forest);text-decoration:none;font-weight:600;}
    .action--c1{border-top:3px solid var(--forest);} .action--c2{border-top:3px solid var(--ink);} .action--c3{border-top:3px solid var(--forest);}
    .guided{background:var(--warm-white);border:1px solid var(--rule-strong);border-left:3px solid var(--forest);border-radius:3px;padding:24px 26px;}
    .guided h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:22px;margin:0 0 14px;}
    .guided ol{margin:0;padding-left:20px;color:var(--ink);} .guided li{margin:0 0 9px;line-height:1.5;}
    .guided li a{color:var(--forest);font-weight:600;}
    @media(max-width:860px){.snapshot{grid-template-columns:1fr;}.dash-banner{flex-direction:column;align-items:flex-start;}}
  </style>
</head>
<body>
  {% section 'mtw-educator-header' %}

  <main class="wrap">
    <section class="dash-hero">
      <span class="eyebrow">Educator Dashboard</span>
      <h1>Welcome back{% if customer.first_name != blank %}, <em>{{ customer.first_name }}</em>{% endif %}.</h1>
      <p>
        {%- if customer.b2b? and customer.current_company != blank -%}{{ customer.current_company.name }} &middot; {% endif -%}
        Approved educator account &middot; {{ customer.email }}
      </p>
    </section>

    {%- liquid
      assign now_month = 'now' | date: '%m' | plus: 0
      assign now_year = 'now' | date: '%Y' | plus: 0
      assign es = shop.metafields.educator.settings.value
      if now_month >= 1 and now_month <= 6
        assign edu_window = es.fall_window | default: 'August–September' | append: ' ' | append: now_year
        assign edu_orderby = es.fall_order_by | default: 'July 15'
        assign edu_banner_img = 'sw-cover-lifestyle.webp'
      else
        assign ny = now_year | plus: 1
        assign edu_window = es.spring_window | default: 'May–June' | append: ' ' | append: ny
        assign edu_orderby = es.spring_order_by | default: 'March 15'
        assign edu_banner_img = 'fairy-cover-pink-blossom.webp'
      endif
      assign open_count = 0
      assign open_total = 0
      for o in customer.orders
        assign o_paid = false
        if o.financial_status == 'paid' or o.tags contains 'po-paid-external'
          assign o_paid = true
        endif
        unless o_paid
          assign open_count = open_count | plus: 1
          assign open_total = open_total | plus: o.total_price
        endunless
      endfor
    -%}

    <div class="dash-banner">
      <span><strong>Next delivery window: {{ edu_window }}.</strong> Most items deliver in this window. Order by {{ edu_orderby }}. Stocked, seasonal, and made-to-order items are confirmed on your quote.</span>
      <a class="dash-banner-cta" href="/pages/educators">Shop the catalog</a>
    </div>

    <div class="snapshot">
      <div class="stat stat--orders">
        <p class="stat-k">Your orders</p>
        <p class="stat-v">{{ customer.orders.size }}</p>
        <p class="stat-sub">{% if customer.orders.size > 0 %}<a href="#orders">View all &rarr;</a>{% else %}No orders yet{% endif %}</p>
      </div>
      <div class="stat stat--invoices">
        <p class="stat-k">Open invoices</p>
        <p class="stat-v">{{ open_count }}</p>
        <p class="stat-sub">{% if open_count > 0 %}{{ open_total | money }} outstanding{% else %}Nothing due{% endif %}</p>
      </div>
      <div class="stat stat--season">
        <p class="stat-k">Next delivery</p>
        <p class="stat-v" style="font-size:23px;">{{ edu_window }}</p>
        <p class="stat-sub">Order by {{ edu_orderby }}</p>
      </div>
    </div>

    <section class="actions">
      <a class="action action--accent action--c1" href="/pages/educators">
        <h3>Shop the Educator Catalog</h3>
        <p>Browse the full catalog at your educator pricing and build a quote.</p>
        <span class="go">Open the catalog &rarr;</span>
      </a>
      {%- if customer.b2b? -%}
      <a class="action action--c2" href="{{ routes.cart_url }}">
        <h3>Build a quote</h3>
        <p>Add catalog items to your cart, then submit at checkout. It becomes a quote our team reviews and approves on your terms.</p>
        <span class="go">Review cart &amp; submit &rarr;</span>
      </a>
      {%- else -%}
      <a class="action action--c2" href="/pages/new-quote">
        <h3>Start a new quote</h3>
        <p>Add items and quantities, then submit a quote for a purchase order.</p>
        <span class="go">New quote &rarr;</span>
      </a>
      {%- endif -%}
      <a class="action action--c3" href="#po">
        <h3>Submit a purchase order</h3>
        <p>Send your school or district PO to fulfill an approved quote.</p>
        <span class="go">Submit PO &rarr;</span>
      </a>
    </section>

    <section class="block" id="orders">
      <h2>Your orders</h2>
      {%- if customer.orders.size > 0 -%}
      <table class="orders">
        <thead><tr><th>Order</th><th>Date</th><th>Payment</th><th>Fulfillment</th><th>Total</th><th></th></tr></thead>
        <tbody>
        {%- for order in customer.orders -%}
          {%- assign o_paid = false -%}{%- if order.financial_status == 'paid' or order.tags contains 'po-paid-external' -%}{%- assign o_paid = true -%}{%- endif -%}
          {%- assign o_ful = false -%}{%- if order.fulfillment_status == 'fulfilled' or order.tags contains 'fulfilled-external' -%}{%- assign o_ful = true -%}{%- endif -%}
          <tr>
            <td><strong>{{ order.name }}</strong></td>
            <td>{{ order.created_at | date: "%b %-d, %Y" }}</td>
            <td>{% if o_paid %}<span class="pill pill--paid">Paid</span>{% elsif order.tags contains 'invoice-sent' %}<span class="pill pill--pending">Invoiced</span>{% else %}<span class="pill pill--other">Payment due</span>{% endif %}</td>
            <td>
              {%- assign fstat = order.fulfillment_status -%}
              {%- if fstat == 'fulfilled' or order.tags contains 'fulfilled-external' -%}<span class="pill pill--paid">Fulfilled</span>
              {%- elsif fstat == 'partial' -%}<span class="pill pill--pending">Partially shipped</span>
              {%- else -%}<span class="pill pill--other">Processing</span>{%- endif -%}
              {%- for f in order.fulfillments -%}
                {%- if f.tracking_url != blank -%}<div style="margin-top:5px;"><a class="lk" href="{{ f.tracking_url }}">Track{% if f.tracking_company != blank %} {{ f.tracking_company }}{% endif %}{% if f.tracking_number != blank %} {{ f.tracking_number }}{% endif %} &rarr;</a></div>
                {%- elsif f.tracking_number != blank -%}<div style="margin-top:5px;font-size:12.5px;color:var(--stone);">{{ f.tracking_company }} {{ f.tracking_number }}</div>{%- endif -%}
              {%- endfor -%}
              {%- if fstat == 'partial' -%}{%- assign rem = 0 -%}{%- for li in order.line_items -%}{%- assign rem = rem | plus: li.fulfillable_quantity -%}{%- endfor -%}{%- if rem > 0 -%}<div style="margin-top:5px;font-size:12px;color:var(--amber);">{{ rem }} item{% if rem > 1 %}s{% endif %} still to ship</div>{%- endif -%}{%- endif -%}
            </td>
            <td>{{ order.total_price | money }}</td>
            <td><a class="lk" href="{{ order.customer_url }}">View &rarr;</a></td>
          </tr>
        {%- endfor -%}
        </tbody>
      </table>
      {%- else -%}
      <div class="guided">
        <h3>Place your first order in three steps</h3>
        <ol>
          <li><strong>Browse the catalog</strong> and add items to your basket. <a href="/pages/educators">Open the Educator Catalog &rarr;</a></li>
          <li><strong>Send a quote.</strong> We reply within one business day with an itemized quote (pricing held 45 days), including shipping and tax. <a href="/pages/new-quote">Start a quote &rarr;</a></li>
          <li><strong>Issue your PO</strong> referencing the quote; we confirm, allocate, and ship to your delivery window. Net-30 / Net-60 available.</li>
        </ol>
        <p style="margin:14px 0 0;color:var(--stone);font-size:13.5px;">Prefer to pay now? Card, Shop Pay, Apple Pay, Google Pay, and ACH are all available at checkout.</p>
      </div>
      {%- endif -%}
    </section>

    <section class="block" id="invoices">
      <h2>Invoices &amp; payment terms</h2>
      {%- assign inv_count = 0 -%}
      {%- for order in customer.orders -%}{%- assign o_paid = false -%}{%- if order.financial_status == 'paid' or order.tags contains 'po-paid-external' -%}{%- assign o_paid = true -%}{%- endif -%}{%- unless o_paid -%}{%- assign inv_count = inv_count | plus: 1 -%}{%- endunless -%}{%- endfor -%}
      {%- if inv_count > 0 -%}
      <table class="orders">
        <thead><tr><th>Invoice</th><th>Date</th><th>Status</th><th>Amount</th><th></th></tr></thead>
        <tbody>
        {%- for order in customer.orders -%}
          {%- assign o_paid = false -%}{%- if order.financial_status == 'paid' or order.tags contains 'po-paid-external' -%}{%- assign o_paid = true -%}{%- endif -%}
          {%- unless o_paid -%}
          <tr>
            <td><strong>{{ order.name }}</strong></td>
            <td>{{ order.created_at | date: "%b %-d, %Y" }}</td>
            <td>{% if order.tags contains 'invoice-sent' %}<span class="pill pill--pending">Invoiced</span>{% else %}<span class="pill pill--other">Payment due</span>{% endif %}</td>
            <td>{{ order.total_price | money }}</td>
            <td><a class="lk" href="{{ order.customer_url }}">View / pay &rarr;</a></td>
          </tr>
          {%- endunless -%}
        {%- endfor -%}
        </tbody>
      </table>
      <p style="color:var(--stone);font-size:13px;margin-top:14px;">Orders paid by PO, check, or ACH are marked paid here as soon as we record your payment. Net-30 / Net-60 terms available for approved organizations.</p>
      {%- else -%}
      <div class="empty">No open invoices. Net-30 / Net-60 invoices will appear here once a purchase order is processed.</div>
      {%- endif -%}
    </section>

    <section class="block" id="po">
      <h2>Submit a purchase order</h2>
      <div class="po-grid">
        <div class="po-card">
          <h3>Email us your PO</h3>
          <p style="margin-top:0;color:var(--stone);">Have an approved quote? Send your school or district PO (PDF) and we convert it to an order on your terms. We confirm within one business day. Inventory is allocated once your PO is received.</p>
          <p style="margin:14px 0 4px;"><a class="btn" href="mailto:educators@mytoywagon.com?subject=Purchase%20Order%20Submission&body=Quote%20number%3A%20%0APO%20number%3A%20%0ABilling%20contact%3A%20%0AShip-to%20address(es)%3A%20%0ANeeded%20by%3A%20%0ANotes%3A%20">Email your PO &rarr;</a></p>
          <p style="color:var(--stone);font-size:12.5px;margin-top:12px;">Include: quote number, PO number, billing contact, ship-to address(es), needed-by date, and a tax-exempt certificate if not already on file.</p>
        </div>
        <div class="po-card">
          <h3>No PO yet?</h3>
          <p style="color:var(--stone);font-size:14px;">Build a quote first. Take the itemized quote (pricing held 45 days) to your procurement team, then send the PO back to us.</p>
          <p style="margin:12px 0 0;"><a class="btn btn--ghost" href="/pages/new-quote">Start a quote &rarr;</a></p>
          <p style="color:var(--stone);font-size:12.5px;margin-top:12px;">Prefer to pay now? Card, Shop Pay, Apple Pay, Google Pay, and ACH are all available at checkout.</p>
        </div>
      </div>
    </section>

    <section class="block" id="account">
      <h2>Your account</h2>
      <div class="po-grid">
        <div class="po-card">
          <h3>Account details</h3>
          <p style="margin:0 0 6px;font-size:14px;"><strong>Status:</strong> Approved educator</p>
          {%- if customer.b2b? and customer.current_company != blank -%}<p style="margin:0 0 6px;font-size:14px;"><strong>Organization:</strong> {{ customer.current_company.name }}</p>{%- endif -%}
          <p style="margin:0 0 6px;font-size:14px;"><strong>Contact:</strong> {{ customer.name | strip }}{% if customer.email != blank %} &middot; {{ customer.email }}{% endif %}</p>
          <p style="margin:0 0 14px;font-size:14px;"><strong>Terms:</strong> Net-30 and Net-60 available for approved organizations, confirmed on each quote.</p>
          <a class="btn btn--ghost" href="{{ routes.account_url }}">Account &amp; addresses</a>
        </div>
        <div class="po-card">
          <h3>Vendor documents</h3>
          <p style="margin:0 0 12px;color:var(--stone);font-size:14px;">For your accounts-payable team and grant or foundation funding: W-9, certificate of insurance, tax-exempt handling, and supplier documentation.</p>
          <a class="btn btn--ghost" href="/pages/vendor-profile">Vendor profile / W-9</a>
          <p style="margin:12px 0 0;font-size:13px;"><a class="lk" href="mailto:educators@mytoywagon.com?subject=Vendor%20documents%20request&body=Please%20send%3A%20W-9%2C%20COI%2C%20tax-exempt%2C%20supplier%20packet.%0AOrganization%3A%20">Request W-9, COI &amp; supplier packet &rarr;</a></p>
        </div>
      </div>
    </section>

    <section class="block">
      <h2>Resources &amp; support</h2>
      <p>
        <a class="btn btn--ghost" href="/pages/educators">Educator Catalog</a> &nbsp;
        <a class="btn btn--ghost" href="/pages/procurement-guide">Procurement guide</a> &nbsp;
        <a class="btn btn--ghost" href="/pages/new-quote">Request a quote</a>
      </p>
      <p style="color:var(--stone);font-size:14px;margin-top:14px;">Need a curriculum-alignment letter for an order or grant? <a class="lk" href="mailto:educators@mytoywagon.com?subject=Curriculum-alignment%20letter">Ask our team &rarr;</a></p>
      <p style="color:var(--stone);font-size:14px;">Questions about an order, quote, or your account: <a class="lk" href="mailto:educators@mytoywagon.com">educators@mytoywagon.com</a> &middot; <a class="lk" href="tel:+16268410421">(626) 841-0421</a> &middot; Mon&ndash;Fri 9&ndash;5 PT</p>
    </section>
  </main>

  {% section 'mtw-educator-footer' %}
  <script src="https://tally.so/widgets/embed.js"></script>
</body>
</html>
{%- else -%}
{% render 'educator-gate' %}
{%- endif -%}
