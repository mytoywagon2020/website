        <p>New arrivals, restocks, and a few thoughts on heirloom play. No spam, ever.</p>
        {%- form 'customer' -%}
          {%- if form.posted_successfully? -%}
            <p class="mtwft__nl-ok">Thank you. You're on the list.</p>
          {%- else -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" name="contact[email]" placeholder="you@email.com" required aria-label="Email">
