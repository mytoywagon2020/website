  "name": "MTW Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Brand tagline", "default": "Heirloom toys, curated by hand. A family-owned boutique, online since 2020." },
    { "type": "text", "id": "location", "label": "Location", "default": "Los Angeles, California" },
    { "type": "text", "id": "hours", "label": "Hours", "default": "Mon to Fri, 9 am to 5 pm PT" },
    { "type": "text", "id": "email", "label": "Contact email", "default": "contact@mytoywagon.com" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "626.841.0421" },
    { "type": "header", "content": "Social (leave blank to hide)" },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "pinterest", "label": "Pinterest URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" },
    { "type": "url", "id": "tiktok", "label": "TikTok URL" },
    { "type": "header", "content": "Trust badge" },
    { "type": "checkbox", "id": "show_badge", "label": "Show Google rating badge", "default": false },
    { "type": "text", "id": "badge_title", "label": "Badge title (unused with Google badge)" },
    { "type": "text", "id": "badge_sub", "label": "Badge subtitle (unused with Google badge)" },
    { "type": "header", "content": "Bottom bar" },
    { "type": "text", "id": "bottom_tagline", "label": "Bottom tagline", "default": "Heirloom toys, curated by hand." },
    { "type": "text", "id": "copyright_suffix", "label": "Copyright suffix", "default": "All rights reserved." }
  ],
  "blocks": [],
  "presets": [{ "name": "MTW Footer" }]
}
{% endschema %}
