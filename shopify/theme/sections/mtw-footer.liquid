      <div class="mtwft__m-contact">
        <h4>Talk to us</h4>
        {%- if section.settings.email != blank -%}<a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>{%- endif -%}
        {%- if section.settings.phone != blank -%}<a href="tel:+1{{ tel }}">{{ section.settings.phone }}</a>{%- endif -%}
        <p class="small">{{ section.settings.hours }}</p>
      </div>

      {%- if section.settings.show_badge -%}
        <div class="mtwft__badge">
          <g:ratingbadge merchant_id="370063513" position="INLINE"></g:ratingbadge>
        </div>
      {%- endif -%}

      <div class="mtwft__m-pay">
        <span class="mtwft__m-pay-label">We accept</span>
        <div class="mtwft__pay">
          <span class="mtwft__chip">Visa</span><span class="mtwft__chip">Mastercard</span><span class="mtwft__chip">Amex</span><span class="mtwft__chip">Apple&nbsp;Pay</span><span class="mtwft__chip">Shop&nbsp;Pay</span><span class="mtwft__chip">PayPal</span>
        </div>
      </div>

      <div class="mtwft__m-bottom">
        {%- if section.settings.bottom_tagline != blank -%}<em>{{ section.settings.bottom_tagline }}</em>{%- endif -%}
        <span class="mtwft__m-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
        <div class="mtwft__m-legal">
          <a href="/policies/privacy-policy">Privacy</a>
          <a href="/policies/terms-of-service">Terms</a>
          <a href="/pages/accessibility">Accessibility</a>
        </div>
      </div>
    </div>
  </footer>

</div>

{% schema %}
