<script src="image-slot.js"></script>
<script>
  /* =================================================================
     CATALOG VARS, single source of truth for ecosystem strings.
     To reskin for another ecosystem, edit ONLY this block.
     A Shopify template can override these via Liquid:
       const CATALOG = { volume: "04", ecosystem: "Small World & Storytelling", makers: ["Papoose", "Gus + Mabel", "Himalayan Felt Co.", "Tara Treasures"] };
     ================================================================= */
  const CATALOG = {
    volume:       "04",
    ecosystem:    "Small World &amp; Storytelling",
    "ecosystem-uc": "SMALL WORLD &amp; STORYTELLING"
  };

  // Ordered list of all 8 ecosystems. To reskin for another ecosystem,
  // change CATALOG.volume above and the subnav stepper auto-updates.
  const ECOSYSTEMS = [
    { vol: "01", slug: "sensory-play",  name: "Sensory Play" },
    { vol: "02", slug: "nature-play",   name: "Nature Play" },
    { vol: "03", slug: "woodland",      name: "Woodland" },
    { vol: "04", slug: "small-world",   name: "Small World & Storytelling" },
    { vol: "05", slug: "fairy-villages",name: "Fairy Villages" },
    { vol: "06", slug: "steam",         name: "STEAM" },
    { vol: "07", slug: "dramatic-play", name: "Dramatic Play" },
    { vol: "08", slug: "creative-arts", name: "Creative Arts" }
  ];

  // Populate the subnav stepper based on current volume.
  (function(){
    var i = ECOSYSTEMS.findIndex(function(e){ return e.vol === CATALOG.volume; });
    if (i === -1) return;
    var prevEl = document.querySelector('#ecosystemStepper .prev');
    var curEl  = document.querySelector('#ecosystemStepper .current');
    var nextEl = document.querySelector('#ecosystemStepper .next');
    if (curEl) curEl.textContent = CATALOG.volume + ' \u00b7 ' + CATALOG.ecosystem;
    if (i > 0 && prevEl) {
      var p = ECOSYSTEMS[i-1];
      prevEl.textContent = p.vol + ' \u00b7 ' + p.name;
      prevEl.href = '/pages/educator-' + p.slug;
    } else if (prevEl) {
      prevEl.style.display = 'none';
      var sep = prevEl.nextElementSibling;
      if (sep && sep.classList.contains('sep')) sep.style.display = 'none';
    }
    if (i < ECOSYSTEMS.length - 1 && nextEl) {
      var n = ECOSYSTEMS[i+1];
      nextEl.textContent = n.vol + ' \u00b7 ' + n.name;
      nextEl.href = '/pages/educator-' + n.slug;
    } else if (nextEl) {
      nextEl.style.display = 'none';
      var sep2 = nextEl.previousElementSibling;
      if (sep2 && sep2.classList.contains('sep')) sep2.style.display = 'none';
    }
  })();
  document.querySelectorAll('[data-fill]').forEach(function(el){
    var key = el.dataset.fill;
    if (CATALOG.hasOwnProperty(key)) el.textContent = CATALOG[key];
  });

  // Nav: solid background after scroll
  (function(){
    var nav = document.getElementById('nav');
    if(!nav) return;
    var onScroll = function(){
      if(window.scrollY > 60){ nav.classList.add('scrolled'); }
      else { nav.classList.remove('scrolled'); }
    };
    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  })();

  // Add-to-cart: increment the cart count badge in the nav.
  // For Shopify port: replace this with a real fetch to /cart/add.js and
  // re-render the cart count from {{ cart.item_count }} on response.
  (function(){
    var count = 0;
    var badge = document.getElementById('cartCount');
    var flash = null;
    function ensureFlash(){
      if (flash) return flash;
      flash = document.createElement('div');
      flash.className = 'cart-flash';
      document.body.appendChild(flash);
      return flash;
    }
    document.querySelectorAll('.add-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        count += 1;
        if (badge) badge.textContent = count;
        var sku = btn.getAttribute('data-sku') || 'item';
        var fl = ensureFlash();
        fl.innerHTML = '<span class="added">Added to cart.</span> <span>' + sku.replace(/-/g,' ') + '</span>';
        fl.classList.add('show');
        clearTimeout(window.__cartFlashT);
        window.__cartFlashT = setTimeout(function(){ fl.classList.remove('show'); }, 2400);
      });
    });
  })();

  // Rotating utility-bar announcement (3 messages, ~5s each).
  (function(){
    var slides = document.querySelectorAll('.utility-center .slide');
    if (slides.length < 2) return;
    var i = 0;
    setInterval(function(){
      slides[i].classList.remove('is-active');
      i = (i + 1) % slides.length;
      slides[i].classList.add('is-active');
    }, 5000);
  })();

  // Reviews carousel. Generic horizontal-scroll snap track with
  // arrow buttons and pagination dots. Number of dots equals the
  // number of "pages", page width = visible track width. We compute
  // page count from track scrollWidth / clientWidth so it adapts to
  // breakpoints automatically.
  (function(){
    document.querySelectorAll('[data-reviews-carousel]').forEach(function(carousel){
      var track = carousel.querySelector('.rc-track');
      var prev  = carousel.querySelector('.rc-nav.prev');
      var next  = carousel.querySelector('.rc-nav.next');
      var dotsHost = carousel.querySelector('.rc-dots');
      if (!track) return;

      function pageCount(){
        return Math.max(1, Math.ceil(track.scrollWidth / track.clientWidth));
      }
      function currentPage(){
        return Math.round(track.scrollLeft / track.clientWidth);
      }
      function buildDots(){
        if (!dotsHost) return;
        var count = pageCount();
        dotsHost.innerHTML = '';
        for (var i = 0; i < count; i++){
          var b = document.createElement('button');
          b.type = 'button';
          b.setAttribute('role', 'tab');
          b.setAttribute('aria-label', 'Go to reviews page ' + (i + 1));
          (function(idx){
            b.addEventListener('click', function(){
              track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
            });
          })(i);
          dotsHost.appendChild(b);
        }
        syncDots();
      }
      function syncDots(){
        if (!dotsHost) return;
        var p = currentPage();
        Array.prototype.forEach.call(dotsHost.children, function(d, i){
          d.classList.toggle('is-active', i === p);
        });
      }
      function syncNav(){
        if (prev) prev.disabled = track.scrollLeft <= 2;
        if (next) next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
      }
      function scrollByPage(dir){
        track.scrollBy({ left: dir * track.clientWidth, behavior: 'smooth' });
      }

      if (prev) prev.addEventListener('click', function(){ scrollByPage(-1); });
      if (next) next.addEventListener('click', function(){ scrollByPage(1); });
      track.addEventListener('scroll', function(){ syncDots(); syncNav(); }, { passive: true });
      window.addEventListener('resize', function(){ buildDots(); syncNav(); });

      buildDots();
      syncNav();
    });
  })();

  // Long-lead pill, auto-tags any element with data-long-lead="true" with a
  // "Ships separately" pill. Wire SKUs as they're added to the slow-ship list
  // by adding data-long-lead="true" to the .home / .kit / .split card.
  (function(){
    document.querySelectorAll('[data-long-lead="true"]').forEach(function(card){
      if (card.querySelector('.ships-separately-pill')) return;
      var pill = document.createElement('span');
      pill.className = 'ships-separately-pill';
      pill.textContent = 'Ships separately';
      var anchor = card.querySelector('.add-row, .add-btn, .price-line, .price');
      if (anchor) anchor.parentNode.insertBefore(pill, anchor);
      else card.appendChild(pill);
    });
  })();
</script>

</body>
</html>
{%- else -%}
{% render 'educator-gate' %}
{%- endif -%}
