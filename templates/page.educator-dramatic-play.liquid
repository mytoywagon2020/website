}
.companions .folk .folk-price{
  font-family: var(--serif);
  font-weight: 500;
  font-size: 18px;
  color: var(--cream);
  line-height: 1;
}
.companions .folk .folk-price small{
  font-family: var(--sans);
  font-style: normal;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 500;
  color: rgba(245,240,229,.55);
  margin-left: 6px;
}
.companions .folk .add-btn.icon{
  padding: 7px 10px;
  background: transparent;
  border: 1px solid rgba(245,240,229,.4);
