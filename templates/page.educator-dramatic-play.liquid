/* ============================== BOTTOM HERO ============================== */
.bottom-hero{
  position: relative;
  height: 80vh;
  min-height: 520px;
  max-height: 920px;
  overflow: hidden;
  display: flex;
  align-items: flex-end;
}
.bottom-hero .bg{ position: absolute; inset: 0; z-index: 0; }
.bottom-hero .veil{
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background: linear-gradient(to bottom, rgba(44,26,14,.02) 0%, rgba(44,26,14,.4) 65%, rgba(44,26,14,.85) 100%);
}
.bottom-hero .content{
  position: relative; z-index: 2;
  width: 100%;
  padding: 0 clamp(28px, 5vw, 80px) 80px;
  text-align: center;
}
.bottom-hero h3{
  margin: 0 auto;
  max-width: 22ch;
  font-family: var(--serif);
  font-weight: 400;
  font-style: italic;
  font-size: clamp(36px, 5vw, 80px);
  line-height: 1.1;
  letter-spacing: -.005em;
  color: var(--cream);
  text-shadow: 0 1px 28px rgba(0,0,0,.3);
}

/* ============================== CLOSING ============================== */
.closing{
  background:
    linear-gradient(180deg, var(--cream) 0%, var(--accent-pale) 60%, var(--accent-soft) 100%);
  color: var(--ink);
  position: relative;
  overflow: hidden;
}
.closing::before{
  content:""; position: absolute;
  top: 0; left: 50%; transform: translateX(-50%);
  width: 1px; height: 80px;
  background: var(--accent); opacity: .45;
}
.closing .wrap{ text-align: center; position: relative; z-index: 2; }
.closing .eyebrow{ color: var(--accent-deep); }
.closing h2{
  margin: 36px auto 0;
  max-width: 22ch;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(44px, 6.4vw, 104px);
  line-height: 1.02;
  letter-spacing: -.01em;
}
.closing h2 .it{ color: var(--accent-deep); }
.closing .price{
  margin: 56px auto 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  color: var(--ink-soft);
}
.closing .cta{ margin-top: 28px; }
.closing .signoff{
  margin-top: 100px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 24px;
  padding-top: 28px;
  border-top: 1px solid var(--rule-soft);
}
.closing .signoff .left,
.closing .signoff .right{
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: .1em;
  color: var(--ink-soft);
}
.closing .signoff .right{ text-align: right; }
.closing .signoff .center{
  font-family: var(--serif);
  font-style: italic;
  font-size: 15px;
  color: var(--ink-soft);
}

/* ============================== FOOTER ============================== */
footer{
  background: var(--ink);
