}
@media (max-width: 1080px){
  .outfit .head{ grid-template-columns: 1fr; gap: 32px; }
  .outfit .note{ flex-direction: column; align-items: flex-start; }
}

/* ----------------------- CONTAINER ----------------------- */
.wrap{ max-width: 1340px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 56px); }
.wrap-wide{ max-width: 1500px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 56px); }
.gut{   padding-top: clamp(56px, 8vw, 92px); padding-bottom: clamp(56px, 8vw, 92px); }
.gut-sm{ padding-top: clamp(40px, 5vw, 64px);  padding-bottom: clamp(40px, 5vw, 64px); }

/* ============================== COVER ============================== */
.cover{
  position: relative;
  height: min(100vh, 920px);
  min-height: 680px;
  overflow: hidden;
  isolation: isolate;
}
.cover .bg{ position:absolute; inset:0; z-index:0; }
.cover .veil{
  position:absolute; inset:0; z-index:1; pointer-events:none;
  background:
    linear-gradient(180deg, rgba(44,26,14,.04) 0%, rgba(44,26,14,0) 35%, rgba(44,26,14,0) 58%, rgba(44,26,14,.55) 100%),
    linear-gradient(180deg, rgba(159,79,97,.18) 0%, rgba(159,79,97,0) 50%);
}
.cover .frame{
  position:absolute; inset:28px; z-index:2; pointer-events:none;
  border: 1px solid rgba(250,246,237,.32);
}
.cover .head{
  position: absolute;
  top: 92px; left: clamp(28px, 5vw, 56px); right: clamp(28px, 5vw, 56px);
  z-index: 3;
  display: flex; justify-content: space-between; align-items: flex-start;
  color: var(--cream);
}
.cover .head .vol{ text-align:right; }
.cover .head .vol .num{
  font-family: var(--serif); font-style: italic;
  font-size: 38px; line-height: 1;
}
.cover h1{
  position:absolute;
  left: clamp(28px, 5vw, 56px);
  right: clamp(28px, 5vw, 56px);
  bottom: 220px;
  z-index: 3;
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  color: var(--cream);
  font-size: clamp(48px, 8vw, 132px);
  line-height: .94;
  letter-spacing: -.012em;
  text-shadow: 0 1px 28px rgba(0,0,0,.2);
}
.cover h1 .it{
  display: block;
  font-style: italic;
  color: color-mix(in oklab, var(--accent-soft) 80%, white);
}
.cover .footer{
  position:absolute;
  left: clamp(28px, 5vw, 56px);
  right: clamp(28px, 5vw, 56px);
  bottom: 48px;
  z-index: 3;
  color: var(--cream);
  display: flex; justify-content: space-between; align-items: flex-end; gap: 24px;
}
.cover .audience{ max-width: 540px; }
.cover .audience .label{ color: rgba(250,246,237,.7); }
.cover .audience p{
  margin-top: 8px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  line-height: 1.4;
  color: var(--cream);
}
.cover .scroll{
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: .14em;
  color: rgba(250,246,237,.85);
  text-align:right;
}
.cover .scroll .dot{
  display:inline-block; width:6px; height:6px; border-radius:50%;
  background: var(--cream); margin-left: 10px; vertical-align: middle;
  animation: pulse 2.4s ease-in-out infinite;
}
@keyframes pulse{ 0%,100%{ opacity:.35 } 50%{ opacity:1 } }

/* ============================== ANCHOR ============================== */
.anchor{
  background: var(--cream);
  border-top: 1px solid var(--rule-soft);
  border-bottom: 1px solid var(--rule-soft);
  position: relative;
}
.anchor .wrap{
  display: grid;
  grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
  gap: 80px;
  align-items: center;
}
.anchor .vol-numeral{
  position: absolute;
  right: clamp(20px, 5vw, 56px);
  top: -30px;
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent-soft);
  font-size: clamp(120px, 16vw, 220px);
  line-height: .8;
  pointer-events: none;
  user-select: none;
  z-index: 0;
}
.anchor h2{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(40px, 5.8vw, 96px);
  line-height: 1.02;
  letter-spacing: -.008em;
  position: relative; z-index: 1;
}
.anchor h2 .it{ color: var(--accent-deep); }
.anchor h2 .quote-open,
.anchor h2 .quote-close{
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent);
  font-size: 1.2em;
  line-height: 0;
  position: relative;
  top: .08em;
}
.anchor .side{
  display: flex; flex-direction: column; gap: 22px;
  border-left: 1px solid var(--rule-soft);
  padding-left: 44px;
}
.anchor .side .eyebrow{ color: var(--ink-soft); }
.anchor .side p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 21px;
  line-height: 1.5;
  color: var(--ink-soft);
}

/* ============================== EDITORIAL INTRO ============================== */
.intro{ background: var(--card-bg); }
.intro .wrap{
  display: grid;
  grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  gap: 72px;
  align-items: stretch;
}
.intro .col-img{ }
.intro .col-img .tile{ height: 100%; min-height: 420px; }
.intro .col-txt{
  display: flex; flex-direction: column; justify-content: center;
  padding: 12px 0;
}
.intro .col-txt .eyebrow{ color: var(--accent-deep); margin-bottom: 28px; }
.intro .col-txt h3{
  margin: 0 0 36px;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(32px, 3.8vw, 56px);
  line-height: 1.08;
  letter-spacing: -.004em;
}
.intro .col-txt h3 .it{ color: var(--accent-deep); }
.intro .body{
  font-size: 17.5px;
  line-height: 1.78;
  max-width: 56ch;
}
.intro .body p{ margin: 0 0 18px; }
.intro .body .dropcap{
  float: left;
  font-family: var(--serif);
  font-style: italic;
  font-size: 92px;
  line-height: .78;
  color: var(--accent);
  padding: 8px 14px 0 0;
}
.intro .body .triplet{
  font-family: var(--serif);
  font-style: italic;
  color: var(--ink);
  font-size: 19px;
  line-height: 1.55;
}
.intro .pillars{
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 44px;
  padding-top: 28px;
  border-top: 1px solid var(--rule-soft);
}
.intro .pillars .p .label{ color: var(--accent-deep); display:block; margin-bottom: 8px; }
.intro .pillars .p p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  line-height: 1.45;
  color: var(--ink-soft);
}

/* ============================== FEATURE STAGE ============================== */
.stage{
  position: relative;
  height: 64vh;
  min-height: 540px;
  max-height: 800px;
  color: var(--cream);
  overflow: hidden;
}
.stage .bg{ position: absolute; inset: 0; z-index: 0; }
.stage .veil{
  position: absolute; inset: 0; z-index: 1;
  background:
    linear-gradient(90deg, rgba(20,10,6,.55) 0%, rgba(20,10,6,0) 48%),
    linear-gradient(180deg, rgba(20,10,6,.16) 0%, rgba(20,10,6,0) 32%, rgba(20,10,6,.6) 100%);
}
.stage .content{
  position: relative; z-index: 2;
  height: 100%;
  padding: clamp(56px, 8vh, 100px) clamp(28px, 5vw, 80px);
  display: grid; grid-template-rows: auto 1fr auto; gap: 24px;
}
.stage .top{ display:flex; justify-content: space-between; align-items: flex-start; gap: 24px; }
.stage .top .eyebrow{ color: var(--accent-soft); }
.stage .top .right{ text-align: right; }
.stage .top .right .label{ color: rgba(250,246,237,.62); }
.stage .top .right .name{ font-family: var(--serif); font-style: italic; font-size: 17px; margin-top: 6px; }
.stage .mid{ align-self: end; max-width: 980px; }
.stage h2{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(56px, 7.6vw, 128px);
  line-height: .94;
  letter-spacing: -.012em;
}
.stage h2 .it{
  display: block;
  font-style: italic;
  color: color-mix(in oklab, var(--accent-soft) 85%, white);
}
.stage .lede{
  margin: 28px 0 0;
  max-width: 640px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  line-height: 1.5;
  color: rgba(250,246,237,.88);
}
.stage .bot{ display: flex; align-items: flex-end; justify-content: flex-start; }

/* ----------- Button ----------- */
.btn{
  display:inline-flex; align-items:center; gap:14px;
  font-family: var(--sans);
  font-weight: 600;
  font-size: 12.5px;
  letter-spacing: .18em;
  text-transform: uppercase;
  background: var(--cream);
  color: var(--ink);
  border: 1px solid var(--cream);
  border-radius: 2px;
  padding: 16px 28px;
  text-decoration: none;
  transition: background .25s ease, color .25s ease, border-color .25s ease;
}
.btn:hover{ background: var(--accent); border-color: var(--accent); color: var(--cream); }
.btn .arrow{
  display:inline-block; width: 22px; height: 1px; background: currentColor; position: relative;
}
.btn .arrow::after{
  content:""; position: absolute; right: 0; top: -3px;
  width: 7px; height: 7px;
  border-top: 1px solid currentColor; border-right: 1px solid currentColor; transform: rotate(45deg);
}
.btn.ink{ background: var(--ink); color: var(--cream); border-color: var(--ink); }
.btn.ink:hover{ background: var(--accent-deep); border-color: var(--accent-deep); color: var(--cream); }
.btn.ghost{ background: transparent; color: var(--cream); border-color: rgba(250,246,237,.5); }
.btn.ghost:hover{ background: var(--cream); color: var(--ink); border-color: var(--cream); }

/* ============================== FEATURE SPLIT (CONTENTS) ============================== */
.split{
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: var(--accent-pale);
  min-height: 72vh;
}
.split .img-side{ position: relative; min-height: 480px; }
.split .img-side .tile{ position: absolute; inset: 0; }
.split .img-side::after{
  content:""; position:absolute; inset:0; pointer-events:none;
  background: linear-gradient(to right, transparent 60%, color-mix(in oklab, var(--accent) 25%, transparent));
}
.split .content{
  padding: clamp(56px, 8vw, 120px) clamp(36px, 6vw, 96px);
  display: flex; flex-direction: column; justify-content: center;
  position: relative;
}
.split .content::before{
  content:""; position:absolute; top: 44px; right: 44px;
  width: 48px; height: 48px;
  border-top: 1px solid var(--gilt); border-right: 1px solid var(--gilt);
  opacity: .55;
}
.split .content .eyebrow{ color: var(--accent-deep); margin-bottom: 24px; }
.split .content h3{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(30px, 3.6vw, 52px);
  line-height: 1.1;
  letter-spacing: -.005em;
}
.split .content .sub{
  margin-top: 6px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  color: var(--accent-deep);
}
.split .content .hair{
  width: 56px; height: 1px; background: var(--accent);
  opacity: .5; margin: 32px 0;
}
.split .content .desc{
  font-family: var(--serif);
  font-size: clamp(17px, 1.4vw, 19px);
  line-height: 1.78;
  color: var(--ink-soft);
  max-width: 56ch;
}
.split .content .contents-list{
  list-style: none; padding: 0; margin: 28px 0 0;
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px 28px;
}
.split .content .contents-list li{
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  line-height: 1.5;
  color: var(--ink);
  padding-left: 20px;
  position: relative;
}
.split .content .contents-list li::before{
  content: ""; position: absolute; left: 0; top: 12px;
  width: 10px; height: 1px; background: var(--accent);
}
.split .content .craft{
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  margin-top: 36px;
  padding-top: 28px;
  border-top: 1px solid rgba(159,79,97,.22);
}
.split .content .craft .label{ color: var(--muted); display:block; margin-bottom: 8px; font-size: 10.5px; }
.split .content .craft .v{
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  line-height: 1.45;
  color: var(--ink);
}
.split .content .craft .v.plain{ font-family: var(--sans); font-style: normal; font-size: 13px; color: var(--ink-soft); line-height: 1.55; }
.split .content .testimony{
  margin-top: 36px;
  padding-top: 28px;
  border-top: 1px solid rgba(159,79,97,.22);
}
.split .content .testimony .quote{
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(19px, 1.6vw, 22px);
  line-height: 1.5;
  color: var(--ink);
  max-width: 56ch;
}
.split .content .testimony .attr{
  margin-top: 18px;
  display: flex; align-items: center; gap: 14px;
}
.split .content .testimony .attr .dash{ display:inline-block; width: 36px; height: 1px; background: var(--accent); }
.split .content .testimony .attr .name{
  font-family: var(--sans);
  font-size: 11.5px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-soft);
}
.split .content .testimony .attr .name b{ color: var(--ink); font-weight: 700; }
.split .content .ctas{ margin-top: 40px; display: flex; flex-wrap: wrap; gap: 16px 22px; align-items: center; }
.split .content .ctas .price{
  font-family: var(--serif);
  font-style: italic;
  font-size: 16px;
  color: var(--ink-soft);
}
.split .content .ctas .btn{ background: var(--ink); color: var(--cream); border-color: var(--ink); }
.split .content .ctas .btn:hover{ background: var(--accent-deep); border-color: var(--accent-deep); }

/* Pairs with, cross-sell block inside Feature Split */
.pairs-with{
  margin-top: 28px;
  padding-top: 22px;
  border-top: 0.5px solid var(--rule);
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px 18px;
  align-items: center;
}
.pairs-with .label{
  grid-column: 1 / -1;
  font-family: var(--sans);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--accent-deep);
  margin-bottom: 4px;
}
.pairs-with .pair-thumb{
  width: 88px; height: 88px;
  background: var(--accent-pale);
  border-radius: 2px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pairs-with .pair-thumb img{ width: 100%; height: 100%; object-fit: contain; padding: 6px; }
.pairs-with .pair-body{ display: flex; flex-direction: column; gap: 4px; }
.pairs-with .pair-body h4{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 19px;
  line-height: 1.25;
  letter-spacing: -.005em;
  color: var(--ink);
}
.pairs-with .pair-body p{
  margin: 0;
  font-family: var(--sans);
  font-size: 13.5px;
  line-height: 1.5;
