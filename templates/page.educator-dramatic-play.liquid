}
.klaviyo-form-submit button{
  font-family: var(--sans);
  font-weight: 600;
  font-size: 12px;
  letter-spacing: .14em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--cream);
  border: 1px solid var(--ink);
  border-radius: 2px;
  padding: 13px 24px;
  cursor: pointer;
  transition: background .2s ease, border-color .2s ease;
