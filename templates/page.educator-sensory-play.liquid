  text-transform: uppercase;
}
.bom-foot .label{ color: var(--stone); }
.bom-foot .v{ color: var(--ink); font-weight: 600; }

/* ----------------------- B2B PRICE BLOCK (gallery cards + general) ----------------------- */
.price-block{
  display: inline-flex;
  align-items: baseline;
  gap: 10px;
  margin-top: 6px;
}

/* ----------------------- ADD TO WAGON (per product card) ----------------------- */
.price{
  display: flex;
  align-items: baseline;
  gap: 10px;
  font-family: var(--serif);
  font-weight: 500;
  font-size: 24px;
  line-height: 1;
