}
.quote-form .col-intro h2{
  margin: 18px 0 24px;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(36px, 4.6vw, 64px);
  line-height: 1.02;
  letter-spacing: -.008em;
}
.quote-form .col-intro h2 .it{ color: var(--accent-deep); }
.quote-form .col-intro p{
  margin: 0 0 18px;
  font-family: var(--serif);
  font-size: 17px;
  line-height: 1.6;
  color: var(--ink-soft);
  max-width: 42ch;
}
.quote-form .col-intro .promise{
  margin-top: 28px;
