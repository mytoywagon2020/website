    document.querySelectorAll('.add-btn[data-sku]').forEach(function(ab){
      var sku = ab.getAttribute('data-sku'); var p = PDP[sku]; if(!p) return;
      if(!ab.getAttribute('data-variant-id')) ab.setAttribute('data-variant-id', p.v);
      var d = cardData(ab); var tw = d.card ? d.card.querySelector('.tile-wrap') : null;
      var href='/pages/educator-product?sku='+encodeURIComponent(sku);
      if(tw){
        var link=tw.querySelector('.card-pdp-link');
        if(!link){ link=document.createElement('a'); link.className='card-pdp-link'; tw.insertBefore(link,tw.firstChild); }
        link.href=href; link.setAttribute('aria-label',(d.nm||'View full details'));
        if(p.s && !tw.querySelector('.quick-view')){ var qv=document.createElement('div'); qv.className='quick-view'; qv.innerHTML='<div class="qv-head">'+esc(d.nm)+'</div><div class="qv-body"><p>'+esc(p.s)+'</p></div>'; tw.appendChild(qv); }
      }
      var vp=d.card?d.card.querySelector('.view-pdp'):null;if(vp){vp.href=href;}
      var row=ab.closest('.add-row'); if(row){ var vp2=row.querySelector('.view-pdp'); if(!vp2){ vp2=document.createElement('a'); vp2.className='view-pdp'; row.appendChild(vp2); } vp2.href=href; vp2.textContent='View full details →'; }
    });
    function sync(items){
      items=items||(window.MTWWagon?MTWWagon.items():[]);
      var byVar={};items.forEach(function(it){byVar[String(it.variantId)]=it.qty;});
      document.querySelectorAll('.add-btn[data-variant-id]').forEach(function(b){
        var lbl=b.querySelector('.lbl');
        if(!lbl){lbl=document.createElement('span');lbl.className='lbl';var t='';Array.prototype.slice.call(b.childNodes).forEach(function(nd){if(nd.nodeType===3){t+=nd.textContent;b.removeChild(nd);}});lbl.textContent=(t.replace(/\s+/g,' ').trim()||'Add to wagon');b.setAttribute('data-lbl0',lbl.textContent);b.appendChild(lbl);}
        var q=byVar[String(b.getAttribute('data-variant-id'))]||0;
        if(q>0){b.classList.add('has-qty');lbl.textContent='✓ In wagon';}else{b.classList.remove('has-qty');lbl.textContent=b.getAttribute('data-lbl0')||'Add to wagon';}
      });
    }
    document.querySelectorAll('.add-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        var sku = btn.getAttribute('data-sku') || 'item';
        var vid = btn.getAttribute('data-variant-id');
        var fl = ensureFlash();
        var show = function(html){
          fl.innerHTML = html;
          fl.classList.add('show');
          clearTimeout(window.__cartFlashT);
          window.__cartFlashT = setTimeout(function(){ fl.classList.remove('show'); }, 2600);
        };
        if(!vid){ show('<span class="added">Coming soon.</span> <span>' + sku.replace(/-/g,' ') + '</span>'); return; }
        if(!window.MTWWagon){ show('<span class="added">Wagon unavailable.</span> <span>Please refresh.</span>'); return; }
        var d = cardData(btn);
        MTWWagon.add({variantId:vid,sku:sku,title:(d.nm||sku.replace(/-/g,' ')),price:d.pr||'',img:d.img||'',qty:1});
        show('<span class="added">Added to your wagon!</span> <span>' + (d.nm||sku.replace(/-/g,' ')) + '</span>');
      });
    });
    if(window.MTWWagon){MTWWagon.subscribe(sync);}else{sync([]);}
  })();

  // Rotating utility-bar announcement (3 messages, ~5s each).
  (function(){
    var slides = document.querySelectorAll('.utility-center .slide');
    if (slides.length < 2) return;
    var i = 0;
    setInterval(function(){
      slides[i].classList.remove('is-active');
      i = (i + 1) % slides.length;
      slides[i].classList.add('is-active');
    }, 5000);
  })();

  // Reviews carousel. Generic horizontal-scroll snap track with
  // arrow buttons and pagination dots. Number of dots equals the
  // number of "pages", page width = visible track width. We compute
  // page count from track scrollWidth / clientWidth so it adapts to
  // breakpoints automatically.
  (function(){
    document.querySelectorAll('[data-reviews-carousel]').forEach(function(carousel){
      var track = carousel.querySelector('.rc-track');
      var prev  = carousel.querySelector('.rc-nav.prev');
      var next  = carousel.querySelector('.rc-nav.next');
      var dotsHost = carousel.querySelector('.rc-dots');
      if (!track) return;

      function pageCount(){
        return Math.max(1, Math.ceil(track.scrollWidth / track.clientWidth));
      }
      function currentPage(){
        return Math.round(track.scrollLeft / track.clientWidth);
      }
      function buildDots(){
        if (!dotsHost) return;
        var count = pageCount();
        dotsHost.innerHTML = '';
        for (var i = 0; i < count; i++){
          var b = document.createElement('button');
          b.type = 'button';
          b.setAttribute('role', 'tab');
          b.setAttribute('aria-label', 'Go to reviews page ' + (i + 1));
          (function(idx){
            b.addEventListener('click', function(){
              track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
            });
          })(i);
          dotsHost.appendChild(b);
        }
        syncDots();
      }
      function syncDots(){
        if (!dotsHost) return;
        var p = currentPage();
        Array.prototype.forEach.call(dotsHost.children, function(d, i){
          d.classList.toggle('is-active', i === p);
        });
      }
      function syncNav(){
        if (prev) prev.disabled = track.scrollLeft <= 2;
        if (next) next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
      }
      function scrollByPage(dir){
        track.scrollBy({ left: dir * track.clientWidth, behavior: 'smooth' });
      }

      if (prev) prev.addEventListener('click', function(){ scrollByPage(-1); });
      if (next) next.addEventListener('click', function(){ scrollByPage(1); });
      track.addEventListener('scroll', function(){ syncDots(); syncNav(); }, { passive: true });
      window.addEventListener('resize', function(){ buildDots(); syncNav(); });

      buildDots();
      syncNav();
    });
  })();

  // Long-lead pill, auto-tags any element with data-long-lead="true" with a
  // "Ships separately" pill. Wire SKUs as they're added to the slow-ship list
  // by adding data-long-lead="true" to the .home / .kit / .split card.
  (function(){
    document.querySelectorAll('[data-long-lead="true"]').forEach(function(card){
      if (card.querySelector('.ships-separately-pill')) return;
      var pill = document.createElement('span');
      pill.className = 'ships-separately-pill';
      pill.textContent = 'Ships separately';
      var anchor = card.querySelector('.add-row, .add-btn, .price-line, .price');
      if (anchor) anchor.parentNode.insertBefore(pill, anchor);
      else card.appendChild(pill);
    });
  })();
</script>

