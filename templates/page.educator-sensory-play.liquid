  .qf-chip-stat{ font-size: 10.5px; padding: 6px 16px; flex-shrink: 0; }
}

/* ----------------------- BOM (kit bill-of-materials) ----------------------- */
.bom{
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 0 0 24px;
  border-top: 0.5px solid var(--rule);
}
.bom-row{
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 8px 16px;
  align-items: baseline;
  padding: 12px 0;
  border-bottom: 0.5px solid var(--rule);
}
.bom-item{
  font-family: var(--serif);
  font-size: 16px;
  line-height: 1.35;
  color: var(--ink);
}
.bom-item .sku-tba{
  display: inline-block;
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--stone);
  background: var(--warm-white);
  border: 0.5px dashed var(--rule-strong);
  padding: 2px 6px;
  margin-right: 8px;
  vertical-align: 2px;
}
.bom-meta{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .04em;
  color: var(--stone);
  text-align: right;
  white-space: nowrap;
}
.bom-foot{
  display: flex; align-items: baseline; justify-content: space-between;
