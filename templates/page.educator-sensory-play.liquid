<style>
/* =================================================================
   MY TOY WAGON, ECOSYSTEM CATALOG TEMPLATE
   Current preset: SENSORY PLAY (Section 01)
   To retheme for another ecosystem, swap the ECOSYSTEM TOKENS block
   below + the CATALOG const at the bottom. Every component downstream
   reads from tokens.
   ================================================================= */

/* ----------------------------- TOKENS ---------------------------- */
:root{
  /* BRAND CHASSIS, shared with retail homepage. Do not vary. */
  --cream:        #F5F0E5;   /* brand cream, neutral-warm */
  --warm-white:   #FFFCF7;   /* card surface over cream */
  --card-bg:      #EDE3CD;   /* warm beige card surface */
  --ink:          #2C2C2A;   /* brand ink, neutral warm grey */
  --ink-soft:     #44423E;   /* softer ink for body */
  --stone:        #5F5E5A;   /* muted brand grey */
  --muted:        #5F5E5A;   /* alias for back-compat */
  --forest:       #3B6D11;   /* brand primary accent (verified, micro) */
  --amber:        #854F0B;   /* brand secondary accent (wagon badge) */
  --gilt:         #C9A96E;
  --gilt-pale:    #E8D5A8;

  /* ECOSYSTEM PALETTE, swap these per ecosystem. Carries mood. */
  --accent:       #3D7A6A;   /* teal-green, primary signature */
  --accent-soft:  #8FB5A9;   /* sage-mint soft */
  --accent-pale:  #DCE9E3;   /* pale mint, background tint */
  --accent-deep:  #285644;   /* deep teal-forest, type emphasis */
  --alt:          #C9A86E;   /* warm sand, secondary (maple/tray tones) */
  --alt-deep:     #8B7340;   /* deep wheat */
  --hue-3:        #9FB8D4;   /* soft sky blue, tertiary (rice/sensory) */
  --hue-3-deep:   #5E7894;   /* slate blue */

  /* mood gradient, ecosystem signature, used on cover + bottom hero */
  --mood-a:       #8FB5A9;   /* sage start */
  --mood-b:       #3D7A6A;   /* teal */
  --mood-c:       #285644;   /* deep teal */
  --mood-d:       #C9A86E;   /* warm sand */
  --mood-e:       #9FB8D4;   /* sky blue end */

  /* meta strings (referenced via ::before content where needed) */
  --rule:         rgba(44,44,42,.12);   /* brand hairline */
  --rule-soft:    rgba(44,44,42,.06);
  --rule-strong:  rgba(44,44,42,.22);   /* visible divider */

  /* type */
  --serif:        "Cormorant Garamond", "Garamond", Georgia, serif;
  --sans:         "Mulish", "Helvetica Neue", system-ui, sans-serif;
  --mono:         "Mulish", "Helvetica Neue", system-ui, sans-serif;
}

/* ----------------------------- BASE ------------------------------ */
*, *::before, *::after{ box-sizing:border-box; margin:0; padding:0; }
html{ scroll-behavior:smooth; }
body{
  background: var(--cream);
  color: var(--ink);
  font-family: var(--sans);
  font-weight: 400;
  font-size: 17px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  overflow-x: hidden;
  text-wrap: pretty;
}
img{ display:block; max-width:100%; }
a{ color:inherit; }
::selection{ background: var(--accent); color: var(--cream); }

.serif{ font-family: var(--serif); }
.it{ font-style: italic; }
.eyebrow{
  font-family: var(--sans);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: .22em;
  text-transform: uppercase;
}
.label{
  font-family: var(--sans);
  font-weight: 500;
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
}
.meta{
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: .06em;
}
.rule-hair{ display:block; width:100%; height:1px; background: var(--rule-soft); border:0; }
.rule{ display:block; width:100%; height:1px; background: var(--rule); border:0; }

/* ----------------------- IMAGE-SLOT SYSTEM ----------------------- */
/* Tiles fill in for photography. Each tile is a tinted, softly-
   textured surface with a monospace corner tag that briefs the
   photographer on what should go here. Role-based tones (.t-primary,
   .t-soft, .t-pale, .t-deep, .t-alt, .t-alt-deep, .t-cream, .t-ink,
   .t-mood) so that a token-swap reskins every tile at once. */
.tile{
  position: relative;
  overflow: hidden;
  isolation: isolate;
  background: var(--accent-pale);
}
.tile::before{
  content:"";
  position: absolute; inset:0;
  background:
    radial-gradient(120% 80% at 20% 18%, rgba(255,255,255,.35), rgba(255,255,255,0) 60%),
    radial-gradient(120% 80% at 85% 90%, rgba(44,26,14,.18), rgba(44,26,14,0) 55%),
    repeating-linear-gradient(135deg, rgba(255,255,255,.06) 0 1px, rgba(255,255,255,0) 1px 14px),
    repeating-linear-gradient(45deg, rgba(44,26,14,.04) 0 1px, rgba(44,26,14,0) 1px 22px);
  pointer-events: none; z-index:1;
}
.tile::after{
  content:"";
  position: absolute; inset:0;
  background: radial-gradient(58% 48% at 50% 50%, rgba(255,255,255,0) 60%, rgba(44,26,14,.10) 100%);
  pointer-events: none; z-index:1;
}
.tile .tag{
  position:absolute; left:14px; top:14px;
  z-index:3;
  font-family: var(--mono);
  font-size:10px;
  letter-spacing:.04em;
  line-height: 1.45;
  color: rgba(44,26,14,.78);
  background: rgba(250,246,237,.82);
  border: 1px solid rgba(44,26,14,.15);
  padding: 6px 10px;
  max-width: calc(100% - 28px);
  backdrop-filter: blur(1px) saturate(120%);
}
.tile .tag.dark{
  color: rgba(250,246,237,.92);
  background: rgba(44,26,14,.45);
  border-color: rgba(250,246,237,.22);
}
.tile .corner{
  position:absolute; width:14px; height:14px;
  border: 1px solid rgba(44,26,14,.4);
  z-index:2;
}
.tile.dark .corner{ border-color: rgba(250,246,237,.55); }
.tile .corner.tl{ top:0; left:0;  border-right:0; border-bottom:0; }
.tile .corner.tr{ top:0; right:0; border-left:0;  border-bottom:0; }
.tile .corner.bl{ bottom:0; left:0;  border-right:0; border-top:0; }
.tile .corner.br{ bottom:0; right:0; border-left:0;  border-top:0; }

/* Role-based tones (token-driven, swap once and the page reskins) */
.t-primary  { background: linear-gradient(160deg, var(--accent-soft) 0%, var(--accent) 60%, var(--accent-deep) 100%); }
.t-soft     { background: linear-gradient(160deg, color-mix(in oklab, var(--accent-soft) 70%, white) 0%, var(--accent-soft) 60%, var(--accent) 100%); }
.t-pale     { background: linear-gradient(155deg, color-mix(in oklab, var(--accent-pale) 80%, white) 0%, var(--accent-pale) 60%, var(--accent-soft) 100%); }
.t-deep     { background: linear-gradient(170deg, var(--accent) 0%, var(--accent-deep) 70%, color-mix(in oklab, var(--accent-deep) 60%, #000) 100%); }
.t-alt      { background: linear-gradient(155deg, color-mix(in oklab, var(--alt) 80%, white) 0%, var(--alt) 55%, var(--alt-deep) 100%); }
.t-alt-deep { background: linear-gradient(180deg, var(--alt) 0%, var(--alt-deep) 65%, color-mix(in oklab, var(--alt-deep) 50%, #000) 100%); }
.t-cream    { background: linear-gradient(155deg, var(--cream) 0%, var(--card-bg) 60%, var(--gilt-pale) 100%); }
.t-ink      { background: linear-gradient(170deg, #44423E 0%, var(--ink) 60%, #1A1A18 100%); }
.t-hue3     { background: linear-gradient(160deg, color-mix(in oklab, var(--hue-3) 75%, white) 0%, var(--hue-3) 55%, var(--hue-3-deep) 100%); }
.t-hue3-deep{ background: linear-gradient(170deg, var(--hue-3) 0%, var(--hue-3-deep) 65%, color-mix(in oklab, var(--hue-3-deep) 50%, #000) 100%); }
.t-gilt     { background: linear-gradient(155deg, var(--gilt-pale) 0%, var(--gilt) 60%, color-mix(in oklab, var(--gilt) 50%, #000) 100%); }
.t-mood     {
  background:
    radial-gradient(60% 90% at 50% 100%, rgba(255,255,255,0) 30%, rgba(255,255,255,.16) 60%, rgba(255,255,255,0) 82%),
    linear-gradient(170deg,
      var(--mood-a) 0%,
      var(--mood-b) 28%,
      var(--mood-c) 52%,
      var(--mood-d) 78%,
      var(--mood-e) 100%);
}

/* ----------------------- NAV (sticky, brand-styled, retail pattern) ----------------------- */
.nav{
  position: sticky;
  top: 0;
  z-index: 50;
  padding: 18px clamp(20px, 4vw, 44px);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 32px;
  background: var(--cream);
  border-bottom: 0.5px solid var(--rule);
  transition: background .25s ease, padding .25s ease;
}
.nav.scrolled{
  background: rgba(245,240,229,.96);
  backdrop-filter: saturate(140%) blur(8px);
  padding-top: 12px;
  padding-bottom: 12px;
}
.nav__search{
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 13px 22px;
  background: var(--warm-white);
  border: 0.5px solid var(--rule-strong);
  border-radius: 999px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 14.5px;
  color: var(--stone);
  cursor: text;
  width: 100%;
  max-width: 380px;
  transition: border-color .2s ease, box-shadow .2s ease;
}
.nav__search:hover{ border-color: var(--ink); box-shadow: 0 1px 12px rgba(44,44,42,.06); }
.nav__search svg{ width: 16px; height: 16px; stroke: var(--ink); stroke-width: 1.6; fill: none; flex-shrink: 0; }
.nav__logo{
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  color: var(--ink);
  line-height: 1;
  justify-self: center;
}
.nav__logo .mark{
  height: 78px;
  width: auto;
  display: block;
  object-fit: contain;
  flex-shrink: 0;
  transition: height .25s ease;
}
.nav.scrolled .nav__logo .mark{ height: 54px; }
.nav__logo .text{ display: none; }
.nav__actions{
  justify-self: end;
  display: inline-flex;
  align-items: center;
  gap: 24px;
}
.nav__action{
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 13px;
  letter-spacing: .02em;
  color: var(--ink);
  text-decoration: none;
  padding: 4px 0;
  transition: color .2s ease;
}
.nav__action:hover{ color: var(--forest); }
.nav__action svg{ width: 17px; height: 17px; stroke: currentColor; stroke-width: 1.4; fill: none; flex-shrink: 0; }
.nav__action .pill{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 18px; height: 18px;
  padding: 0 5px;
  background: var(--forest);
  color: var(--cream);
  border-radius: 9px;
  font-size: 10.5px;
  font-weight: 600;
  letter-spacing: 0;
}

/* ----------------------- PROMO STRIP (editorial breadcrumb) ----------------------- */
.promo-strip{
  background: var(--card-bg);
  border-bottom: 0.5px solid var(--rule);
  text-align: center;
  padding: 12px clamp(16px, 4vw, 40px);
  font-family: var(--sans);
  font-style: normal;
  font-size: 13px;
  letter-spacing: .02em;
  color: var(--ink-soft);
  line-height: 1.5;
}
.promo-strip .vol{ color: var(--accent-deep); font-weight: 600; }
.promo-strip .sep{ display: inline-block; width: 3px; height: 3px; border-radius: 50%; background: var(--rule-strong); vertical-align: middle; margin: 0 14px; }
.promo-strip strong{ color: var(--ink); font-weight: 600; font-style: normal; font-family: var(--sans); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; margin-right: 8px; }

/* ----------------------- SUBNAV (slim ecosystem stepper + in-page jumps) ----------------------- */
.subnav{
  background: var(--cream);
  border-bottom: 0.5px solid var(--rule);
  padding: 14px clamp(20px, 4vw, 44px);
}
.subnav-inner{
  max-width: 1440px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 24px;
  font-family: var(--sans);
  font-size: 12px;
  letter-spacing: .04em;
}
.subnav .back{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  color: var(--ink);
  text-decoration: none;
  font-weight: 500;
  transition: color .2s ease;
}
.subnav .back:hover{ color: var(--forest); }
.subnav .back::before{
  content: "";
  display: inline-block;
  width: 7px; height: 7px;
  border-top: 1px solid currentColor;
  border-left: 1px solid currentColor;
  transform: rotate(-45deg);
}
.subnav .stepper{
  display: inline-flex; align-items: center; gap: 18px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px;
  color: var(--ink);
}
.subnav .stepper a{
  color: var(--stone);
  text-decoration: none;
  transition: color .2s ease;
}
.subnav .stepper a:hover{ color: var(--ink); }
.subnav .stepper .current{
  color: var(--accent-deep);
  font-weight: 500;
}
.subnav .stepper .sep{ color: var(--rule-strong); font-style: normal; }
.subnav .jumps{
  display: inline-flex; align-items: center; gap: 22px;
  justify-content: flex-end;
}
.subnav .jumps a{
  color: var(--ink-soft);
  text-decoration: none;
  font-weight: 500;
  transition: color .2s ease;
}
.subnav .jumps a:hover{ color: var(--forest); }

@media (max-width: 1080px){
  .nav{ grid-template-columns: auto 1fr auto; gap: 16px; padding: 14px 20px; }
  .nav__search{ display: none; }
  .nav__logo{ justify-self: start; }
  .nav__action .label{ display: none; }
  .subnav-inner{ grid-template-columns: 1fr; gap: 14px; }
  .subnav .jumps{ display: none; }
  .subnav .stepper{ overflow-x: auto; scrollbar-width: none; white-space: nowrap; flex-wrap: nowrap; }
  .subnav .stepper::-webkit-scrollbar{ display: none; }
}

/* ----------------------- BRAND BARS + DNA ----------------------- */
.utility{
  background: var(--ink);
  color: var(--cream);
  font-size: 12px;
  letter-spacing: .06em;
}
.utility-inner{
  max-width: 1440px;
  margin: 0 auto;
  padding: 11px clamp(20px, 5vw, 44px);
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 24px;
}
.utility-left{ color: rgba(245,240,229,.75); display: flex; align-items: center; gap: 20px; }
.utility-left a{ color: inherit; text-decoration: none; transition: color .2s ease; }
.utility-left a:hover{ color: var(--cream); }
.utility-left .phone{ display: inline-flex; align-items: center; gap: 8px; }
.utility-left .phone svg{ width: 12px; height: 12px; stroke: currentColor; stroke-width: 1.4; fill: none; }
.utility-center{
  text-align: center;
  font-family: var(--sans);
  font-style: normal;
  font-weight: 500;
  font-size: 12.5px;
  letter-spacing: .04em;
  color: var(--cream);
  line-height: 1.5;
  position: relative;
  min-height: 1.5em;
}
.utility-center .slide{
  display: block;
  opacity: 0;
  position: absolute;
  inset: 0;
  transition: opacity .5s ease;
  pointer-events: none;
}
.utility-center .slide.is-active{
  opacity: 1;
  position: relative;
  pointer-events: auto;
}
.utility-center em{ color: color-mix(in oklab, var(--accent-soft) 80%, white); font-style: normal; font-weight: 600; }
.utility-right{
  color: rgba(245,240,229,.75);
  display: flex; align-items: center; justify-content: flex-end; gap: 20px;
}
.utility-right a{ color: inherit; text-decoration: none; transition: color .2s ease; }
.utility-right a:hover{ color: var(--cream); }
.utility-right .pipe{ color: rgba(245,240,229,.25); }

/* Inverse soft strip, mirrors the homepage's "For educators" strip */
.families-soft{
  background: var(--cream);
  border-bottom: 0.5px solid var(--rule);
}
.families-soft-inner{
  max-width: 1340px;
  margin: 0 auto;
  padding: 22px clamp(20px, 5vw, 56px);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  flex-wrap: wrap;
}
.families-soft-text{
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  color: var(--ink);
  line-height: 1.4;
  max-width: 640px;
}
.families-soft-text strong{
  display: block;
  font-style: normal;
  font-weight: 500;
  font-family: var(--sans);
  font-size: 10.5px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 4px;
}
.families-soft-cta{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--sans);
  font-size: 12px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 500;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 0.5px solid var(--rule-strong);
  padding-bottom: 4px;
  flex-shrink: 0;
  transition: color .2s ease, border-color .2s ease;
}
.families-soft-cta:hover{ color: var(--forest); border-color: var(--forest); }

/* Wagon badge, the brand's amber rotated pill */
.wagon-badge{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 7px 14px;
  background: var(--amber);
  color: var(--cream);
  font-family: var(--serif);
  font-style: italic;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: .04em;
  border-radius: 2px;
  border: 0.5px dashed rgba(245,240,229,.55);
  box-shadow: 0 2px 6px rgba(44,44,42,.18);
  white-space: nowrap;
  transform: rotate(-3deg);
}
.wagon-badge.flat{ transform: none; }

/* Numbered block-num (brand pattern: "01 / The Anchor") */
.block-num{
  font-family: var(--serif);
  font-style: italic;
  font-size: 15px;
  color: var(--stone);
  letter-spacing: 0;
  margin: 0 0 14px;
  display: block;
}
.block-num .dot{ color: var(--accent); }

/* Verified buyer disc, forest green, brand micro-DNA */
.verified-disc{
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--sans);
  font-size: 10.5px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--forest);
}
.verified-disc svg{ width: 12px; height: 12px; flex-shrink: 0; }

/* Image fill, drop real photos into placeholder tiles.
   `.has-photo` hides the gradient texture and corner brackets.
   `cover` mode (default): photo fills the tile, cropped to fit.
   `contained` mode: photo sits inside the tile on its tinted gradient
   backdrop, never stretched edge-to-edge. Use this for product portraits
   from a catalog studio shoot, not lifestyle photography. */
.tile.has-photo::before,
.tile.has-photo::after{ display: none; }
.tile.has-photo > .tag,
.tile.has-photo > .corner{ display: none; }
.tile.has-photo > img{
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  z-index: 0;
}
.tile.has-photo.contained > img{
  object-fit: contain;
  padding: 8% 10%;
  z-index: 2;
  filter: drop-shadow(0 18px 36px rgba(44,44,42,.18));
}
.tile.has-photo .credit{
  position: absolute;
  right: 12px; bottom: 12px;
  z-index: 3;
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .08em;
  color: rgba(44,44,42,.55);
  background: rgba(245,240,229,.78);
  padding: 4px 7px;
  border: 0.5px solid rgba(44,44,42,.15);
  text-transform: uppercase;
}
.tile.dark.has-photo .credit{
  color: rgba(245,240,229,.85);
  background: rgba(44,44,42,.45);
  border-color: rgba(245,240,229,.2);
}

/* ----------------------- QUICK FACTS (thin, scannable, above-fold) ----------------------- */
.quick-facts{
  background: var(--cream);
  border-bottom: 0.5px solid var(--rule);
  border-top: 0.5px solid var(--rule);
}
.quick-facts-inner{
  max-width: 1340px;
  margin: 0 auto;
  padding: 14px clamp(16px, 4vw, 56px);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
}
.qf-chip-stat{
  font-family: var(--sans);
  font-weight: 500;
  font-size: 11.5px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink);
  padding: 6px 22px;
  position: relative;
  white-space: nowrap;
}
.qf-chip-stat + .qf-chip-stat::before{
  content: "·";
  position: absolute;
  left: 0;
  color: var(--rule-strong);
  font-weight: 400;
}
@media (max-width: 880px){
  .quick-facts-inner{
    justify-content: flex-start;
    overflow-x: auto;
    flex-wrap: nowrap;
    scrollbar-width: none;
  }
