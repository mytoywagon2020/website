  font-size: 10.5px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--ink-soft);
  line-height: 1.8;
}

/* Human-touch block: "Replied to by a human" + Schedule a call */
.human-touch{
  margin-top: 28px;
  padding-top: 24px;
  border-top: 0.5px solid var(--rule);
  display: grid;
  gap: 22px;
}
.human-touch .ht-card{
  display: flex;
  align-items: flex-start;
  gap: 16px;
}
.human-touch .ht-card svg{
  width: 24px;
  height: 24px;
  stroke: var(--accent-deep);
  fill: none;
  stroke-width: 1.4;
  flex-shrink: 0;
  margin-top: 4px;
}
.human-touch .ht-body strong{
  display: block;
  font-family: var(--serif);
  font-weight: 500;
  font-size: 19px;
  color: var(--ink);
  line-height: 1.3;
  margin-bottom: 6px;
  letter-spacing: -.005em;
}
.human-touch .ht-body p{
  margin: 0;
  font-family: var(--sans);
  font-size: 13.5px;
  color: var(--ink-soft);
  line-height: 1.55;
}
.human-touch .ht-body .ht-link{
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-top: 10px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 0.5px solid var(--ink);
  padding-bottom: 3px;
  transition: color .2s ease, border-color .2s ease;
}
.human-touch .ht-body .ht-link:hover{ color: var(--forest); border-color: var(--forest); }
.human-touch .ht-call{
  margin-top: 6px;
  font-family: var(--sans);
  font-size: 12px;
  letter-spacing: .04em;
  color: var(--ink-soft);
}
.human-touch .ht-call a{ color: var(--ink); font-weight: 500; text-decoration: none; border-bottom: 0.5px solid var(--rule-strong); padding-bottom: 1px; }
.human-touch .ht-call a:hover{ border-color: var(--ink); }
.qf-form{ display: grid; gap: 22px 24px; grid-template-columns: 1fr 1fr; }
.qf-row{ display: flex; flex-direction: column; gap: 8px; min-width: 0; }
.qf-row.full{ grid-column: 1 / -1; }
.qf-row label{
  font-family: var(--sans);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
}
.qf-row label .req{ color: var(--accent-deep); margin-left: 4px; }
.qf-row input[type="text"],
.qf-row input[type="email"],
.qf-row input[type="tel"],
.qf-row select,
.qf-row textarea{
