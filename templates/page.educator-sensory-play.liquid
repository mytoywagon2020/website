}
.kit .add-row{ margin-top: 18px; }

/* ----------------------- CART + ACCOUNT (utility bar + nav) ----------------------- */
.signed-in{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px;
  color: var(--cream);
}
.signed-in .dot-active{
  display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--forest);
  box-shadow: 0 0 0 2px rgba(59,109,17,.25);
}
.signed-in .role{
  font-family: var(--sans);
  font-style: normal;
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: rgba(245,240,229,.55);
  margin-left: 8px;
}

.nav__actions{
  justify-self: end;
  display: inline-flex;
  align-items: center;
  gap: 12px;
}
.nav__cart{
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: .04em;
  color: var(--ink);
  text-decoration: none;
  padding: 11px 16px;
  border: 0.5px solid var(--rule-strong);
  border-radius: 2px;
  transition: border-color .2s ease;
}
.nav__cart:hover{ border-color: var(--ink); }
.nav__cart-count{
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 18px; height: 18px;
  padding: 0 5px;
  background: var(--forest);
  color: var(--cream);
  border-radius: 9px;
  font-size: 10.5px;
  font-weight: 600;
}

/* ----------------------- HOW IT WORKS (friction-reduction strip) ----------------------- */
.how-it-works{
  background: var(--card-bg);
  border-top: 0.5px solid var(--rule);
  border-bottom: 0.5px solid var(--rule);
}
.how-it-works-inner{
  max-width: 1340px;
  margin: 0 auto;
  padding: 56px clamp(20px, 5vw, 56px);
}
.how-head{
  display: grid;
  grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  gap: 56px;
  align-items: end;
  margin-bottom: 36px;
  padding-bottom: 28px;
  border-bottom: 0.5px solid var(--rule);
}
.how-head .eyebrow{ color: var(--accent-deep); margin-bottom: 18px; display: inline-block; }
.how-head h3{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(28px, 3.2vw, 42px);
  line-height: 1.05;
  letter-spacing: -.005em;
}
.how-head h3 .it{ color: var(--accent-deep); }
.how-head p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 42ch;
}
.steps{
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
.step{
  padding: 0 32px 0 0;
  border-right: 0.5px solid var(--rule);
}
.step:last-child{ border-right: 0; padding-right: 0; }
.step:nth-child(n+2){ padding-left: 32px; }
.step .num{
  font-family: var(--serif);
  font-style: italic;
  font-size: 38px;
  line-height: 1;
  color: var(--accent-deep);
  margin-bottom: 16px;
  display: block;
}
.step h4{
  margin: 0 0 10px;
  font-family: var(--serif);
  font-weight: 500;
  font-size: 22px;
  line-height: 1.2;
  letter-spacing: -.005em;
  color: var(--ink);
}
.step p{
  margin: 0;
  font-size: 14.5px;
  line-height: 1.6;
  color: var(--ink-soft);
  max-width: 36ch;
}
.step .more{
  margin-top: 14px;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 0.5px solid var(--ink);
  padding-bottom: 3px;
  transition: color .2s ease, border-color .2s ease;
}
.step .more:hover{ color: var(--forest); border-color: var(--forest); }
@media (max-width: 1080px){
  .how-head{ grid-template-columns: 1fr; gap: 24px; }
  .steps{ grid-template-columns: 1fr; gap: 28px; }
  .step{ border-right: 0; border-bottom: 0.5px solid var(--rule); padding: 0 0 24px 0 !important; }
  .step:last-child{ border-bottom: 0; padding-bottom: 0 !important; }
}
.price-policy{
  background: var(--card-bg);
  border-top: 0.5px solid var(--rule);
  border-bottom: 0.5px solid var(--rule);
  text-align: center;
  padding: 12px 16px;
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--stone);
}
.price-policy strong{ color: var(--ink); font-weight: 600; }

/* ----------------------- STRUCTURED QUOTE FORM ----------------------- */
.quote-form{ background: var(--card-bg); }
.quote-form .wrap{
  display: grid;
