}
.gallery .quote-strip p{
  margin: 0 auto;
  max-width: 32ch;
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(24px, 2.6vw, 36px);
  line-height: 1.35;
  color: var(--ink);
}

/* ============================== COMPANIONS ============================== */
.companions{
