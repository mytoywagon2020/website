}
.price small{
  font-family: var(--sans);
  font-style: normal;
  font-size: 10px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
  font-weight: 500;
}
.add-row{
  display: flex;
  align-items: center;
  gap: 14px;
  margin-top: 12px;
}
.add-btn{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--cream);
  background: var(--ink);
  border: 1px solid var(--ink);
