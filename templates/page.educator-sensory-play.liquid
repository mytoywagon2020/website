  text-decoration: none;
  transition: background .2s ease, border-color .2s ease;
}
.add-btn:hover{ background: var(--forest); border-color: var(--forest); }
.add-btn.plain{
  background: transparent; color: var(--ink);
}
.add-btn.plain:hover{ background: var(--ink); color: var(--cream); }
.add-btn .plus{
  display: inline-block;
  width: 9px; height: 9px;
  position: relative;
}
.add-btn .plus::before,
.add-btn .plus::after{
  content: ""; position: absolute; background: currentColor;
}
.add-btn .plus::before{ left: 0; right: 0; top: 50%; height: 1px; transform: translateY(-50%); }
.add-btn .plus::after{ top: 0; bottom: 0; left: 50%; width: 1px; transform: translateX(-50%); }
.view-pdp{
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 500;
  color: var(--stone);
  text-decoration: none;
  border-bottom: 0.5px solid var(--rule-strong);
  padding-bottom: 2px;
  transition: color .2s ease, border-color .2s ease;
}
.view-pdp:hover{ color: var(--ink); border-color: var(--ink); }
.view-pdp[href="#"]{ display: none; }
.home .tile-wrap{ position: relative; }
.card-pdp-link{ position:absolute; inset:0; z-index:4; display:block; }
.quick-spec{ position:absolute; inset:0; z-index:5; pointer-events:none; display:flex; flex-direction:column; justify-content:center; gap:6px; padding:26px; background:rgba(28,28,26,.84); color:var(--cream); opacity:0; transition:opacity .25s ease; font-family:var(--sans); font-size:12.5px; line-height:1.5; }
.quick-spec strong{ font-family:var(--serif); font-size:16px; margin-bottom:4px; }
.home .tile-wrap:hover .quick-spec{ opacity:1; }
.quick-spec{ display:none !important; } /* superseded by shared .quick-view */
.stock-pill{
  font-family: var(--sans);
  font-size: 10.5px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 500;
  color: var(--forest);
  display: inline-flex;
  align-items: center;
  gap: 6px;
}
.stock-pill::before{
  content: ""; display: inline-block;
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--forest);
}

/* Kit price-line override */
.kit .price-line{
  font-family: var(--serif);
  font-weight: 500;
  font-size: 30px;
  line-height: 1;
  color: var(--ink);
  letter-spacing: -.005em;
  font-style: normal;
  text-transform: none;
  margin: 0 0 6px;
  padding-top: 0;
  border-top: 0;
}
.kit .price-line .msrp{
  font-family: var(--sans);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: .04em;
  color: var(--stone);
  text-decoration: line-through;
  margin-left: 10px;
}
.kit .price-note{
  font-family: var(--sans);
  font-size: 10.5px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
  margin: 0 0 22px;
  padding-bottom: 18px;
  border-bottom: 0.5px solid var(--rule-strong);
