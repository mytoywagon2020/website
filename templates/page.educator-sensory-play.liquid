  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: .04em;
  color: var(--ink);
  background: var(--warm-white);
  border: 0.5px solid var(--rule-strong);
  border-radius: 999px;
  cursor: pointer;
