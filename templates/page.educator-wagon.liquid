{% layout none %}
{%- comment -%}
  Educator Wagon — the fork-in-the-road page between browsing and transacting.
  Two explicit paths: Path A (pay now via checkout) and Path B (PO / quote submission).
  Gated to educator-approved or B2B customers only.
{%- endcomment -%}
{%- assign is_approved = false -%}
{%- if customer and customer.tags contains 'educator-approved' -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if customer.b2b? -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if request.design_mode or theme.role != 'main' -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if is_approved -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Your Wagon | {{ shop.name }} Educator Portal</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --cream:#F5F0E5;--warm-white:#FFFCF7;--ink:#2C2C2A;--forest:#3B6D11;
      --amber:#854F0B;--stone:#5F5E5A;--card-bg:#EDE3CD;
      --rule:rgba(44,44,42,0.12);--rule-strong:rgba(44,44,42,0.22);
    }
    *{box-sizing:border-box;} html,body{margin:0;padding:0;}
    body{font-family:'Mulish',sans-serif;color:var(--ink);background:var(--cream);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased;}
    a{color:inherit;text-decoration:none;} img{max-width:100%;display:block;}
    .wrap{max-width:1080px;margin:0 auto;padding:0 40px;}

    /* ── Page hero ── */
    .wgn-hero{padding:36px 0 0;}
    .wgn-hero__eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .wgn-hero h1{font-family:'Cormorant Garamond',serif;font-size:38px;font-weight:500;margin:10px 0 4px;letter-spacing:-.01em;}
    .wgn-hero p{color:var(--stone);margin:0;font-size:14px;}

    /* ── Tax-exempt alert ── */
    .wgn-alert{display:flex;align-items:flex-start;gap:12px;background:#FEF8EC;border:1px solid var(--amber);border-radius:3px;padding:14px 18px;margin:22px 0 0;font-size:13.5px;line-height:1.55;}
    .wgn-alert__icon{font-size:18px;line-height:1;flex-shrink:0;margin-top:1px;}
    .wgn-alert strong{color:var(--amber);}
    .wgn-alert a{color:var(--forest);font-weight:600;text-decoration:underline;text-underline-offset:2px;}

    /* ── Main grid ── */
    .wgn-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:28px;padding:24px 0 56px;align-items:start;}

    /* ── Cart summary card ── */
    .wgn-card{background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:26px;}
    .wgn-card h2{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;margin:0 0 18px;padding-bottom:14px;border-bottom:.5px solid var(--rule);}
    table.wgn-items{width:100%;border-collapse:collapse;font-size:13.5px;}
    table.wgn-items thead th{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--stone);font-weight:600;padding:0 8px 10px;text-align:left;border-bottom:.5px solid var(--rule);}
    table.wgn-items thead th:last-child{text-align:right;}
    table.wgn-items td{padding:12px 8px;border-bottom:.5px solid var(--rule);vertical-align:middle;}
    .wgn-thumb{width:48px;height:48px;border-radius:2px;object-fit:cover;background:var(--card-bg);}
    .wgn-it-title{font-weight:600;font-size:13.5px;line-height:1.3;}
    .wgn-it-meta{font-size:11.5px;color:var(--stone);margin-top:2px;}
    .wgn-qty{text-align:center;color:var(--stone);}
    .wgn-price{text-align:right;white-space:nowrap;font-weight:600;}
    .wgn-rate{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);background:#edf4e6;border-radius:2px;padding:2px 5px;margin-top:3px;}
    .wgn-totals{padding:14px 8px 0;display:flex;flex-direction:column;gap:6px;}
    .wgn-totals__row{display:flex;justify-content:space-between;font-size:13.5px;color:var(--stone);}
    .wgn-totals__row--total{font-size:15px;font-weight:700;color:var(--ink);border-top:.5px solid var(--rule);padding-top:10px;margin-top:4px;}
    .wgn-totals__note{font-size:11.5px;color:var(--stone);margin-top:8px;line-height:1.5;}
    .wgn-edit{font-size:12px;font-weight:600;color:var(--forest);text-decoration:underline;text-underline-offset:2px;display:inline-block;margin-top:14px;}

    /* ── Actions card ── */
    .wgn-actions{display:flex;flex-direction:column;gap:14px;}

    /* Path A */
    .wgn-path{background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:24px;}
    .wgn-path__label{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);margin:0 0 6px;}
    .wgn-po-label{display:block;font-size:11.5px;color:var(--stone);margin:0 0 6px;}
    .wgn-po-input{width:100%;height:42px;border:1px solid var(--rule-strong);border-radius:2px;background:var(--warm-white);padding:0 12px;font-family:'Mulish',sans-serif;font-size:13.5px;color:var(--ink);margin:0 0 12px;}
    .wgn-po-input:focus{outline:2px solid var(--forest);outline-offset:1px;}
    .wgn-path h3{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;margin:0 0 8px;}
    .wgn-path p{font-size:12.5px;color:var(--stone);margin:0 0 16px;line-height:1.5;}
    .wgn-path__sub{font-size:11.5px;color:var(--stone);margin-top:8px;text-align:center;line-height:1.4;}
    .wgn-path__sub a{color:var(--forest);font-weight:600;text-decoration:underline;text-underline-offset:2px;}

    .wgn-btn{display:block;width:100%;padding:15px 24px;font-family:'Mulish',sans-serif;font-size:11.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;text-align:center;border-radius:2px;cursor:pointer;border:1.5px solid var(--ink);background:var(--ink);color:var(--cream);text-decoration:none;transition:background .15s,border-color .15s;}
    .wgn-btn:hover{background:var(--forest);border-color:var(--forest);}
    .wgn-btn--ghost{background:transparent;color:var(--ink);}
    .wgn-btn--ghost:hover{background:var(--ink);color:var(--cream);}

    /* ── Empty state ── */
    .wgn-empty{background:var(--warm-white);border:1px dashed var(--rule-strong);border-radius:3px;padding:52px 40px;text-align:center;color:var(--stone);grid-column:1/-1;}
    .wgn-empty h2{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:500;color:var(--ink);margin:0 0 10px;}
    .wgn-empty p{font-size:14px;margin:0 0 22px;}

    /* ── Compliance strip ── */
    .wgn-compliance{background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:18px 22px;margin:0 0 56px;}
    .wgn-compliance h4{font-size:10px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--stone);margin:0 0 10px;}
    .wgn-compliance__links{display:flex;flex-wrap:wrap;gap:10px 28px;}
    .wgn-compliance__links a{font-size:13px;font-weight:600;color:var(--forest);text-decoration:underline;text-underline-offset:2px;}
    .wgn-compliance__links a:hover{color:var(--ink);}
    .wgn-compliance__note{font-size:11.5px;color:var(--stone);margin-top:10px;line-height:1.5;}

    /* ── Client wagon: qty stepper, remove, busy, confirm ── */
    .wgn-qstep{display:inline-flex;align-items:center;border:1px solid var(--rule-strong);border-radius:3px;overflow:hidden;}
    .wgn-qstep button{width:26px;height:26px;border:0;background:var(--warm-white);color:var(--ink);font-size:15px;line-height:1;cursor:pointer;}
    .wgn-qstep button:hover{background:var(--card-bg);}
    .wgn-qstep input{width:34px;height:26px;border:0;border-left:1px solid var(--rule);border-right:1px solid var(--rule);text-align:center;font-family:inherit;font-size:13px;color:var(--ink);background:#fff;-moz-appearance:textfield;}
    .wgn-qstep input::-webkit-outer-spin-button,.wgn-qstep input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0;}
    .wgn-remove{display:block;margin-top:6px;font-size:11px;color:var(--stone);background:none;border:0;cursor:pointer;text-decoration:underline;text-underline-offset:2px;padding:0;}
    .wgn-remove:hover{color:var(--amber);}
    .wgn-btn[disabled]{opacity:.6;cursor:default;pointer-events:none;}
    .wgn-btn.is-busy{opacity:.7;cursor:progress;pointer-events:none;}
    .wgn-error{color:var(--amber);font-size:12px;margin-top:10px;text-align:center;line-height:1.45;}
    .wgn-confirm{background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:48px 40px;text-align:center;grid-column:1/-1;}
    .wgn-confirm h2{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:500;margin:0 0 12px;}
    .wgn-confirm p{font-size:14px;color:var(--stone);margin:0 auto 8px;max-width:48ch;}
    .wgn-confirm a.lnk{color:var(--forest);font-weight:600;text-decoration:underline;text-underline-offset:2px;}

    @media(max-width:800px){
      .wgn-grid{grid-template-columns:1fr;}
      .wrap{padding:0 20px;}
    }
  </style>
</head>
<body>
  {% section 'mtw-educator-header' %}
  {% render 'educator-wagon-cart' %}

  <main class="wrap">
    <section class="wgn-hero">
      <span class="wgn-hero__eyebrow">Educator Portal</span>
      <h1>Your wagon</h1>
      <p>Review your items, then choose your payment path below.</p>
    </section>

    {%- comment -%}Tax-exempt warning — show if customer does not carry the tax-exempt tag{%- endcomment -%}
    {%- unless customer.tags contains 'tax-exempt' -%}
    <div class="wgn-alert" role="alert">
      <span class="wgn-alert__icon" aria-hidden="true">&#9888;&#65039;</span>
      <div>
        <strong>No tax certificate on file.</strong> Sales tax will be calculated at checkout until your exemption certificate is verified.
        To remove tax before your order is confirmed, email your certificate to <a href="mailto:educators@mytoywagon.com">educators@mytoywagon.com</a> from your registered school address. Our team applies the exemption within one business day.
      </div>
    </div>
    {%- endunless -%}

    <!-- Wagon (client-side; walled products use a draft-order checkout) -->
    <div id="wgnGrid"></div>

    <!-- Compliance strip -->
    <div class="wgn-compliance">
      <h4>Compliance &amp; Procurement Documents</h4>
      <div class="wgn-compliance__links">
        <a href="{{ 'vendor-onboarding-packet.pdf' | asset_url }}">&#8659; Download W-9, COI &amp; Sole-Source Letter (PDF)</a>
        <a href="/pages/vendor-profile">Vendor profile page</a>
        <a href="mailto:educators@mytoywagon.com">Contact educator support</a>
      </div>
      <p class="wgn-compliance__note">
        ACH / direct deposit details are provided to your district accounting department upon verified request &mdash; contact us from your registered school email address.
      </p>
    </div>

  </main>

  {% section 'mtw-educator-footer' %}

  <script>
  (function(){
    var grid=document.getElementById('wgnGrid');
    if(!grid) return;
    function money(c){ return window.MTWWagon ? MTWWagon.money(c) : '$'+((c||0)/100).toFixed(2); }
    function esc(t){ var d=document.createElement('div'); d.textContent=t==null?'':t; return d.innerHTML; }

    function render(items){
      if(!window.MTWWagon){ grid.innerHTML=''; return; }
      items = items || MTWWagon.items();
      if(!items.length){
        grid.innerHTML='<div class="wgn-grid"><div class="wgn-empty"><h2>Your wagon is empty</h2><p>Add items from the educator catalog, then come back here to check out or submit a purchase order.</p><a class="wgn-btn" href="/pages/educators" style="display:inline-block;width:auto;padding:14px 32px;">Browse the catalog &rarr;</a></div></div>';
        return;
      }
      var n=MTWWagon.count(), sub=MTWWagon.subtotalCents();
      var rows=items.map(function(it){
        var vid=esc(it.variantId);
        return '<tr data-vid="'+vid+'">'+
          '<td>'+(it.img?'<img class="wgn-thumb" src="'+esc(it.img)+'" alt="'+esc(it.title)+'">':'')+'</td>'+
          '<td><div class="wgn-it-title">'+esc(it.title)+'</div>'+(it.sku?'<div class="wgn-it-meta">SKU '+esc(it.sku)+'</div>':'')+'<button type="button" class="wgn-remove" data-remove="'+vid+'">Remove</button></td>'+
          '<td class="wgn-qty"><span class="wgn-qstep"><button type="button" data-dec="'+vid+'" aria-label="Decrease quantity">&minus;</button><input type="number" min="1" value="'+(it.qty||1)+'" data-qty="'+vid+'" aria-label="Quantity"><button type="button" data-inc="'+vid+'" aria-label="Increase quantity">+</button></span></td>'+
          '<td class="wgn-price">'+money((it.priceCents||0)*(it.qty||1))+'<span class="wgn-rate">Educator rate</span></td>'+
        '</tr>';
      }).join('');
      grid.innerHTML=
      '<div class="wgn-grid">'+
        '<div class="wgn-card">'+
          '<h2>'+n+' item'+(n!==1?'s':'')+' in your wagon</h2>'+
          '<table class="wgn-items"><thead><tr><th style="width:54px;"></th><th>Item</th><th style="text-align:center;">Qty</th><th>Educator rate</th></tr></thead><tbody>'+rows+'</tbody></table>'+
          '<div class="wgn-totals">'+
            '<div class="wgn-totals__row"><span>'+n+' item'+(n!==1?'s':'')+'</span><span>'+money(sub)+'</span></div>'+
            '<div class="wgn-totals__row wgn-totals__row--total"><span>Estimated total</span><span>'+money(sub)+'</span></div>'+
            '<p class="wgn-totals__note">Shipping, final educator pricing adjustments, and applicable tax are confirmed on your quote or at checkout. Bundles qualify for 10% savings.</p>'+
          '</div>'+
        '</div>'+
        '<div class="wgn-actions">'+
          '<div class="wgn-path">'+
            '<p class="wgn-path__label">Path A &mdash; Pay immediately</p>'+
            '<h3>Proceed to secure checkout</h3>'+
            '<p>Pay by credit card, P-card, Shop Pay, or Apple Pay. Best for site-funded purchases, PTA accounts, or reimbursement orders.</p>'+
            '<button type="button" class="wgn-btn" id="wgnPayCard">Proceed to secure checkout &rarr;</button>'+
            '<p class="wgn-path__sub">You&rsquo;ll land on our secure Shopify checkout. Tax-exempt status is applied automatically for verified accounts.</p>'+
            '<p class="wgn-error" id="wgnCardErr" hidden></p>'+
          '</div>'+
          '<div class="wgn-path">'+
            '<p class="wgn-path__label">Path B &mdash; District approval</p>'+
            '<h3>Submit for district approval</h3>'+
            '<p>For Net-30, board-approved POs, and budget requisitions. We generate a formal itemized invoice your procurement office can countersign.</p>'+
            '<label class="wgn-po-label" for="wgnPONum">Have an official PO number? Enter it here (optional):</label>'+
            '<input class="wgn-po-input" id="wgnPONum" type="text" autocomplete="off" placeholder="e.g. PO-2026-0142">'+
            '<button type="button" class="wgn-btn wgn-btn--ghost" id="wgnPayPO">Submit for district approval &rarr;</button>'+
            '<p class="wgn-path__sub">Pricing held 45 days. Inventory reserved on PO confirmation.</p>'+
            '<p class="wgn-error" id="wgnPOErr" hidden></p>'+
          '</div>'+
        '</div>'+
      '</div>';
    }

    function setBusy(btn,on){ if(!btn)return; btn.classList.toggle('is-busy',on); btn.disabled=on; }
    function err(el,msg){ if(!el)return; el.textContent=msg||''; el.hidden=!msg; }

    function doPay(method, btn, errEl){
      if(!window.MTWWagon) return;
      err(errEl,''); setBusy(btn,true);
      var opts={};
      if(method==='po'){ var pn=document.getElementById('wgnPONum'); if(pn && pn.value.trim()) opts.poNumber=pn.value.trim(); }
      MTWWagon.checkout(method, opts).then(function(url){
        if(method==='po'){
          grid.innerHTML='<div class="wgn-grid"><div class="wgn-confirm"><h2>Purchase order request sent</h2><p>We&rsquo;ve created your itemized order. Our team confirms Net-30 terms and emails your countersign-ready quote within one business day.</p><p><a class="lnk" href="'+esc(url)+'">View your itemized quote &rarr;</a></p></div></div>';
          MTWWagon.clear();
        } else {
          window.location.href=url;
        }
      }).catch(function(e){
        setBusy(btn,false);
        var msg=(e&&e.message==='empty') ? 'Your wagon is empty.' : 'We couldn&rsquo;t reach checkout. Please try again, or email educators@mytoywagon.com.';
        err(errEl, msg);
      });
    }

    grid.addEventListener('click', function(e){
      var t=e.target; if(!t.getAttribute) return;
      var inc=t.getAttribute('data-inc'), dec=t.getAttribute('data-dec'), rm=t.getAttribute('data-remove');
      if(inc){ MTWWagon.setQty(inc, MTWWagon.qtyOf(inc)+1); }
      else if(dec){ MTWWagon.setQty(dec, Math.max(1, MTWWagon.qtyOf(dec)-1)); }
      else if(rm){ MTWWagon.remove(rm); }
      else if(t.id==='wgnPayCard'){ doPay('card', t, document.getElementById('wgnCardErr')); }
      else if(t.id==='wgnPayPO'){ doPay('po', t, document.getElementById('wgnPOErr')); }
    });
    grid.addEventListener('change', function(e){
      var v=e.target.getAttribute && e.target.getAttribute('data-qty');
      if(v){ MTWWagon.setQty(v, Math.max(1, parseInt(e.target.value,10)||1)); }
    });

    if(window.MTWWagon){ MTWWagon.subscribe(render); } else { render([]); }
  })();
  </script>
</body>
</html>
{%- else -%}
{% render 'educator-gate' %}
{%- endif -%}
