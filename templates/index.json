      "settings": {
        "label": "Featured brand",
        "heading": "Hand-carved in Romania, by the makers at <em>Bumbu Toys</em>.",
        "body": "<p>Each piece in the Bumbu line is shaped from maple and basswood, with beech and oak for heavier landscape elements. All timber is FSC-certified, harvested from responsibly managed European forests.</p><p>Pieces are hand-painted in small batches with water-based, non-toxic stains, then finished with organic oils and beeswax. Safe for the toddler who mouths the horse, durable for the older sibling who builds it into a story.</p>",
        "quote": "Hand-carved wood, painted in small batches. A line that scales across childhood, and back onto the shelf each season.",
        "cta_text": "Shop Bumbu Toys",
        "cta_link": "/collections/bumbu-toys",
        "video": "shopify://files/videos/video-bumbu-workshop-romania_fd611223-8999-438d-a22b-d9df0374ec6c.mp4",
        "video_url": ""
      }
