    "mtw_story": {
      "type": "mtw-story",
      "settings": {
        "label": "Our Story",
        "title": "A small toy shop, with a <em>big heart</em>.",
        "lead": "<p>My Toy Wagon began with a simple inspiration: our two daughters, Hafsa and Noor. They are the heartbeat of the shop, the reminders that childhood is fleeting, and that the toys we choose for it matter.</p>",
        "body": "<p>We carefully curate wooden and felt toys that hold up to real play, that scale across ages, and that pass quietly to a younger sibling. Most orders are packed and shipped by hand from our shop in Los Angeles.</p>",
        "signature": "Irfana & Rashid",
        "role": "Founders, My Toy Wagon",
        "button_text": "Read our full story",
        "button_link": "/pages/our-story"
      }
    },
