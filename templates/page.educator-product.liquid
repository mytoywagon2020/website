{% layout none %}
{%- comment -%}
  Educator PDP — a REAL gated page (not a product page) for WALLED educator items.
  Walled products have no Online Store PDP and Liquid can't read their metafields
  (all_products excludes off-channel products). This Page renders a premium PDP
  (gallery, value badges, accordion sections) from a data island keyed by ?sku=.
  ROADMAP: swap the data island for a live fetch to the app proxy
  (/apps/wagon/product?sku=) which returns title/price/media/metafields from the
  Admin API — same markup, live data, still off /products.json. Gated to educators.
{%- endcomment -%}
{%- assign is_approved = false -%}
{%- if customer and customer.tags contains 'educator-approved' -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if customer.b2b? -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if request.design_mode or theme.role != 'main' -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if is_approved -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Educator Catalog | {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{--cream:#F5F0E5;--warm-white:#FFFCF7;--ink:#2C2C2A;--forest:#3B6D11;--amber:#854F0B;--stone:#5F5E5A;--card-bg:#EDE3CD;--rule:rgba(44,44,42,.12);--rule-strong:rgba(44,44,42,.22);--serif:'Cormorant Garamond',serif;--sans:'Mulish',sans-serif;}
    *{box-sizing:border-box;} html,body{margin:0;padding:0;}
    body{font-family:var(--sans);color:var(--ink);background:var(--cream);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased;}
    img{max-width:100%;display:block;} a{color:inherit;text-decoration:none;}
    .wrap{max-width:1100px;margin:0 auto;padding:0 40px;}
    .pdp-crumb{padding:22px 0 0;font-size:12px;color:var(--stone);}
    .pdp-crumb a{color:var(--forest);text-decoration:underline;text-underline-offset:2px;}
    .pdp{display:grid;grid-template-columns:1.05fr .95fr;gap:48px;padding:24px 0 48px;align-items:start;}

    /* Gallery */
    .pdp__gallery{position:sticky;top:24px;}
    .pdp__main{position:relative;background:var(--card-bg);border-radius:5px;overflow:hidden;aspect-ratio:3/4;}
    .pdp__main img{width:100%;height:100%;object-fit:cover;}
    .pdp__thumbs{display:flex;gap:10px;margin-top:12px;flex-wrap:wrap;}
    .pdp__thumbs button{width:60px;aspect-ratio:3/4;border-radius:3px;overflow:hidden;border:1.5px solid transparent;background:var(--card-bg);cursor:pointer;padding:0;}
    .pdp__thumbs button.is-active{border-color:var(--forest);}
    .pdp__thumbs img{width:100%;height:100%;object-fit:cover;}

    /* Info */
    .pdp__eyebrow{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .pdp__title{font-family:var(--serif);font-size:36px;font-weight:500;margin:8px 0 8px;letter-spacing:-.01em;line-height:1.08;}
    .pdp__price{font-family:var(--serif);font-size:27px;color:var(--forest);display:flex;align-items:center;gap:10px;}
    .pdp__rate{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);background:#edf4e6;border-radius:2px;padding:3px 7px;font-family:var(--sans);}
    .pdp__sku{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--stone);margin-top:4px;}
    .pdp__badges{margin:16px 0 4px;font-size:12px;font-weight:600;color:var(--stone);letter-spacing:.02em;line-height:1.8;}
    .pdp__badges .bdg{white-space:nowrap;}
    .pdp__badges .sep{color:var(--rule-strong);margin:0 8px;}
    .pdp__buy{display:flex;gap:12px;align-items:stretch;margin:22px 0 10px;flex-wrap:wrap;}
    .qty{display:inline-flex;align-items:center;border:1px solid var(--rule-strong);border-radius:2px;overflow:hidden;}
    .qty button{width:36px;height:48px;border:0;background:var(--warm-white);color:var(--ink);font-size:17px;cursor:pointer;}
    .qty button:hover{background:var(--forest);color:#fff;}
    .qty input{width:46px;height:48px;border:0;border-left:1px solid var(--rule);border-right:1px solid var(--rule);text-align:center;font-family:var(--sans);font-size:14px;-moz-appearance:textfield;}
    .qty input::-webkit-outer-spin-button,.qty input::-webkit-inner-spin-button{-webkit-appearance:none;margin:0;}
    .add-btn{flex:1;min-width:200px;padding:0 24px;font-family:var(--sans);font-size:11.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;text-align:center;border-radius:2px;cursor:pointer;border:1.5px solid var(--ink);background:var(--ink);color:var(--cream);transition:background .15s,border-color .15s;}
    .add-btn:hover{background:var(--forest);border-color:var(--forest);}
    .add-btn.is-in{background:var(--forest);border-color:var(--forest);cursor:default;}
    .pdp__sub{font-size:11.5px;color:var(--stone);margin:6px 0 0;}
    .pdp__sub a{color:var(--forest);text-decoration:underline;text-underline-offset:2px;}
    .pdp__wagonlink{display:inline-block;margin-top:12px;font-size:12px;font-weight:600;color:var(--forest);text-decoration:underline;text-underline-offset:2px;}
    .pdp__back{display:inline-block;margin-top:28px;padding-top:20px;border-top:.5px solid var(--rule);width:100%;font-size:14px;font-weight:600;color:var(--forest);text-decoration:none;}
    .pdp__back:hover{text-decoration:underline;text-underline-offset:3px;}

    /* Description + accordions (premium typography) */
    .pdp__lead{margin:22px 0 6px;font-size:15px;line-height:1.72;}
    .pdp__lead p{margin:0 0 12px;}
    .acc{border-top:.5px solid var(--rule);}
    .acc:last-of-type{border-bottom:.5px solid var(--rule);}
    .acc summary{list-style:none;cursor:pointer;padding:15px 2px;display:flex;justify-content:space-between;align-items:center;font-family:var(--sans);font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink);}
    .acc summary::-webkit-details-marker{display:none;}
    .acc summary::after{content:"+";font-size:18px;font-weight:400;color:var(--stone);line-height:1;}
    .acc[open] summary::after{content:"\2212";}
    .acc__body{padding:0 2px 16px;font-size:14px;line-height:1.7;}
    .acc__body p{margin:0 0 10px;} .acc__body ul{margin:0 0 10px;padding-left:18px;} .acc__body li{margin:0 0 6px;} .acc__body strong{font-weight:700;}

    .pdp-empty{padding:80px 0;text-align:center;color:var(--stone);}
    .pdp-empty h1{font-family:var(--serif);font-size:28px;color:var(--ink);font-weight:500;margin:0 0 12px;}
    .cart-flash{position:fixed;left:50%;bottom:28px;transform:translateX(-50%) translateY(20px);background:var(--ink);color:var(--cream);padding:12px 20px;border-radius:3px;font-size:13px;opacity:0;pointer-events:none;transition:opacity .25s,transform .25s;z-index:50;max-width:90vw;}
    .cart-flash.show{opacity:1;transform:translateX(-50%) translateY(0);}
    .cart-flash .added{font-weight:700;}
    @media(max-width:820px){.pdp{grid-template-columns:1fr;gap:26px;}.pdp__gallery{position:static;}.wrap{padding:0 20px;}}
  </style>
</head>
<body>
  {% section 'mtw-educator-header' %}
  {% render 'educator-wagon-cart' %}

  <main class="wrap">
    <div class="pdp-crumb"><a href="/pages/educators">Educator Catalog</a> &nbsp;/&nbsp; <a href="/pages/educator-fairy-villages">Fairy Villages</a> &nbsp;/&nbsp; <span id="pdpCrumb">Product</span></div>
    <div id="pdpApp"></div>
  </main>

  {% section 'mtw-educator-footer' %}

  <script>
  window.MTW_PDP = {
    "MTW-FV-MUS":{t:"Mushroom Garden Fairy Home",p:"$228",vid:"48345499205802",back:"/pages/educator-fairy-villages",badges:["Handmade in Nepal","Hand-stitched wool felt","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/MushroomHousewithCarrotGardenMat2.jpg?v=1743982397","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/MushroomHousewithCarrotGardenMat4.jpg?v=1743982397","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/MushroomHousewithCarrotGardenMat3.jpg?v=1743982397","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/MushroomHousewithCarrotGardenMat5.jpg?v=1743982397","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/MushroomHousewithCarrotGardenMat6.jpg?v=1743982397"]},
    "MTW-FV-PGN":{t:"Wonderheart Pastel Gnomes",p:"$108",vid:"48345499238570",back:"/pages/educator-fairy-villages",badges:["Made in USA","Birch + wool felt","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/PastelGnomes9_f2c357ae-3221-4f47-8837-35c5b3fe6e40.jpg?v=1780030148"]},
    "MTW-FV-RGN":{t:"Wonderheart Bright Gnomes",p:"$108",vid:"48345499271338",back:"/pages/educator-fairy-villages",badges:["Made in USA","Birch + wool felt","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/WonderheartMay20256_be730604-fdda-4e34-a9c1-96cc457f29c0.jpg?v=1780030149"]},
    "MTW-FV-VLG":{t:"Build the Village Fairy Village Set",p:"$640",vid:"48345499304106",back:"/pages/educator-fairy-villages",badges:["Handmade in Nepal","Wool felt","Net-30 ready","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/MushroomHousewithCarrotGardenMat2_39b838cb-ec42-45de-964b-28fce68096bc.jpg?v=1780030149"]},
    "MTW-FV-BFH":{t:"Butterfly Fairy House",p:"$45",vid:"48355698475178",back:"/pages/educator-fairy-villages",badges:["Handmade in Nepal","Hand-stitched wool felt","Fair trade","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/ButterflyFairyHouse2.jpg?v=1744153545","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/ButterflyFairyHouse.jpg?v=1744153545","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/2c.jpg?v=1744153545"]},
    "MTW-FV-PNK":{t:"Pink Blossom House",p:"$58",vid:"48355716497578",back:"/pages/educator-fairy-villages",badges:["Handmade in Nepal","Hand-stitched wool felt","Fair trade","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/pink-blossom-fairy-house.jpg?v=1779662621","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/PinkFairyBlossomHouse.jpg?v=1773420624","https://cdn.shopify.com/s/files/1/0522/0882/8586/products/3_0ad9cad3-32d2-4420-9420-20640d7aa264.jpg?v=1773420624","https://cdn.shopify.com/s/files/1/0522/0882/8586/products/1_6c39d39d-7257-449d-976c-ca6c2ad42f16.jpg?v=1773420624"]},
    "MTW-FV-LIL":{t:"Lilac Blossom House",p:"$58",vid:"48355716530346",back:"/pages/educator-fairy-villages",badges:["Handmade in Nepal","Hand-stitched wool felt","Fair trade","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/LilacFairyBlossomHouse2.jpg?v=1775874905","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/LilacFairyBlossomHouse.jpg?v=1775874905","https://cdn.shopify.com/s/files/1/0522/0882/8586/files/LilacFairyBlossomHouse2_7b52dd45-8c13-4425-acae-fb03f242984e.jpg?v=1775874905"]},
    "MTW-FV-RBN":{t:"Rainbow House",p:"$50",vid:"48355716595882",back:"/pages/educator-fairy-villages",badges:["Handmade in Nepal","100% wool · CE-certified","Fair trade","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/LargeRainbowShimmerHome.png?v=1774074543"]},
    "MTW-FV-RBS":{t:"Rainbow Shimmer Home",p:"$65",vid:"48355716661418",back:"/pages/educator-fairy-villages",badges:["Handmade in Nepal","100% wool · CE-certified","Fair trade","Ages 3–8"],imgs:["https://cdn.shopify.com/s/files/1/0522/0882/8586/files/rainbow-shimmer-fairy-house.png?v=1779662621"]}
  };
  </script>

  <!-- Full details by SKU: lead paragraph(s) shown, the rest in accordions. -->
  <template data-pdp="MTW-FV-PNK">
    <div class="pdp__lead"><p>A hand-felted pink blossom cottage — the signature piece of our Fairy Villages line. The pointed roof is built of overlapping wool petals stitched one at a time; the doorway opens onto a hollow interior where a small fairy or gnome can live, sit, or sleep.</p></div>
    <details class="acc" open><summary>About this piece</summary><div class="acc__body"><p>Every house is hand-stitched in Nepal by a women's felting cooperative. Wool is sourced from Australia and New Zealand, hand-rolled and shaped without molds — meaning no two houses are identical. Tiny differences in petal angle and curve mark each one as the work of a particular maker.</p></div></details>
    <details class="acc"><summary>Educator notes</summary><div class="acc__body"><p>The anchor piece for spring nature tables, small-world play, and the Fairy Villages classroom set. Pairs naturally with Wonderheart wooden gnomes (4″ or mini) — the open doorway is sized to receive both.</p></div></details>
    <details class="acc"><summary>Specifications</summary><div class="acc__body"><ul><li>Hand-stitched wool felt over an internal armature</li><li>Approximately 7″ tall</li><li>Spot-clean only · fair-trade · handmade in Nepal</li><li>Ages 3–8</li></ul></div></details>
  </template>
  <template data-pdp="MTW-FV-LIL">
    <div class="pdp__lead"><p>A hand-felted lilac blossom cottage — the dusk-toned sibling of the Pink Blossom House. The roof of curled wool petals reads as lilac at one angle and pale violet at another; the doorway opens onto a hollow interior big enough to seat a small fairy or wooden gnome.</p></div>
    <details class="acc" open><summary>About this piece</summary><div class="acc__body"><p>Hand-stitched in Nepal by a women's felting cooperative. Wool is sourced from Australia and New Zealand and felted by hand without molds, so no two houses are identical — petal angles, curve depths, and color saturation all carry the maker's fingerprint.</p></div></details>
    <details class="acc"><summary>Educator notes</summary><div class="acc__body"><p>A favorite for spring–early summer nature tables. Pairs with the Wonderheart Mini Pastel Purple or Pink Gnome for the most natural color story.</p></div></details>
    <details class="acc"><summary>Specifications</summary><div class="acc__body"><ul><li>Hand-stitched wool felt over an internal armature</li><li>Approximately 7″ tall</li><li>Spot-clean only · fair-trade · handmade in Nepal</li><li>Ages 3–8</li></ul></div></details>
  </template>

  <script>
  (function(){
    var PDP=window.MTW_PDP||{};
    var app=document.getElementById('pdpApp'), crumb=document.getElementById('pdpCrumb');
    function param(n){ try{ return new URLSearchParams(window.location.search).get(n); }catch(e){ return null; } }
    function esc(t){var d=document.createElement('div');d.textContent=t==null?'':t;return d.innerHTML;}
    function notFound(){ app.innerHTML='<div class="pdp-empty"><h1>Product not found</h1><p>This item may have moved. <a class="pdp__wagonlink" href="/pages/educators">Return to the catalog &rarr;</a></p></div>'; }

    function renderProduct(P){
      var sku=P.sku;
      if(crumb) crumb.textContent=P.t;
      document.title=P.t+' | Educator Catalog';
      var imgs=(P.imgs&&P.imgs.length)?P.imgs:[''];
      var badges=(P.badges||[]).slice(); badges.push('Net-30 · tax-exempt');
      var badgeHtml=badges.map(function(b){return '<span class="bdg">'+esc(b)+'</span>';}).join('<span class="sep">•</span>');
      var thumbHtml=imgs.length>1 ? '<div class="pdp__thumbs" id="pdpThumbs">'+imgs.map(function(u,i){return '<button type="button" data-i="'+i+'" class="'+(i===0?'is-active':'')+'"><img src="'+esc(u)+'" alt="View '+(i+1)+'"></button>';}).join('')+'</div>' : '';

      app.innerHTML=
        '<div class="pdp">'+
          '<div class="pdp__gallery">'+
            '<div class="pdp__main"><img id="pdpMain" src="'+esc(imgs[0])+'" alt="'+esc(P.t)+'"></div>'+
            thumbHtml+
          '</div>'+
          '<div class="pdp__info">'+
            '<span class="pdp__eyebrow">'+esc(P.eyebrow||'Educator Catalog')+'</span>'+
            '<h1 class="pdp__title">'+esc(P.t)+'</h1>'+
            '<div class="pdp__price">'+esc(P.p)+'<span class="pdp__rate">Educator rate</span></div>'+
            '<div class="pdp__sku">'+esc(sku)+'</div>'+
            '<div class="pdp__badges">'+badgeHtml+'</div>'+
            '<div class="pdp__buy">'+
              '<span class="qty"><button type="button" id="qDec" aria-label="Decrease">&minus;</button><input id="qVal" type="number" min="1" value="1" aria-label="Quantity"><button type="button" id="qInc" aria-label="Increase">+</button></span>'+
              '<button type="button" class="add-btn" id="pdpAdd">Add to wagon</button>'+
            '</div>'+
            '<p class="pdp__sub">Educator pricing &middot; Net-30 &middot; tax-exempt. Pay by card or purchase order at your wagon.</p>'+
            '<a class="pdp__wagonlink" href="/pages/educator-wagon">View your wagon &rarr;</a>'+
            (P.bodyHtml||'')+
            '<a class="pdp__back" href="'+esc(P.back||'/pages/educators')+'">&larr; Back to the catalog</a>'+
          '</div>'+
        '</div>';

      var main=document.getElementById('pdpMain'), thumbs=document.getElementById('pdpThumbs');
      if(thumbs){ thumbs.addEventListener('click',function(e){ var b=e.target.closest('button[data-i]'); if(!b)return; var i=+b.getAttribute('data-i'); main.src=imgs[i]; Array.prototype.forEach.call(thumbs.children,function(c){c.classList.remove('is-active');}); b.classList.add('is-active'); }); }

      var qv=document.getElementById('qVal');
      function curQty(){ return window.MTWWagon?MTWWagon.qtyOf(P.vid):0; }
      function syncIfInWagon(){ if(window.MTWWagon && curQty()>0){ MTWWagon.setQty(P.vid, Math.max(1,parseInt(qv.value,10)||1)); } }
      document.getElementById('qInc').addEventListener('click',function(){ qv.value=(parseInt(qv.value,10)||1)+1; syncIfInWagon(); paint(); });
      document.getElementById('qDec').addEventListener('click',function(){ qv.value=Math.max(1,(parseInt(qv.value,10)||1)-1); syncIfInWagon(); paint(); });
      qv.addEventListener('change',function(){ qv.value=Math.max(1,parseInt(qv.value,10)||1); syncIfInWagon(); paint(); });
      var flash=null;
      function show(html){ if(!flash){flash=document.createElement('div');flash.className='cart-flash';document.body.appendChild(flash);} flash.innerHTML=html;flash.classList.add('show');clearTimeout(window.__t);window.__t=setTimeout(function(){flash.classList.remove('show');},2600); }
      var addBtn=document.getElementById('pdpAdd');
      function paint(){ if(!addBtn) return; var n=curQty(); if(n>0){ addBtn.textContent='✓ In wagon'; addBtn.classList.add('is-in'); } else { addBtn.textContent='Add to wagon'; addBtn.classList.remove('is-in'); } }
      addBtn.addEventListener('click',function(){
        if(!window.MTWWagon){ show('<span class="added">Wagon unavailable.</span> Please refresh.'); return; }
        if(curQty()>0){ show('<span class="added">Already in your wagon.</span> Adjust the quantity above, or view your wagon.'); return; }
        if(!P.vid){ show('<span class="added">Coming soon.</span> '+esc(P.t)); return; }
        var q=Math.max(1,parseInt(qv.value,10)||1);
        MTWWagon.add({variantId:P.vid,sku:sku,title:P.t,price:P.p,img:imgs[0],qty:q});
        show('<span class="added">Added to your wagon!</span> '+esc(P.t));
      });
      if(window.MTWWagon){ var ex=curQty(); if(ex>0) qv.value=ex; MTWWagon.subscribe(paint); } else { paint(); }
    }

    var sku=(param('sku')||'').toUpperCase().trim();
    var baked=PDP[sku];
    if(baked){
      var bodyTpl=document.querySelector('template[data-pdp="'+sku+'"]');
      renderProduct({ sku:sku, t:baked.t, p:baked.p, vid:baked.vid, imgs:baked.imgs, badges:baked.badges, back:baked.back||'/pages/educators', eyebrow:'Educator Catalog · Fairy Villages', bodyHtml: bodyTpl?bodyTpl.innerHTML:'<div class="pdp__lead"><p>Full classroom details available on request — contact educators@mytoywagon.com.</p></div>' });
    } else if(sku){
      // Live fetch via the app proxy (works for ANY walled SKU once the Worker is deployed).
      app.innerHTML='<div class="pdp-empty"><h1>Loading…</h1></div>';
      fetch('/apps/wagon/product?sku='+encodeURIComponent(sku),{headers:{'Accept':'application/json'}})
        .then(function(r){ return r.json(); })
        .then(function(d){
          if(!d||!d.title){ notFound(); return; }
          var pr=''; if(d.price!=null && d.price!==''){ var nf=parseFloat(d.price); pr='$'+(nf%1===0?String(parseInt(nf,10)):nf.toFixed(2)); }
          var mf=d.metafields||{}; var badges=[];
          if(mf['custom.age_range']) badges.push('Ages '+mf['custom.age_range']);
          if(mf['custom.material']) badges.push(mf['custom.material']);
          if(mf['custom.origin']) badges.push(mf['custom.origin']);
          renderProduct({ sku:(d.sku||sku), t:d.title, p:pr, vid:d.variantId, imgs:d.images, badges:badges, back:'/pages/educators', eyebrow:'Educator Catalog', bodyHtml: d.descriptionHtml?('<div class="pdp__lead">'+d.descriptionHtml+'</div>'):'' });
        })
        .catch(notFound);
    } else { notFound(); }
  })();
  </script>
</body>
</html>
{%- else -%}
{% render 'educator-gate' %}
{%- endif -%}
