    <details class="acc"><summary>Pairs with</summary><div class="acc__body"><p>Mushroom Garden Fairy Home · Build the Village · Bumbu mushrooms and trees.</p></div></details>
  </template>
  <template data-pdp="MTW-FV-RGN">
