{% layout none %}
{%- comment -%}
  Educator Dashboard — gated portal home for approved educators.
  Renders live customer data via Liquid. Closed unless the customer is tagged
  'educator-approved' or is a B2B customer.

  Design: 2026-05 redesign — "Combined" desktop + mobile per design team README.
  Wagon-card state branches on cart.item_count + customer.metafields.educator.open_quote_id.
  Featured tiles read from shop.metafields.educator.featured_handles (list of 3 product handles).

  Page order (between header and footer sections):
    utility bar (above mtw-educator-header) → mtw-educator-header → welcome bar
    → main grid (left rail + content) → mtw-educator-footer

  Hard rules from README:
    - NO countdown to order-by date (considered and rejected).
    - Status pill classes 'paid' / 'pending' / 'other' — do not invent new colors.
    - Sticky left rail on desktop; disabled below 860px.
    - <details> Account section on mobile (native HTML, no JS).
    - Mobile h1 32px, desktop h1 52px. Body bg #dcd5c5 warm tan (intentional).
    - Catalog tile bg colors are intentional placeholders for seasonal photography.
{%- endcomment -%}
{%- assign is_approved = false -%}
{%- if customer and customer.tags contains 'educator-approved' -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if customer.b2b? -%}{%- assign is_approved = true -%}{%- endif -%}
{%- if is_approved -%}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Educator Dashboard | {{ shop.name }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Mulish:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --cream:#F5F0E5;
      --warm-white:#FFFCF7;
      --ink:#2C2C2A;
      --forest:#3B6D11;
      --amber:#854F0B;
      --stone:#5F5E5A;
      --card-bg:#EDE3CD;
      --rule:rgba(44,44,42,0.12);
      --rule-strong:rgba(44,44,42,0.22);
      --moss:#5A7240;
      /* Warm tan body bg — intentional (design team confirmed) */
      --body-bg:#dcd5c5;
    }
    *{box-sizing:border-box;}
    html,body{margin:0;padding:0;}
    body{font-family:'Mulish',sans-serif;color:var(--ink);background:var(--body-bg);font-size:15px;line-height:1.6;-webkit-font-smoothing:antialiased;}
    a{color:inherit;text-decoration:none;}
    img{max-width:100%;display:block;}

    /* Utility bar — full-width black strip above header */
    .dash-utility{background:var(--ink);}
    .dash-utility__inner{max-width:1080px;margin:0 auto;padding:10px 40px;display:flex;justify-content:space-between;align-items:center;gap:16px;color:rgba(245,240,229,.8);font-size:12px;letter-spacing:.06em;}
    .dash-utility__left,.dash-utility__right{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .dash-utility__right a{color:inherit;}

    /* Welcome bar */
    .orders-lookup{display:flex;flex-wrap:wrap;align-items:center;gap:10px;margin:0 0 12px;}
    .orders-lookup__label{font-size:11.5px;font-weight:600;text-transform:uppercase;letter-spacing:.14em;color:var(--stone);}
    .orders-lookup__input{flex:1 1 240px;max-width:320px;padding:9px 12px;font-size:13.5px;font-family:inherit;border:1px solid var(--rule-strong);border-radius:2px;background:var(--warm-white);color:var(--ink);}
    .orders-lookup__input:focus{outline:none;border-color:var(--ink);}
    .orders-lookup__empty{font-size:12px;color:var(--stone);font-style:italic;}
    .orders .actions{white-space:nowrap;}
    .orders .actions .reorder-form{display:inline;margin-left:8px;}
    .orders .actions .reorder-btn{background:transparent;border:none;padding:0;font:inherit;cursor:pointer;color:var(--forest);text-decoration:underline;text-underline-offset:3px;}
    .orders .actions .reorder-btn:hover{color:var(--ink);}
    .orders .po-tag{color:var(--stone);font-size:12px;font-weight:400;}

    .dash-trust{background:var(--warm-white);border-bottom:.5px solid var(--rule);padding:14px clamp(20px,4vw,40px);}
    .dash-trust__inner{max-width:1080px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:10px 14px;font-size:13px;color:var(--stone);}
    .dash-trust__pill{font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:var(--cream);background:var(--forest);padding:5px 10px;border-radius:999px;white-space:nowrap;}
    .dash-trust__sep{color:var(--rule-strong);}
    .dash-trust__line{flex:1 1 auto;min-width:240px;font-style:italic;color:var(--stone);line-height:1.45;}
    .dash-trust__contact{font-size:12.5px;font-weight:600;color:var(--forest);text-decoration:underline;text-underline-offset:3px;white-space:nowrap;}
    .dash-trust__contact:hover{color:var(--ink);}
    .dash-trust__sub{max-width:1080px;margin:6px auto 0;font-size:11.5px;color:var(--stone);}
    @media(max-width:640px){.dash-trust__sep{display:none;}}

    .dash-welcome{border-bottom:.5px solid var(--rule);background:var(--cream);}
    .dash-welcome__inner{max-width:1080px;margin:0 auto;padding:36px 40px 30px;display:flex;justify-content:space-between;align-items:flex-end;gap:32px;}
    .dash-welcome__eyebrow{font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .dash-welcome__title{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:500;margin:10px 0 0;letter-spacing:-.01em;line-height:1.05;}
    .dash-welcome__title em{font-style:italic;}
    .dash-welcome__title br{display:none;}
    .dash-welcome__sub{color:var(--stone);margin:8px 0 0;font-size:14.5px;}
    .dash-welcome__right{text-align:right;flex-shrink:0;}
    .dash-welcome__season{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--amber);font-weight:700;}
    .dash-welcome__orderby{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:500;margin-top:4px;font-style:italic;}
    .dash-welcome__deliver{font-size:12.5px;color:var(--stone);margin-top:2px;}
    .dash-welcome__pill{display:none;}

    /* Main grid */
    .dash-main{max-width:1080px;margin:0 auto;padding:36px 40px 40px;display:grid;grid-template-columns:300px 1fr;gap:36px;align-items:start;}

    /* LEFT RAIL */
    .dash-aside{position:sticky;top:20px;display:flex;flex-direction:column;gap:18px;}

    /* Wagon card */
    .wagon-card{background:var(--ink);color:var(--cream);padding:22px 22px 24px;border-radius:3px;position:relative;overflow:hidden;}
    .wagon-card__head{display:flex;justify-content:space-between;align-items:flex-start;}
    .wagon-card__label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;opacity:.7;font-weight:600;}
    .wagon-card__title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:500;margin:4px 0 4px;line-height:1.15;}
    .wagon-card__title em{font-style:italic;}
    .wagon-card__title--small{font-size:22px;line-height:1.2;}
    .wagon-card__title--empty{font-size:24px;font-style:italic;margin:4px 0 6px;line-height:1.2;}
    .wagon-card__meta{font-size:12px;color:rgba(245,240,229,.65);margin-bottom:16px;}
    .wagon-card__meta--strong{color:rgba(245,240,229,.78);margin-bottom:6px;}
    .wagon-card__cta{display:inline-block;background:var(--cream);color:var(--ink);padding:10px 16px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border-radius:2px;border:0;cursor:pointer;font-family:inherit;transition:background 160ms ease;}
    .wagon-card__cta:hover{background:var(--warm-white);}
    .wagon-card__actions{display:flex;flex-direction:column;gap:8px;margin-bottom:10px;}
    .wagon-card__cta--solid{background:var(--cream);color:var(--ink);text-align:center;}
    .wagon-card__cta--solid:hover{background:var(--warm-white);}
    .wagon-card__cta--ghost{background:transparent;color:var(--cream);border:1px solid rgba(245,240,229,.45);text-align:center;}
    .wagon-card__cta--ghost:hover{background:rgba(245,240,229,.12);}
    .wagon-card__hint{font-size:11px;line-height:1.5;color:rgba(245,240,229,.7);margin:0;}
    .wagon-card__progress{display:flex;gap:4px;margin-bottom:14px;}
    .wagon-card__progress span{flex:1;height:3px;background:rgba(245,240,229,.25);border-radius:1px;}
    .wagon-card__progress span.is-active{background:#7a9355;}
    .wagon-card__steps{font-size:11px;color:rgba(245,240,229,.55);letter-spacing:.04em;margin-bottom:16px;}
    .wagon-card__steps strong{color:var(--cream);font-weight:700;}

    /* Account card (desktop) */
    .acct-card{background:var(--warm-white);border:.5px solid var(--rule);padding:20px 22px;border-radius:3px;}
    .acct-card__label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .acct-card__org{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:500;margin-top:6px;}
    .acct-card__lines{font-size:12.5px;color:var(--stone);line-height:1.55;margin-top:6px;}
    .acct-card__links{margin-top:14px;display:flex;flex-direction:column;gap:6px;font-size:12.5px;}
    .acct-card__links a{color:var(--forest);font-weight:600;}
    .acct-card__links a:hover{color:var(--ink);}
    .acct-card--mobile{display:none;}

    /* Open invoices card */
    .inv-card{background:var(--warm-white);border:.5px solid var(--rule);padding:16px 20px;border-radius:2px;}
    .inv-card__label{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .inv-card__amt{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;margin-top:4px;}
    .inv-card__line{font-size:12px;color:var(--stone);margin-top:2px;}
    .inv-card__line a{color:var(--forest);font-weight:600;}

    /* Support card */
    .support-card{background:var(--card-bg);padding:18px 22px;border-radius:3px;}
    .support-card__label{font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--amber);font-weight:700;}
    .support-card__body{font-size:13px;color:var(--ink);line-height:1.55;margin:8px 0 0;}
    .support-card__body span{color:var(--stone);}

    /* MAIN COLUMN */
    .dash-content{min-width:0;}

    /* Season feature */
    .season{margin-bottom:40px;}
    .season__head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:18px;border-bottom:.5px solid var(--rule-strong);padding-bottom:12px;gap:16px;}
    .season__eyebrow{font-size:10.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--amber);font-weight:700;}
    .season__title{font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:500;margin:6px 0 0;letter-spacing:-.005em;}
    .season__title em{font-style:italic;}
    .season__more{font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);font-weight:700;white-space:nowrap;}
    .season__more:hover{color:var(--ink);}
    .season__lede{color:var(--stone);font-size:14.5px;line-height:1.6;margin:0 0 24px;max-width:640px;}
    .tiles{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}

    /* Catalog tile */
    .tile{display:block;text-decoration:none;color:var(--ink);background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;overflow:hidden;transition:transform 200ms ease,box-shadow 200ms ease,border-color 200ms ease;}
    .tile:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(44,44,42,.08);border-color:var(--rule-strong);}
    .tile__art{position:relative;height:200px;overflow:hidden;}
    .tile__art--moss{background-color:#5A7240;}
    .tile__art--forest{background-color:#3B6D11;}
    .tile__art--amber{background-color:#854F0B;}
    .tile__art-overlay{position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.45) 0%,rgba(0,0,0,.12) 26%,rgba(0,0,0,0) 55%,rgba(0,0,0,0) 70%,rgba(0,0,0,.18) 100%);z-index:1;}
    .tile__art svg{position:absolute;inset:0;width:100%;height:100%;}
    .tile__section{position:absolute;top:12px;left:12px;font-size:11.5px;letter-spacing:.2em;text-transform:uppercase;color:#fff;font-weight:700;z-index:2;background:rgba(20,20,18,.62);padding:5px 10px;border-radius:3px;text-shadow:0 1px 2px rgba(0,0,0,.45);}
    .tile__body{padding:18px 20px 22px;}
    .tile__title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;margin:0;line-height:1.15;}
    .tile__blurb{color:var(--stone);font-size:13px;line-height:1.5;margin:8px 0 14px;}
    .tile__foot{display:flex;justify-content:space-between;align-items:center;border-top:.5px solid var(--rule);padding-top:12px;}
    .tile__price-label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .tile__price{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;margin-top:2px;}
    .tile__add{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);font-weight:700;}

    .season__cta-strip{margin-top:18px;padding:14px 18px;background:var(--warm-white);border:.5px dashed var(--rule-strong);border-radius:3px;}
    .season__cta-strip span{font-size:13.5px;color:var(--stone);}
    .season__cta-strip a{color:var(--forest);font-weight:700;}

    /* Orders */
    .orders-block{margin-bottom:36px;}
    .orders-block__head{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:14px;}
    .orders-block__title{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:500;margin:0;letter-spacing:-.005em;}
    .orders-block__more{font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);font-weight:700;}
    .orders-block__more:hover{color:var(--ink);}
    table.orders{width:100%;border-collapse:collapse;font-size:13.5px;}
    table.orders th{text-align:left;font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--stone);font-weight:600;padding:10px 12px;border-bottom:.5px solid var(--rule-strong);}
    table.orders td{padding:14px 12px;border-bottom:.5px solid var(--rule);vertical-align:middle;}
    table.orders td.is-id{font-weight:600;}
    .pill{display:inline-block;font-size:10.5px;font-weight:600;letter-spacing:.04em;padding:3px 10px;border-radius:999px;}
    .pill.paid{background:#e7f0e0;color:#3B6D11;}
    .pill.pending{background:#f6ecd8;color:#854F0B;}
    .pill.other{background:#e4e2dd;color:#3a3a37;}
    .pill.due{background:#f7e0c4;color:#7a3d05;}
    .lk{color:var(--forest);font-weight:600;}
    .lk:hover{color:var(--ink);}

    /* PO section */
    .po-section{background:var(--warm-white);border:.5px solid var(--rule);padding:24px 28px;border-radius:3px;}
    .po-section__inner{display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap;}
    .po-section__eyebrow{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);font-weight:600;}
    .po-section__title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:500;margin:6px 0 4px;}
    .po-section__body{color:var(--stone);font-size:13.5px;margin:0;}

    /* Buttons */
    .btn{display:inline-flex;align-items:center;gap:6px;padding:11px 22px;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;border-radius:2px;background:var(--ink);color:var(--cream);border:.5px solid var(--ink);cursor:pointer;transition:background 160ms ease,color 160ms ease,border-color 160ms ease;font-family:inherit;}
    .btn:hover{background:var(--forest);border-color:var(--forest);color:var(--cream);}

    /* Guided / empty */
    .guided{background:var(--warm-white);border:1px solid var(--rule-strong);border-left:3px solid var(--forest);border-radius:3px;padding:24px 26px;}
    .guided h3{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:22px;margin:0 0 14px;}
    .guided ol{margin:0;padding-left:20px;color:var(--ink);}
    .guided li{margin:0 0 9px;line-height:1.5;}
    .guided li a{color:var(--forest);font-weight:600;}

    /* MOBILE — single column, reorder, <details> account */
    @media (max-width: 860px){
      .dash-utility__inner{padding:8px 16px;justify-content:center;font-size:10.5px;letter-spacing:.04em;}
      .dash-utility__right{display:none;}

      .dash-welcome__inner{flex-direction:column;align-items:flex-start;gap:12px;padding:24px 16px 18px;}
      .dash-welcome__title{font-size:32px;}
      .dash-welcome__title br{display:inline;}
      .dash-welcome__right{display:none;}
      .dash-welcome__pill{display:inline-block;padding:6px 10px;background:var(--warm-white);border:.5px solid var(--rule-strong);border-radius:2px;font-size:12px;color:var(--ink);}
      .dash-welcome__pill .label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--amber);font-weight:700;margin-right:4px;}

      .dash-main{grid-template-columns:1fr;gap:16px;padding:16px;}
      .dash-aside{position:static;order:0;}
      .dash-content{order:1;}

      /* Hide desktop account card on mobile, show <details> variant */
      .acct-card{display:none;}
      .acct-card--mobile{display:block;background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:14px 16px;}
      .acct-card--mobile > summary{cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;}
      .acct-card--mobile > summary::-webkit-details-marker{display:none;}
      .acct-card--mobile > summary::marker{content:'';}
      .acct-card--mobile .indicator{color:var(--stone);font-size:18px;line-height:1;transition:transform 160ms ease;}
      .acct-card--mobile[open] .indicator{transform:rotate(45deg);}
      .acct-card--mobile .body{margin-top:12px;font-size:12.5px;color:var(--stone);line-height:1.55;}
      .acct-card--mobile .body .links{margin-top:10px;display:flex;flex-direction:column;gap:6px;}
      .acct-card--mobile .body .links a{color:var(--forest);font-weight:600;}

      /* Wagon CTA full-width on mobile */
      .wagon-card{padding:18px 18px 20px;}
      .wagon-card__title{font-size:24px;}
      .wagon-card__cta{display:block;text-align:center;padding:12px 14px;}

      .season__head{flex-direction:column;align-items:flex-start;gap:8px;}
      .season__title{font-size:24px;}
      .tiles{grid-template-columns:1fr;gap:10px;}

      /* Mobile catalog tiles become horizontal cards */
      .tile{display:flex;min-height:96px;}
      .tile__art{height:auto;width:110px;flex-shrink:0;}
      .tile__art svg{display:none;}
      .tile__section{font-size:9.5px;letter-spacing:.16em;line-height:1.2;top:10px;left:10px;right:10px;}
      .tile__body{flex:1;padding:12px 14px;display:flex;flex-direction:column;justify-content:space-between;}
      .tile__title{font-size:17px;line-height:1.2;}
      .tile__blurb{display:none;}
      .tile__foot{border-top:0;padding-top:0;align-items:baseline;margin-top:8px;}
      .tile__price-label{display:none;}
      .tile__price{font-size:16px;margin-top:0;}
      .tile__add{font-size:10px;}

      .season__more{display:none;}
      .season__more--mobile{display:block;text-align:center;margin-top:12px;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--forest);font-weight:700;padding:12px 0;border:.5px solid var(--rule-strong);border-radius:2px;}

      /* Orders as cards on mobile */
      .orders-block__title{font-size:22px;}
      table.orders thead{display:none;}
      table.orders,table.orders tbody{display:block;}
      table.orders tr{display:block;background:var(--warm-white);border:.5px solid var(--rule);border-radius:3px;padding:14px 16px;margin-bottom:8px;}
      table.orders td{display:block;padding:3px 0;border:0;}
      table.orders td.is-id{font-size:14px;font-weight:700;margin-bottom:2px;display:inline-block;}
      table.orders td:nth-child(5){display:inline-block;float:right;font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:500;}

      .po-section{padding:18px 18px 20px;}
      .po-section__inner{flex-direction:column;align-items:stretch;}
      .po-section .btn{display:block;text-align:center;}
    }
    .season__more--mobile{display:none;}
  </style>
</head>
<body>

  {%- comment -%}Utility bar — black strip above the header section{%- endcomment -%}
  <div class="dash-utility">
    <div class="dash-utility__inner">
      <div class="dash-utility__left">Approved educator portal &middot; Net-30 / Net-60 available</div>
      <div class="dash-utility__right"><a href="mailto:educators@mytoywagon.com">educators@mytoywagon.com</a> &middot; (626) 841-0421</div>
    </div>
  </div>

  {% section 'mtw-educator-header' %}

  {%- liquid
    # ---- Season / window copy (no countdown — design team rejected it) ----
    assign now_month = 'now' | date: '%m' | plus: 0
    assign now_year = 'now' | date: '%Y' | plus: 0
    assign es = shop.metafields.educator.settings.value
    if now_month >= 1 and now_month <= 6
      assign edu_window = es.fall_window | default: 'August–September' | append: ' ' | append: now_year
      assign edu_orderby_label = es.fall_order_by | default: 'July 15'
      assign edu_season_label = 'Fall'
    else
      assign ny = now_year | plus: 1
      assign edu_window = es.spring_window | default: 'May–June' | append: ' ' | append: ny
      assign edu_orderby_label = es.spring_order_by | default: 'March 15'
      assign edu_season_label = 'Spring'
    endif

    # ---- Open invoices (unpaid orders) ----
    # Skip cancelled, refunded, voided, partially-refunded — those aren't
    # "open" obligations even if financial_status != 'paid'.
    assign open_count = 0
    assign open_total = 0
    assign first_open_order_name = ''
    assign first_open_order_url = ''
    for o in customer.orders limit: 50
      assign o_skip = false
      if o.cancelled_at != blank
        assign o_skip = true
      elsif o.financial_status == 'refunded' or o.financial_status == 'voided' or o.financial_status == 'partially_refunded'
        assign o_skip = true
      endif
      unless o_skip
        assign o_paid = false
        if o.financial_status == 'paid' or o.tags contains 'po-paid-external'
          assign o_paid = true
        endif
        unless o_paid
          assign open_count = open_count | plus: 1
          assign open_total = open_total | plus: o.total_price
          if first_open_order_name == ''
            assign first_open_order_name = o.name
            assign first_open_order_url = o.customer_url
          endif
        endunless
      endunless
    endfor

    # ---- Wagon state ----
    # 'empty'    - no cart items AND no open_quote_id
    # 'draft'    - cart has items (regardless of quote state)
    # 'awaiting' - cart empty AND customer has educator.open_quote_id set
    # open_quote_id is written by staff in admin after replying with the
    # formal quote (Customer record → Metafields → educator.open_quote_id).
    # Pre-staff-update, the dashboard JS reads localStorage as a fallback
    # so educators see the Awaiting-PO state immediately after submit.
    assign open_quote_id = customer.metafields.educator.open_quote_id | default: ''
    assign wagon_state = 'empty'
    if cart.item_count > 0
      assign wagon_state = 'draft'
    elsif open_quote_id != ''
      assign wagon_state = 'awaiting'
    endif

    # ---- Org name ----
    # Fallback chain: B2B current_company → Helium customer_fields metafield
    # → educator namespace fallback → blank (welcome line drops the org).
    assign org_name = ''
    if customer.b2b? and customer.current_company != blank
      assign org_name = customer.current_company.name
    endif
    if org_name == ''
      assign org_name = customer.metafields.customer_fields.institution_name | default: customer.metafields.educator.institution_name | default: ''
    endif

    # ---- Terms line ----
    # B2B customers have Net-30/60 set up on the Shopify company record.
    # Non-B2B approved educators don't until staff creates a Company for them
    # (which happens on first PO/Net-30 request, per the runbook). So show
    # "Net-30 on file" only when it's actually true.
    assign terms_line = 'Approved educator'
    if customer.b2b?
      assign terms_line = 'Approved educator &middot; Net-30 / Net-60 on file'
    endif

    # ---- Tax-exempt status (committed source of truth = customer tags) ----
    # tax-exempt-verified -> active; tax-exempt-pending -> under review;
    # neither -> prompt to submit a cert on /pages/tax-exempt-upload.
    assign tax_state = 'none'
    if customer.tags contains 'tax-exempt-verified'
      assign tax_state = 'verified'
    elsif customer.tags contains 'tax-exempt-pending'
      assign tax_state = 'pending'
    endif

    # ---- Featured catalog tiles ----
    # Source of truth: shop.metafields.educator.featured_handles (list of 3 product handles).
    # Fallback: empty list → generic browse-the-catalog tile.
    assign featured_handles = shop.metafields.educator.featured_handles.value
    assign hue_classes = 'tile__art--moss,tile__art--forest,tile__art--amber' | split: ','
    assign section_labels = 'Sensory Play,Woodland,Nature Play' | split: ','
  -%}

  {%- comment -%}Welcome bar{%- endcomment -%}
