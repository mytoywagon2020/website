      <div>
        <div class="dash-welcome__eyebrow">Educator dashboard</div>
        <h1 class="dash-welcome__title">
          Welcome back,<br/>{% if customer.first_name != blank %}<em>{{ customer.first_name }}</em>{% else %}<em>educator</em>{% endif %}.
        </h1>
        <p class="dash-welcome__sub">
          {%- if org_name != '' %}{{ org_name }} &middot; {% endif -%}
