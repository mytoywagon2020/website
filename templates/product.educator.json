{%- endif -%}<span class='mpm-ct'>{{ rp.title }}</span><span class='mpm-cp'>{{ rp.price | money }}</span></a>{%- endfor -%}</div></div>{%- endif -%}</div><style>.mpm{font-family:Mulish,sans-serif;margin:16px 0;}.mpm-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px 28px;padding:18px 0;border-top:1px solid rgba(159,79,97,.22);border-bottom:1px solid rgba(159,79,97,.22);}.mpm-cell{display:flex;flex-direction:column;gap:3px;}.mpm-lbl{font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:#9a8f86;}.mpm-val{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:17px;color:#2C2C2A;line-height:1.4;}.mpm-safety{padding:14px 0;border-bottom:1px solid rgba(159,79,97,.22);}.mpm-sval{display:block;font-size:13px;line-height:1.6;color:#2C2C2A;margin-top:5px;}.mpm-tags{padding:16px 0;}.mpm-pills{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;}.mpm-pill{font-size:11.5px;padding:6px 13px;border-radius:999px;background:#EFEADD;color:#3B4A2F;}.mpm-extend{padding:16px 0;border-top:1px solid rgba(159,79,97,.22);}.mpm-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:14px;margin-top:12px;}.mpm-card{display:flex;flex-direction:column;gap:6px;text-decoration:none;color:#2C2C2A;}.mpm-card img{width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:2px;}.mpm-ct{font-size:12.5px;line-height:1.3;}.mpm-cp{font-size:12px;color:#5F5E5A;}</style>{%- endif -%}"
