/* ----------------------- OUTFIT YOUR CLASSROOM ----------------------- */
.outfit{
  background: var(--cream);
  padding: clamp(56px, 8vw, 92px) 0;
  position: relative;
}
.outfit .head{
  max-width: 1340px;
