/* ----------------------- B2B PRICE BLOCK (gallery cards + general) ----------------------- */
.price-block{
  display: inline-flex;
  align-items: baseline;
  gap: 10px;
  margin-top: 6px;
}

/* ----------------------- ADD TO CART (per product card) ----------------------- */
