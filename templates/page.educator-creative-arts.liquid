/* ----------------------- HOW IT WORKS (friction-reduction strip) ----------------------- */
.how-it-works{
  background: var(--card-bg);
  border-top: 0.5px solid var(--rule);
  border-bottom: 0.5px solid var(--rule);
}
.how-it-works-inner{
  max-width: 1340px;
  margin: 0 auto;
  padding: 56px clamp(20px, 5vw, 56px);
}
.how-head{
  display: grid;
  grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  gap: 56px;
  align-items: end;
  margin-bottom: 36px;
  padding-bottom: 28px;
  border-bottom: 0.5px solid var(--rule);
}
.how-head .eyebrow{ color: var(--accent-deep); margin-bottom: 18px; display: inline-block; }
.how-head h3{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(28px, 3.2vw, 42px);
  line-height: 1.05;
  letter-spacing: -.005em;
}
.how-head h3 .it{ color: var(--accent-deep); }
.how-head p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 42ch;
}
.steps{
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
}
.step{
  padding: 0 32px 0 0;
  border-right: 0.5px solid var(--rule);
}
.step:last-child{ border-right: 0; padding-right: 0; }
.step:nth-child(n+2){ padding-left: 32px; }
.step .num{
  font-family: var(--serif);
  font-style: italic;
  font-size: 38px;
  line-height: 1;
  color: var(--accent-deep);
