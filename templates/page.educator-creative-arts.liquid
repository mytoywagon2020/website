  <div class="wrap">
    <div class="col-img">
      <div class="tile t-hue3 has-photo"><img src="https://cdn.shopify.com/s/files/1/0522/0882/8586/files/weavingstation_b780a863-8811-4c8e-bcfb-7e671c1bda72.png?v=1688516804&amp;width=1100" style="object-position: center 30%;" alt="A young girl weaving on a wooden weaving station for classroom creative-arts and the slow work of making"/>
