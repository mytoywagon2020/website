  .step{ border-right: 0; border-bottom: 0.5px solid var(--rule); padding: 0 0 24px 0 !important; }
  .step:last-child{ border-bottom: 0; padding-bottom: 0 !important; }
}
.price-policy{
  background: var(--card-bg);
