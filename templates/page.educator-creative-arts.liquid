}
.outfit .head h2{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(40px, 5.4vw, 88px);
  line-height: 1.0;
  letter-spacing: -.008em;
  color: var(--ink);
}
.outfit .head h2 .it{ color: var(--accent-deep); }
.outfit .head .right p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 20px;
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 42ch;
}
.outfit .head .right .meta{
  margin-top: 18px;
  font-family: var(--mono);
  font-size: 10.5px;
  letter-spacing: .08em;
  color: var(--stone);
}
.outfit .kits{
  max-width: 1340px;
  margin: 64px auto 0;
