  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.companions .folk .f{
  display: flex;
  flex-direction: column;
}
.companions .folk .f .tile{
  position: relative;
  aspect-ratio: 1 / 1.1;
  width: 100%;
}
.companions .folk .f .name{
  position: static;
  margin: 12px 0 0;
  text-shadow: none;
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  color: var(--cream);
  line-height: 1.2;
  text-align: left;
