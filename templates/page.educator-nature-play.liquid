  margin: 0 auto 28px;
}

/* ----------------------- OUTFIT YOUR CLASSROOM ----------------------- */
.outfit{
  background: var(--cream);
  padding: clamp(56px, 8vw, 92px) 0;
  position: relative;
}
.outfit .head{
  max-width: 1340px;
  margin: 0 auto;
  padding: 0 clamp(20px, 5vw, 56px) 56px;
  display: grid;
  grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
  gap: 64px;
  align-items: end;
  border-bottom: 0.5px solid var(--rule);
}
.outfit .head h2{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(40px, 5.4vw, 88px);
  line-height: 1.0;
  letter-spacing: -.008em;
  color: var(--ink);
}
.outfit .head h2 .it{ color: var(--accent-deep); }
.outfit .head .right p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 20px;
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 42ch;
}
.outfit .head .right .meta{
  margin-top: 18px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .08em;
  color: var(--stone);
}
.outfit .kits{
  max-width: 1340px;
  margin: 64px auto 0;
  padding: 0 clamp(20px, 5vw, 56px);
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 24px;
}
.outfit .kit{
  background: var(--card-bg);
  border: 0.5px solid var(--rule);
  border-radius: 2px;
  padding: 40px 34px 32px;
  display: flex;
  flex-direction: column;
  position: relative;
  transition: transform .25s ease, border-color .25s ease;
}
.outfit .kit:hover{ transform: translateY(-3px); border-color: var(--rule-strong); }
.outfit .kit.featured{
  background: var(--accent-pale);
  border-color: color-mix(in oklab, var(--accent-soft) 80%, transparent);
}
.outfit .kit .pill{
  position: absolute;
  top: -12px;
  right: 24px;
}
.outfit .kit .tier{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 16px;
}
.outfit .kit h3{
  margin: 0 0 6px;
  font-family: var(--serif);
  font-weight: 500;
  font-size: 30px;
  line-height: 1.1;
  letter-spacing: -.005em;
  color: var(--ink);
}
.outfit .kit .sub{
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  color: var(--accent-deep);
  line-height: 1.4;
}
.outfit .kit .hair{
  width: 40px; height: 1px;
  background: var(--ink);
  opacity: .3;
  margin: 24px 0 22px;
}
.outfit .kit .desc{
  font-size: 14px;
  line-height: 1.65;
  color: var(--ink-soft);
  margin: 0 0 22px;
  max-width: 38ch;
}
.outfit .kit ul.contains{
  list-style: none;
  margin: 0 0 28px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1;
}
.outfit .kit ul.contains li{
  font-family: var(--serif);
  font-style: italic;
  font-size: 16px;
  line-height: 1.45;
  color: var(--ink);
  padding-left: 18px;
  position: relative;
}
.outfit .kit ul.contains li::before{
  content: "";
  position: absolute;
  left: 0; top: 11px;
  width: 9px; height: 1px;
  background: var(--accent);
}
.outfit .kit .price-line{
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
  margin-bottom: 18px;
  padding-top: 18px;
  border-top: 0.5px solid var(--rule-strong);
}
.outfit .kit .kit-cta{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  padding-bottom: 4px;
  border-bottom: 0.5px solid var(--ink);
  align-self: flex-start;
  transition: color .2s ease, border-color .2s ease;
}
.outfit .kit .kit-cta:hover{ color: var(--forest); border-color: var(--forest); }
.outfit .kit.featured .kit-cta{ color: var(--accent-deep); border-color: var(--accent-deep); }
.outfit .kit.featured .kit-cta:hover{ color: var(--ink); border-color: var(--ink); }

.outfit .note{
  max-width: 1340px;
  margin: 56px auto 0;
  padding: 0 clamp(20px, 5vw, 56px);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}
.outfit .note .left{
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  color: var(--ink-soft);
  max-width: 56ch;
}
.outfit .note .right{
  display: inline-flex;
  align-items: center;
  gap: 14px;
}
@media (max-width: 1080px){
  .outfit .head{ grid-template-columns: 1fr; gap: 32px; }
  .outfit .note{ flex-direction: column; align-items: flex-start; }
}

/* ----------------------- CONTAINER ----------------------- */
.wrap{ max-width: 1340px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 56px); }
.wrap-wide{ max-width: 1500px; margin: 0 auto; padding: 0 clamp(20px, 5vw, 56px); }
.gut{   padding-top: clamp(56px, 8vw, 92px); padding-bottom: clamp(56px, 8vw, 92px); }
.gut-sm{ padding-top: clamp(40px, 5vw, 64px);  padding-bottom: clamp(40px, 5vw, 64px); }

/* ============================== COVER ============================== */
.cover{
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  margin: 0 auto;
  max-width: 1440px;
  min-height: min(82vh, 760px);
  padding: clamp(48px, 7vw, 96px);
  overflow: hidden;
  isolation: isolate;
}
.cover > h1,
.cover > .cover-subtitle,
.cover > .footer{ width: 100%; max-width: 680px; }
.cover .bg{ position:absolute; inset:0; z-index:0; }
.cover .veil{
  position:absolute; inset:0; z-index:1; pointer-events:none;
  background:
    linear-gradient(90deg, rgba(18,16,11,.50) 0%, rgba(18,16,11,.37) 32%, rgba(18,16,11,.16) 52%, rgba(18,16,11,.03) 72%, rgba(18,16,11,0) 88%);
}
.cover .frame{
  position:absolute; inset:28px; z-index:2; pointer-events:none;
  border: 1px solid rgba(250,246,237,.32);
}
.cover .head{ display: none; }
.cover .head .vol{ text-align:right; }
.cover .head .vol .num{
  font-family: var(--serif); font-style: italic;
  font-size: clamp(48px, 5.6vw, 88px); line-height: 1;
}
.cover h1{
  position: relative;
  z-index: 3;
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  color: var(--cream);
  font-size: clamp(48px, 8vw, 132px);
  line-height: .94;
  letter-spacing: -.012em;
  text-shadow: 0 2px 24px rgba(0,0,0,.7), 0 1px 4px rgba(0,0,0,.5);
}
.cover h1 .it{
  display: block;
  font-style: italic;
  color: color-mix(in oklab, var(--accent-soft) 80%, white);
}
.cover .cover-subtitle{
  position: relative;
  z-index: 3;
  margin: 22px 0 0;
  max-width: 60ch;
  font-family: var(--sans);
  font-size: clamp(14px, 1.4vw, 17px);
  line-height: 1.55;
  font-weight: 500;
  letter-spacing: .01em;
  color: rgba(250,246,237,.96);
  text-shadow: 0 1px 3px rgba(0,0,0,.95), 0 1px 14px rgba(0,0,0,.85);
}
.cover .footer{
  position: relative;
  z-index: 3;
  width: 100%;
  margin-top: 28px;
  color: var(--cream);
  text-shadow: 0 1px 3px rgba(0,0,0,.95), 0 1px 14px rgba(0,0,0,.85);
  display: flex; justify-content: flex-start; align-items: flex-end; gap: 24px;
}
.cover .audience{ max-width: 540px; }
.cover .audience .label{ color: rgba(250,246,237,.96); text-shadow: 0 1px 8px rgba(0,0,0,.55); }
.cover .audience p{
  margin-top: 8px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  line-height: 1.4;
  color: var(--cream);
}
.cover .scroll{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .14em;
  color: rgba(250,246,237,.85);
  text-align:right;
}
.cover .scroll .dot{
  display:inline-block; width:6px; height:6px; border-radius:50%;
  background: var(--cream); margin-left: 10px; vertical-align: middle;
  animation: pulse 2.4s ease-in-out infinite;
}
@keyframes pulse{ 0%,100%{ opacity:.35 } 50%{ opacity:1 } }

/* ============================== ANCHOR ============================== */
.anchor{
  background: var(--cream);
  border-top: 1px solid var(--rule-soft);
  border-bottom: 1px solid var(--rule-soft);
  position: relative;
}
.anchor .wrap{
  display: grid;
  grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
  gap: 80px;
  align-items: center;
}
.anchor .vol-numeral{
  position: absolute;
  right: clamp(20px, 5vw, 56px);
  top: -30px;
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent-soft);
  font-size: clamp(120px, 16vw, 220px);
  line-height: .8;
  pointer-events: none;
  user-select: none;
  z-index: 0;
}
.anchor h2{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(40px, 5.8vw, 96px);
  line-height: 1.02;
  letter-spacing: -.008em;
  position: relative; z-index: 1;
}
.anchor h2 .it{ color: var(--accent-deep); }
.anchor h2 .quote-open,
.anchor h2 .quote-close{
  font-family: var(--serif);
  font-style: italic;
  color: var(--accent);
  font-size: 1.2em;
  line-height: 0;
  position: relative;
  top: .08em;
}
.anchor .side{
  display: flex; flex-direction: column; gap: 22px;
  border-left: 1px solid var(--rule-soft);
  padding-left: 44px;
}
.anchor .side .eyebrow{ color: var(--ink-soft); }
.anchor .side p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 21px;
  line-height: 1.5;
  color: var(--ink-soft);
}

/* ============================== EDITORIAL INTRO ============================== */
.intro{ background: var(--card-bg); }
.intro .wrap{
  display: grid;
  grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  gap: 72px;
  align-items: stretch;
}
.intro .col-img{ }
.intro .col-img .tile{ height: 100%; min-height: 420px; }
.intro .col-txt{
  display: flex; flex-direction: column; justify-content: center;
  padding: 12px 0;
}
.intro .col-txt .eyebrow{ color: var(--accent-deep); margin-bottom: 28px; }
.intro .col-txt h3{
  margin: 0 0 36px;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(32px, 3.8vw, 56px);
  line-height: 1.08;
  letter-spacing: -.004em;
}
.intro .col-txt h3 .it{ color: var(--accent-deep); }
.intro .body{
  font-size: 17px;
  line-height: 1.78;
  max-width: 56ch;
}
.intro .body p{ margin: 0 0 18px; }
.intro .body .dropcap{
  float: left;
  font-family: var(--serif);
  font-style: italic;
  font-size: 92px;
  line-height: .78;
  color: var(--accent);
  padding: 8px 14px 0 0;
}
.intro .body .triplet{
  font-family: var(--serif);
  font-style: italic;
  color: var(--ink);
  font-size: 19px;
  line-height: 1.55;
}
.intro .pillars{
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  margin-top: 44px;
  padding-top: 28px;
  border-top: 1px solid var(--rule-soft);
}
.intro .pillars .p .label{ color: var(--accent-deep); display:block; margin-bottom: 8px; }
.intro .pillars .p p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  line-height: 1.45;
  color: var(--ink-soft);
}

/* ============================== FEATURE STAGE ============================== */
.stage{
  position: relative;
  height: 64vh;
  min-height: 540px;
  max-height: 800px;
  color: var(--cream);
  overflow: hidden;
}
.stage .bg{ position: absolute; inset: 0; z-index: 0; }
.stage .veil{
  position: absolute; inset: 0; z-index: 1;
  background:
    linear-gradient(90deg, rgba(20,10,6,.55) 0%, rgba(20,10,6,0) 48%),
    linear-gradient(180deg, rgba(20,10,6,.16) 0%, rgba(20,10,6,0) 32%, rgba(20,10,6,.6) 100%);
}
.stage .content{
  position: relative; z-index: 2;
  height: 100%;
  padding: clamp(56px, 8vh, 100px) clamp(28px, 5vw, 80px);
  display: grid; grid-template-rows: auto 1fr auto; gap: 24px;
}
.stage .top{ display:flex; justify-content: space-between; align-items: flex-start; gap: 24px; }
.stage .top .eyebrow{ color: var(--accent-soft); }
.stage .top .right{ text-align: right; }
.stage .top .right .label{ color: rgba(250,246,237,.62); }
.stage .top .right .name{ font-family: var(--serif); font-style: italic; font-size: 17px; margin-top: 6px; }
.stage .mid{ align-self: end; max-width: 980px; }
.stage h2{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(56px, 7.6vw, 128px);
  line-height: .94;
  letter-spacing: -.012em;
}
.stage h2 .it{
  display: block;
  font-style: italic;
  color: color-mix(in oklab, var(--accent-soft) 85%, white);
}
.stage .lede{
  margin: 28px 0 0;
  max-width: 640px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  line-height: 1.5;
  color: rgba(250,246,237,.88);
}
.stage .bot{ display: flex; align-items: flex-end; justify-content: flex-start; }

/* ----------- Button ----------- */
.btn{
  display:inline-flex; align-items:center; gap:14px;
  font-family: var(--sans);
  font-weight: 600;
  font-size: 12px;
  letter-spacing: .18em;
  text-transform: uppercase;
  background: var(--cream);
  color: var(--ink);
  border: 1px solid var(--cream);
  border-radius: 2px;
  padding: 16px 28px;
  text-decoration: none;
  transition: background .25s ease, color .25s ease, border-color .25s ease;
}
.btn:hover{ background: var(--accent); border-color: var(--accent); color: var(--cream); }
.btn .arrow{
  display:inline-block; width: 22px; height: 1px; background: currentColor; position: relative;
}
.btn .arrow::after{
  content:""; position: absolute; right: 0; top: -3px;
  width: 7px; height: 7px;
  border-top: 1px solid currentColor; border-right: 1px solid currentColor; transform: rotate(45deg);
}
.btn.ink{ background: var(--ink); color: var(--cream); border-color: var(--ink); }
.btn.ink:hover{ background: var(--accent-deep); border-color: var(--accent-deep); color: var(--cream); }
.btn.ghost{ background: transparent; color: var(--cream); border-color: rgba(250,246,237,.5); }
.btn.ghost:hover{ background: var(--cream); color: var(--ink); border-color: var(--cream); }

/* ============================== FEATURE SPLIT (CONTENTS) ============================== */
.split{
  display: grid;
  grid-template-columns: 1fr 1fr;
  background: var(--accent-pale);
  min-height: 72vh;
}
.split .img-side{ position: relative; min-height: 480px; }
.split .img-side .tile{ position: absolute; inset: 0; }
.split .img-side::after{
  content:""; position:absolute; inset:0; pointer-events:none;
  background: linear-gradient(to right, transparent 60%, color-mix(in oklab, var(--accent) 25%, transparent));
}
.split .content{
  padding: clamp(56px, 8vw, 120px) clamp(36px, 6vw, 96px);
  display: flex; flex-direction: column; justify-content: center;
  position: relative;
}
.split .content::before{
  content:""; position:absolute; top: 44px; right: 44px;
  width: 48px; height: 48px;
  border-top: 1px solid var(--gilt); border-right: 1px solid var(--gilt);
  opacity: .55;
}
.split .content .eyebrow{ color: var(--accent-deep); margin-bottom: 24px; }
.split .content h3{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(30px, 3.6vw, 52px);
  line-height: 1.1;
  letter-spacing: -.005em;
}
.split .content .sub{
  margin-top: 6px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  color: var(--accent-deep);
}
.split .content .hair{
  width: 56px; height: 1px; background: var(--accent);
  opacity: .5; margin: 32px 0;
}
.split .content .desc{
  font-family: var(--serif);
  font-size: clamp(17px, 1.4vw, 19px);
  line-height: 1.78;
  color: var(--ink-soft);
  max-width: 56ch;
}
.split .content .contents-list{
  list-style: none; padding: 0; margin: 28px 0 0;
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px 28px;
}
.split .content .contents-list li{
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  line-height: 1.5;
  color: var(--ink);
  padding-left: 20px;
  position: relative;
}
.split .content .contents-list li::before{
  content: ""; position: absolute; left: 0; top: 12px;
  width: 10px; height: 1px; background: var(--accent);
}
.split .content .craft{
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
  margin-top: 36px;
  padding-top: 28px;
  border-top: 1px solid rgba(159,79,97,.22);
}
.split .content .craft .label{ color: var(--muted); display:block; margin-bottom: 8px; font-size: 11px; }
.split .content .craft .v{
  font-family: var(--serif);
  font-style: italic;
  font-size: 17px;
  line-height: 1.45;
  color: var(--ink);
}
.split .content .craft .v.plain{ font-family: var(--sans); font-style: normal; font-size: 13px; color: var(--ink-soft); line-height: 1.55; }
.split .content .testimony{
  margin-top: 36px;
  padding-top: 28px;
  border-top: 1px solid rgba(159,79,97,.22);
}
.split .content .testimony .quote{
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(19px, 1.6vw, 22px);
  line-height: 1.5;
  color: var(--ink);
  max-width: 56ch;
}
.split .content .testimony .attr{
  margin-top: 18px;
  display: flex; align-items: center; gap: 14px;
}
.split .content .testimony .attr .dash{ display:inline-block; width: 36px; height: 1px; background: var(--accent); }
.split .content .testimony .attr .name{
  font-family: var(--sans);
  font-size: 12px; letter-spacing: .16em; text-transform: uppercase; color: var(--ink-soft);
}
.split .content .testimony .attr .name b{ color: var(--ink); font-weight: 700; }
.split .content .ctas{ margin-top: 40px; display: flex; flex-wrap: wrap; gap: 16px 22px; align-items: center; }
.split .content .ctas .price{
  font-family: var(--serif);
  font-style: italic;
  font-size: 16px;
  color: var(--ink-soft);
}
.split .content .ctas .btn{ background: var(--ink); color: var(--cream); border-color: var(--ink); }
.split .content .ctas .btn:hover{ background: var(--accent-deep); border-color: var(--accent-deep); }

/* Pairs with, cross-sell block inside Feature Split */
.pairs-with{
  margin-top: 28px;
  padding-top: 22px;
  border-top: 0.5px solid var(--rule);
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px 18px;
  align-items: center;
}
.pairs-with .label{
  grid-column: 1 / -1;
  font-family: var(--sans);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 8px;
  padding: 4px 10px;
  background: color-mix(in oklab, var(--accent) 8%, transparent);
  border-left: 2px solid var(--accent);
  display: inline-block;
  width: auto;
  justify-self: start;
  border-radius: 0 2px 2px 0;
}
.pairs-with .pair-thumb{
  width: 88px; height: 88px;
  background: var(--accent-pale);
  border-radius: 2px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pairs-with .pair-thumb img{ width: 100%; height: 100%; object-fit: contain; padding: 6px; }
.pairs-with .pair-body{ display: flex; flex-direction: column; gap: 4px; }
.pairs-with .pair-body h4{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 19px;
  line-height: 1.25;
  letter-spacing: -.005em;
  color: var(--ink);
}
.pairs-with .pair-body p{
  margin: 0;
  font-family: var(--sans);
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-soft);
}
.pairs-with .pair-body .pair-meta{
  font-family: var(--sans);
  font-size: 13px;
  color: var(--ink);
}
.pairs-with .pair-body .pair-meta strong{ font-weight: 600; margin-right: 8px; }
.pairs-with .pair-body .pair-action{
  margin-top: 8px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 0.5px solid var(--ink);
  padding-bottom: 2px;
  align-self: flex-start;
}
.pairs-with .pair-body .pair-action:hover{ color: var(--forest); border-color: var(--forest); }

/* ============================== DETAIL SPREAD ============================== */
.spread{
  background: var(--ink);
  color: var(--cream);
  padding: clamp(72px, 10vw, 120px) clamp(28px, 5vw, 80px);
}
.spread .row{
  display: grid;
  grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
  gap: 72px;
  align-items: start;
}
.spread h3{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(30px, 3.6vw, 52px);
  line-height: 1.05;
}
.spread h3 .it{ color: color-mix(in oklab, var(--accent-soft) 80%, white); }
.spread .head .eyebrow{ color: var(--accent-soft); margin-bottom: 22px; }
.spread .head p.sub{
  margin-top: 22px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 19px;
  line-height: 1.55;
  color: rgba(250,246,237,.66);
  max-width: 38ch;
}
.spread .crops{
  display: grid;
  grid-template-columns: 1.3fr .9fr .9fr;
  grid-auto-rows: 220px;
  gap: 16px;
}
.spread .crops .tile{ width: 100%; height: 100%; }
.spread .learn{
  margin-top: 56px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 1px solid rgba(250,246,237,.2);
  border-bottom: 1px solid rgba(250,246,237,.2);
}
.spread .learn .l{
  padding: 24px 22px;
  border-right: 1px solid rgba(250,246,237,.12);
}
.spread .learn .l:last-child{ border-right: 0; }
.spread .learn .num{
  font-family: var(--serif);
  font-style: italic;
  font-size: 28px;
  line-height: 1;
  color: color-mix(in oklab, var(--accent-soft) 80%, white);
  margin-bottom: 14px;
}
.spread .learn .name{
  font-family: var(--serif);
  font-size: 22px;
  line-height: 1.15;
}
.spread .learn .desc{
  margin-top: 8px;
  font-size: 13px;
  color: rgba(250,246,237,.66);
  line-height: 1.55;
}

/* ============================== GALLERY ============================== */
.gallery{
  background: linear-gradient(180deg, var(--cream) 0%, var(--accent-pale) 100%);
  position: relative;
  overflow: hidden;
}
.gallery .head{
  display: grid;
  grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
  gap: 72px;
  align-items: end;
  padding-bottom: 56px;
  border-bottom: 1px solid var(--rule-soft);
}
.gallery .head .eyebrow{ color: var(--accent-deep); margin-bottom: 22px; display:inline-block; }
.gallery .head h2{
  margin: 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(44px, 6vw, 96px);
  line-height: .98;
  letter-spacing: -.008em;
}
.gallery .head h2 .it{ color: var(--accent-deep); }
.gallery .head .right p{
  margin: 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 21px;
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 40ch;
}
.gallery .head .index{
  margin-top: 18px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .08em;
  color: var(--ink-soft);
}
.homes{
  margin-top: 56px;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 24px;
}
.home{ position: relative; }
.home .tile-wrap{
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: 2px;
  aspect-ratio: 1 / 1;
}
.home .tile-wrap .tile{ width: 100%; height: 100%; min-height: 0; }
.home .tile-wrap .overlay{
  position: absolute; inset: 0; z-index: 4; pointer-events: none;
  background: linear-gradient(to top, rgba(44,26,14,.65) 0%, rgba(44,26,14,0) 45%);
  opacity: 0;
  transition: opacity .35s ease;
}
.home .tile-wrap .float-name{
  position: absolute; left: 22px; right: 22px; bottom: 22px; z-index: 5;
  font-family: var(--serif);
  font-size: 22px;
  line-height: 1.15;
  color: var(--cream);
  text-shadow: 0 1px 12px rgba(0,0,0,.35);
  transform: translateY(8px);
  opacity: 0;
  transition: opacity .35s ease, transform .35s ease;
}
.home:hover .tile-wrap .overlay{ opacity: 1; }
.home:hover .tile-wrap .float-name{ opacity: 1; transform: translateY(0); }
.home .cap{
  margin-top: 18px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.home .cap .no{
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px;
  line-height: 1;
  color: var(--accent-deep);
}
.home .cap .name{
  font-family: var(--serif);
  font-size: 22px;
  line-height: 1.15;
  letter-spacing: -.004em;
  color: var(--ink);
  margin-top: 2px;
}
.home .cap .desc{
  font-size: 13px;
  line-height: 1.5;
  color: var(--ink-soft);
  margin: 6px 0 4px;
}
.home .cap .price{
  font-size: 22px;
  margin: 6px 0 0;
}
.home .cap .stock-pill{
  align-self: flex-start;
  margin: 2px 0;
}
.home .cap .add-row{
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 10px;
}
.home .cap .add-btn{ flex-shrink: 0; padding: 9px 14px; font-size: 11px; }
.home .cap .view-pdp{ font-size: 11px; white-space: nowrap; }

/* Footer alignment, pushes SKU + price + add-row to the bottom of every
   card so they line up horizontally across the grid row even when desc
   lengths vary. The .meta SKU line is the footer starter and absorbs
   the vertical slack via margin-top:auto. Subtle hairline divides the
   editorial description from the procurement footer. */
.home{ display: flex; flex-direction: column; height: 100%; }
.home .cap{ flex: 1 1 auto; }
.home .cap > .meta{
  margin-top: auto;
  padding-top: 14px;
  border-top: 0.5px solid var(--rule);
  font-family: var(--sans);
  font-weight: 500;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--stone);
  display: block;
}
.home .cap .price{
  grid-column: 2;
  margin-top: 4px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .08em;
  color: var(--accent-deep);
}
.home .cap .tags{
  grid-column: 2;
  display:flex; flex-wrap: wrap; gap: 8px;
}
.home .cap .tags .t{
  font-family: var(--sans);
  font-size: 10px;
  letter-spacing: .16em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--accent-deep);
  padding: 4px 9px;
  border: 1px solid color-mix(in oklab, var(--accent-deep) 35%, transparent);
  border-radius: 2px;
}

/* legacy size-X classes are no-ops now, all gallery cards uniform */
.home.size-hero,
.home.size-tall,
.home.size-std,
.home.size-wide{ grid-column: span 1; }
.home.size-hero .tile-wrap .tile,
.home.size-tall .tile-wrap .tile,
.home.size-std .tile-wrap .tile,
.home.size-wide .tile-wrap .tile{ height: 100%; min-height: 0; }

/* ----------------------- REVIEWS (from the classrooms) ----------------------- */
.reviews-section{
  background: var(--cream);
}
.reviews-section .reviews-head{
  text-align: center;
  margin-bottom: 56px;
}
.reviews-section .reviews-head .eyebrow{
  color: var(--accent-deep);
  display: inline-block;
  margin-bottom: 18px;
}
.reviews-section .reviews-head h2{
  margin: 0 0 18px;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(40px, 5vw, 72px);
  line-height: 1.02;
  letter-spacing: -.008em;
}
.reviews-section .reviews-head h2 em{ font-style: italic; color: var(--accent-deep); }
.reviews-section .rating-summary{
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-family: var(--sans);
  font-size: 14px;
  color: var(--ink-soft);
  letter-spacing: .04em;
}
.reviews-section .rating-summary .stars{
  color: var(--amber);
  font-size: 16px;
  letter-spacing: 2px;
}
.reviews-section .reviews-grid{
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 22px;
}
.reviews-section .review{
  background: var(--warm-white);
  border: 0.5px solid var(--rule);
  border-radius: 2px;
  padding: 28px 30px;
  display: flex;
  flex-direction: column;
}
.reviews-section .review .stars{
  color: var(--amber);
  font-size: 14px;
  letter-spacing: 1px;
  margin-bottom: 18px;
}
.reviews-section .review h3{
  margin: 0 0 16px;
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(20px, 1.8vw, 22px);
  line-height: 1.25;
  letter-spacing: -.005em;
  color: var(--ink);
}
.reviews-section .review p{
  margin: 0 0 18px;
  font-size: 14px;
  line-height: 1.65;
  color: var(--ink-soft);
  flex: 1;
}
.reviews-section .review .who{
  margin: 0;
  padding-top: 16px;
  border-top: 0.5px solid var(--rule);
  font-family: var(--sans);
  font-size: 12px;
  color: var(--stone);
  line-height: 1.45;
}
.reviews-section .review .who strong{ color: var(--ink); font-weight: 600; }
.reviews-section .see-all{
  margin-top: 44px;
  text-align: center;
}
.reviews-section .see-all a{
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  padding-bottom: 4px;
  border-bottom: 0.5px solid var(--ink);
  transition: color .2s ease, border-color .2s ease;
}
.reviews-section .see-all a:hover{ color: var(--forest); border-color: var(--forest); }
@media (max-width: 1080px){
  .reviews-section .reviews-grid{ grid-template-columns: 1fr; gap: 18px; }
}

/* Reviews carousel, generic, MTW-wide educator reviews.
   Swap from .reviews-grid (static 3-up) to a snap-scroll track with
   prev/next arrows and pagination dots. Cards reuse .review styles. */
.reviews-section .reviews-carousel{
  position: relative;
  margin: 0 -8px;
}
.reviews-section .rc-track{
  display: flex;
  gap: 22px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-padding: 8px;
  padding: 6px 8px 18px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.reviews-section .rc-track::-webkit-scrollbar{ display: none; }
.reviews-section .rc-track .review{
  flex: 0 0 calc((100% - 44px) / 3);
  scroll-snap-align: start;
  min-width: 280px;
  margin: 0;
}
.reviews-section .rc-nav{
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 44px; height: 44px;
  background: var(--warm-white);
  border: 0.5px solid var(--rule-strong);
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--serif);
  font-size: 16px;
  color: var(--ink);
  z-index: 2;
  box-shadow: 0 2px 12px rgba(44,44,42,.06);
  transition: background .2s ease, border-color .2s ease, color .2s ease, opacity .2s ease;
}
.reviews-section .rc-nav:hover{ background: var(--ink); color: var(--cream); border-color: var(--ink); }
.reviews-section .rc-nav:disabled{ opacity: .25; cursor: default; }
.reviews-section .rc-nav:disabled:hover{ background: var(--warm-white); color: var(--ink); border-color: var(--rule-strong); }
.reviews-section .rc-nav.prev{ left: -22px; }
.reviews-section .rc-nav.next{ right: -22px; }
.reviews-section .rc-nav svg{ width: 14px; height: 14px; stroke: currentColor; stroke-width: 1.6; fill: none; }
.reviews-section .rc-dots{
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 24px;
}
.reviews-section .rc-dots button{
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--rule-strong);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: background .25s ease, width .25s ease, border-radius .25s ease;
}
.reviews-section .rc-dots button.is-active{
  background: var(--accent-deep);
  width: 22px;
  border-radius: 3px;
}
@media (max-width: 1080px){
  .reviews-section .rc-track .review{ flex: 0 0 86%; }
  .reviews-section .rc-nav{ display: none; }
}
.collection-bridge{
  margin-top: 72px;
  padding: 36px 0 0;
  border-top: 0.5px solid var(--rule-strong);
  text-align: center;
}
.collection-bridge p{
  margin: 0 auto 18px;
  max-width: 56ch;
  font-family: var(--serif);
  font-style: italic;
  font-size: 19px;
  line-height: 1.5;
  color: var(--ink-soft);
}
.collection-bridge p strong{
  font-style: normal;
  font-family: var(--sans);
  font-weight: 600;
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--ink);
  display: block;
  margin-bottom: 10px;
}
.collection-bridge .bridge-cta{
  display: inline-flex;
  align-items: center;
  gap: 12px;
  font-family: var(--sans);
  font-weight: 500;
  font-size: 12px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--cream);
  background: var(--ink);
  border: 1px solid var(--ink);
  border-radius: 2px;
  padding: 16px 28px;
  text-decoration: none;
  transition: background .2s ease, border-color .2s ease;
}
.collection-bridge .bridge-cta:hover{ background: var(--accent-deep); border-color: var(--accent-deep); }
.collection-bridge .bridge-cta::after{
  content: ""; width: 8px; height: 8px;
  border-top: 1px solid currentColor;
  border-right: 1px solid currentColor;
  transform: rotate(45deg);
  display: inline-block;
}

.gallery .quote-strip{
  margin-top: 110px;
  padding: 56px 0;
  border-top: 1px solid var(--rule-soft);
  border-bottom: 1px solid var(--rule-soft);
  text-align: center;
}
.gallery .quote-strip p{
  margin: 0 auto;
  max-width: 32ch;
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(24px, 2.6vw, 36px);
  line-height: 1.35;
  color: var(--ink);
}

/* ============================== COMPANIONS ============================== */
.companions{
  position: relative;
  overflow: hidden;
  color: var(--cream);
  background: var(--hue-3-deep);
}
.companions::after{
  content:""; position:absolute; left:0; right:0; bottom:0; height: 3px; z-index: 2;
  background: linear-gradient(to right, var(--accent) 0%, var(--alt) 50%, var(--hue-3) 100%);
  opacity: .55;
}
.companions .wrap{
  display: grid;
  grid-template-columns: minmax(0, 6fr) minmax(0, 6fr);
  gap: 80px;
  align-items: center;
}
.companions .col-img .tile{ height: 460px; }
.companions .col-txt .eyebrow{ color: color-mix(in oklab, var(--accent-soft) 80%, white); }
.companions h2{
  margin: 22px 0 0;
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(44px, 5.8vw, 92px);
  line-height: .98;
  letter-spacing: -.01em;
}
.companions h2 .it{ color: color-mix(in oklab, var(--accent-soft) 85%, white); }
.companions p.lede{
  margin: 28px 0 0;
  font-family: var(--serif);
  font-style: italic;
  font-size: 22px;
  line-height: 1.55;
  color: rgba(250,246,237,.84);
  max-width: 38ch;
}
.companions .folk{
  margin-top: 48px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.companions .folk .f{
  display: flex;
  flex-direction: column;
}
.companions .folk .f .tile{
  position: relative;
  aspect-ratio: 1 / 1.1;
  width: 100%;
}
.companions .folk .f .name{
  position: static;
  margin: 12px 0 0;
  text-shadow: none;
  font-family: var(--serif);
  font-style: italic;
  font-size: 18px;
  color: var(--cream);
  line-height: 1.2;
  text-align: left;
  display: block;
}
.companions .folk .folk-row{
  margin-top: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}
.companions .folk .folk-price{
  font-family: var(--serif);
  font-weight: 500;
  font-size: 18px;
  color: var(--cream);
  line-height: 1;
}
.companions .folk .folk-price small{
  font-family: var(--sans);
  font-style: normal;
  font-size: 9px;
  letter-spacing: .14em;
  text-transform: uppercase;
  font-weight: 500;
  color: rgba(245,240,229,.55);
  margin-left: 6px;
}
.companions .folk .add-btn.icon{
  padding: 7px 10px;
  background: transparent;
  border: 1px solid rgba(245,240,229,.4);
