}
.companions .folk .add-btn.icon .plus{ width: 11px; height: 11px; }
.companions .price-line{
  margin-top: 36px;
  font-family: var(--sans);
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
