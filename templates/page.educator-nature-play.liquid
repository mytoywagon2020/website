.klaviyo-form-submit button:hover{ background: var(--forest); border-color: var(--forest); }
.klaviyo-form-submit .note{
  font-family: var(--serif);
  font-style: italic;
  font-size: 13px;
  color: var(--stone);
  line-height: 1.45;
  max-width: 36ch;
}
@media (max-width: 1080px){
  .klaviyo-strip-inner{ grid-template-columns: 1fr; gap: 32px; }
}
footer .cols .downloads li{
  font-family: var(--sans);
  font-style: normal;
  font-size: 13px;
  line-height: 1.4;
  margin-bottom: 4px;
}
footer .cols .downloads a{
  display: inline-flex;
  align-items: baseline;
  gap: 6px;
  text-decoration: none;
  color: rgba(250,246,237,.86);
  padding: 4px 0;
  transition: color .2s ease;
}
footer .cols .downloads a:hover{ color: color-mix(in oklab, var(--accent-soft) 80%, white); }
footer .cols .downloads a::after{
  content: attr(data-ext);
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .12em;
  color: rgba(250,246,237,.5);
