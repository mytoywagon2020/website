      slides[i].classList.add('is-active');
    }, 5000);
  })();

  // Reviews carousel. Generic horizontal-scroll snap track with
  // arrow buttons and pagination dots. Number of dots equals the
  // number of "pages", page width = visible track width. We compute
  // page count from track scrollWidth / clientWidth so it adapts to
  // breakpoints automatically.
  (function(){
    document.querySelectorAll('[data-reviews-carousel]').forEach(function(carousel){
      var track = carousel.querySelector('.rc-track');
      var prev  = carousel.querySelector('.rc-nav.prev');
      var next  = carousel.querySelector('.rc-nav.next');
      var dotsHost = carousel.querySelector('.rc-dots');
      if (!track) return;

      function pageCount(){
        return Math.max(1, Math.ceil(track.scrollWidth / track.clientWidth));
      }
      function currentPage(){
        return Math.round(track.scrollLeft / track.clientWidth);
      }
      function buildDots(){
        if (!dotsHost) return;
        var count = pageCount();
        dotsHost.innerHTML = '';
        for (var i = 0; i < count; i++){
          var b = document.createElement('button');
          b.type = 'button';
          b.setAttribute('role', 'tab');
          b.setAttribute('aria-label', 'Go to reviews page ' + (i + 1));
          (function(idx){
            b.addEventListener('click', function(){
              track.scrollTo({ left: idx * track.clientWidth, behavior: 'smooth' });
            });
          })(i);
          dotsHost.appendChild(b);
        }
        syncDots();
      }
      function syncDots(){
        if (!dotsHost) return;
        var p = currentPage();
        Array.prototype.forEach.call(dotsHost.children, function(d, i){
          d.classList.toggle('is-active', i === p);
        });
      }
      function syncNav(){
        if (prev) prev.disabled = track.scrollLeft <= 2;
        if (next) next.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
      }
      function scrollByPage(dir){
        track.scrollBy({ left: dir * track.clientWidth, behavior: 'smooth' });
      }

      if (prev) prev.addEventListener('click', function(){ scrollByPage(-1); });
      if (next) next.addEventListener('click', function(){ scrollByPage(1); });
      track.addEventListener('scroll', function(){ syncDots(); syncNav(); }, { passive: true });
      window.addEventListener('resize', function(){ buildDots(); syncNav(); });

      buildDots();
      syncNav();
    });
  })();

  // Long-lead pill, auto-tags any element with data-long-lead="true" with a
  // "Ships separately" pill. Wire SKUs as they're added to the slow-ship list
  // by adding data-long-lead="true" to the .home / .kit / .split card.
  (function(){
    document.querySelectorAll('[data-long-lead="true"]').forEach(function(card){
      if (card.querySelector('.ships-separately-pill')) return;
      var pill = document.createElement('span');
      pill.className = 'ships-separately-pill';
      pill.textContent = 'Ships separately';
      var anchor = card.querySelector('.add-row, .add-btn, .price-line, .price');
      if (anchor) anchor.parentNode.insertBefore(pill, anchor);
      else card.appendChild(pill);
    });
  })();

