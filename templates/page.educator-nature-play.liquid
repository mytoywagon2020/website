        var kitCustom = document.querySelector('input[name="kit"][value="custom"]');
        if (kitCustom) kitCustom.checked = true;
        var notes = document.getElementById('qf-notes');
        if (notes) {
          var line = 'Split-PO request: ' + name + ' (' + sku + '). Please split this order across multiple line-item invoices to fit our purchasing thresholds.';
          notes.value = notes.value ? (notes.value.replace(/\s+$/,'') + '\n' + line) : line;
        }
      });
    });
  })();
