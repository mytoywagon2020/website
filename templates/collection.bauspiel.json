        },
        "t2": {
          "type": "text",
          "settings": {
            "enlarge_text": true,
            "text": "<p>Bauspiel's range progresses with developmental milestones. Toddlers explore color and shape with simple stacking blocks and color staircases. Preschoolers move on to castle extensions and storytelling sets, building role-play and narrative skills. Older children create complex architectures with lucent cubes and mirror blocks. Each set extends the others, so a family's Bauspiel collection becomes a lifetime of play rather than a stage to outgrow.</p>"
          }
        },
